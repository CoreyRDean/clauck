def cmd_semantic(text: str) -> None:
    """Two-stage natural-language command pipeline.

    Stage 1: Cheap Haiku interpreter classifies the command (~$0.01).
    Stage 2: Either run a deterministic command or execute with the
             interpreter-chosen model/effort/turns/budget.
    """
    import re as _re
    import threading
    import time as _time

    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — semantic commands require claude on PATH")

    # ── Spinner (wraps both stages) ──────────────────────────────────────
    spinner_running = [True]
    spinner_label = ["mining intent"]
    start_time = _time.time()

    def spinner():
        chars = "\u280b\u2819\u2839\u2838\u283c\u2834\u2826\u2827\u2807\u280f"
        i = 0
        while spinner_running[0]:
            elapsed = int(_time.time() - start_time)
            label = spinner_label[0]
            sys.stderr.write(f"\r  {chars[i % len(chars)]} {label}... ({elapsed}s)")
            sys.stderr.flush()
            i += 1
            _time.sleep(0.1)
        sys.stderr.write("\r" + " " * 50 + "\r")
        sys.stderr.flush()

    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # ── Stage 1: Interpreter ────────────────────────────────────────────
    interpreter_prompt = _build_interpreter_prompt()
    user_prompt = f"The user ran: `clauck {text}`"

    # Use strict-mcp-config with empty config so the interpreter runs bare
    # (no MCP surface cache-creation cost). Without this, $0.05 budget is
    # consumed immediately by MCP tool prompt.
    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        empty_mcp.write_text('{"mcpServers":{}}')

    try:
        # Use Sonnet for reliability — Haiku was generating explanatory prose
        # instead of strict JSON on edge cases. Cost increase is marginal
        # (~$0.03-0.05 vs $0.01) and the reliability is worth it.
        result_s1 = subprocess.run(
            [claude_bin, "-p", user_prompt,
             "--append-system-prompt", interpreter_prompt,
             "--model", "sonnet",
             "--max-turns", "3",
             "--max-budget-usd", "0.20",
             "--output-format", "json",
             "--setting-sources", "",
             "--strict-mcp-config",
             "--mcp-config", str(empty_mcp)],
            capture_output=True, text=True,
        )
    except Exception:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        raise

    # Parse the interpreter envelope (claude -p --output-format json gives
    # {"result": "...", "is_error": ..., ...}); the inner result is our JSON.
    routing = {}
    interpreter_error = ""
    if result_s1.returncode == 0 and result_s1.stdout.strip():
        try:
            envelope = json.loads(result_s1.stdout)
            inner = envelope.get("result", "").strip()
            # Find the JSON object in the inner text
            json_match = _re.search(r'\{[\s\S]*\}', inner)
            if json_match:
                routing = json.loads(json_match.group(0))
            else:
                interpreter_error = f"no JSON found in interpreter output: {inner[:200]}"
        except (json.JSONDecodeError, ValueError) as e:
            interpreter_error = f"interpreter JSON parse failed: {e}"
    elif result_s1.returncode != 0:
        interpreter_error = f"interpreter exited {result_s1.returncode}: {result_s1.stderr[:200]}"

    if not routing or "command_type" not in routing:
        # Interpreter failed — log the reason, fall back with honest marker
        if interpreter_error:
            sys.stderr.write(f"\r  ! interpreter fallback: {interpreter_error[:120]}\n")
            sys.stderr.flush()
        routing = {
            "command_type": "semantic",
            "interpretation": f"(interpreter failed — raw request passed through)",
            "enhanced_prompt": text,
            "exec_model": "sonnet",
            "exec_effort": "medium",
            "exec_max_turns": 15,
            "exec_max_budget_usd": 0.50,
        }

    interpretation = routing.get("interpretation", text)

    # ── Stage 2: Dispatch ───────────────────────────────────────────────

    if routing["command_type"] == "deterministic":
        # Stop spinner, print interpretation, then run the deterministic command
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        print(f"  \u2192 {interpretation}")

        # Two supported formats from the interpreter, in priority order:
        #
        # 1. `deterministic_argv`: a JSON array of tokens, e.g.
        #    ["clauck", "fire", "pe-pipeline", "SOURCE_CONTENT=long text with spaces"]
        #    This is the preferred format because it's unambiguous — no
        #    tokenization pass, no quoting rules for the model to get right.
        #
        # 2. `deterministic_cmd`: a single shell-style string (legacy).
        #    We parse with shlex.split so quoted values survive:
        #    `clauck fire pe-pipeline SOURCE_CONTENT="long text with spaces"`
        #    A naive .split() (which this used to do) truncated multi-word
        #    arg values at the first space, causing pipelines like pe-pipeline
        #    to receive only the first word of SOURCE_CONTENT.
        argv = routing.get("deterministic_argv")
        if isinstance(argv, list) and argv:
            parts = [str(a) for a in argv]
        else:
            det_cmd = routing.get("deterministic_cmd", "").strip()
            if not det_cmd:
                die("interpreter returned deterministic but no command/argv")
            import shlex as _shlex
            try:
                parts = _shlex.split(det_cmd)
            except ValueError as e:
                # Malformed quoting. Fall back to naive split with a loud
                # warning so the bug is visible, not silent truncation.
                print(
                    f"  ! shlex parse failed ({e}); falling back to naive split — "
                    f"multi-word arg values will be truncated",
                    file=sys.stderr,
                )
                parts = det_cmd.split()

        if parts and parts[0] == "clauck":
            parts = parts[1:]
        if parts and parts[0] == "bash":
            # Direct trigger-job.sh invocation
            result = subprocess.run(parts, capture_output=True, text=True)
            print(result.stdout.strip())
            if result.returncode != 0:
                print(result.stderr.strip(), file=sys.stderr)
                sys.exit(result.returncode)
        elif parts:
            # Re-enter clauck's own main dispatch
            sys.argv = ["clauck"] + parts
            main()
        else:
            die(f"could not parse deterministic command: argv={argv!r} cmd={routing.get('deterministic_cmd', '')!r}")
        return

    # semantic path — run execution pass with interpreter-chosen parameters
    # Temporarily pause spinner to print interpretation, then resume with new label
    spinner_running[0] = False
    spin_thread.join(timeout=0.5)
    print(f"  \u2192 {interpretation}")
    print(f"  {'─' * 60}")

    exec_model = routing.get("exec_model", "sonnet")
    exec_effort = routing.get("exec_effort", "medium")
    exec_max_turns = str(routing.get("exec_max_turns", 15))
    exec_max_budget = str(routing.get("exec_max_budget_usd", 0.50))
    enhanced_prompt = routing.get("enhanced_prompt", text)

    system_prompt = SEMANTIC_EXEC_SYSTEM_PROMPT.replace("{JOBS_DIR}", str(JOBS_DIR))
    system_prompt = system_prompt.replace("{MANIFEST}", str(MANIFEST))
    system_prompt = system_prompt.replace("{STATE_DIR}", str(STATE_DIR))
    system_prompt = system_prompt.replace("{MARKETPLACE_DIR}", str(MARKETPLACE_DIR))
    system_prompt = system_prompt.replace("{CONFIG_FILE}", str(CONFIG_FILE))
    system_prompt = system_prompt.replace("{TRIGGER_SCRIPT}", str(TRIGGER_SCRIPT))

    # Restart spinner for stage 2 with updated label
    spinner_running[0] = True
    spinner_label[0] = f"executing ({exec_model}, {exec_effort} effort)"
    start_time = _time.time()
    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # Explicit permission allowlist for the scheduled-jobs directory.
    # Recent claude CLI versions added extra guards on .claude/ paths that
    # --dangerously-skip-permissions + --permission-mode bypassPermissions
    # don't override. --settings injects explicit allow rules that do.
    allowlist_settings = json.dumps({
        "permissions": {
            "defaultMode": "bypassPermissions",
            "allow": [
                "Bash(*)",
                "Write(**)",
                "Edit(**)",
                "Read(**)",
                f"Write({JOBS_DIR}/**)",
                f"Edit({JOBS_DIR}/**)",
                f"Bash(rm *{JOBS_DIR}/*)",
                f"Bash(mkdir *{JOBS_DIR}/*)",
            ],
        }
    })

    try:
        result = subprocess.run(
            [claude_bin, "-p", enhanced_prompt,
             "--append-system-prompt", system_prompt,
             "--dangerously-skip-permissions",
             "--permission-mode", "bypassPermissions",
             "--settings", allowlist_settings,
             "--max-turns", exec_max_turns,
             "--max-budget-usd", exec_max_budget,
             "--model", exec_model,
             "--effort", exec_effort,
             "--output-format", "json",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
    finally:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)

    # Parse Claude's JSON envelope
    try:
        envelope = json.loads(result.stdout) if result.stdout else {}
    except (json.JSONDecodeError, ValueError):
        envelope = {}

    is_error = envelope.get("is_error", result.returncode != 0)
    claude_result = envelope.get("result", "").strip()

    if claude_result:
        print(claude_result)

    if is_error:
        err_text = envelope.get("errors") or result.stderr
        if err_text:
            if isinstance(err_text, list):
                err_text = "; ".join(str(e) for e in err_text)
            print(str(err_text).strip(), file=sys.stderr)
        sys.exit(1)


# ── main ─────────────────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    # JIT update notice (reads local state file, no network)
    jit_update_check()

    cmd = args[0]
    rest = args[1:]

    if cmd == "list":
        cmd_list()
    elif cmd == "next":
        cmd_next()
    elif cmd == "status":
        cmd_status()
    elif cmd == "fire" and rest:
        cmd_fire(rest[0], extra_args=rest[1:])
    elif cmd == "pause" and rest:
        cmd_pause(rest[0])
    elif cmd == "resume" and rest:
        cmd_resume(rest[0])
    elif cmd == "edit" and rest:
        cmd_edit(rest[0])
    elif cmd in ("remove", "delete", "rm") and rest:
        cmd_remove(rest[0])
    elif cmd == "logs" and rest:
        last = 5
        if "--last" in rest:
            idx = rest.index("--last")
            if idx + 1 < len(rest):
                last = int(rest[idx + 1])
            rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
        cmd_logs(rest[0], last)
    elif cmd == "marketplace":
        cmd_marketplace(filter_tag=rest[0] if rest else "")
    elif cmd == "install" and rest:
        cmd_install_marketplace(rest[0])
    elif cmd == "update":
        cmd_update(apply="--apply" in rest)
    elif cmd == "uninstall":
        cmd_uninstall(wipe="--wipe" in rest)
    elif cmd == "config":
        cmd_config(rest)
    elif cmd == "version":
        cmd_version()
    elif cmd == "peek":
        cmd_peek()
    elif cmd == "add" and rest:
        add_path = ""
        add_name = ""
        add_when = ""
        i = 0
        while i < len(rest):
            if rest[i] == "--name" and i + 1 < len(rest):
                add_name = rest[i + 1]
                i += 2
            elif rest[i] == "--when" and i + 1 < len(rest):
                add_when = rest[i + 1]
                i += 2
            elif not add_path:
                add_path = rest[i]
                i += 1
            else:
                i += 1
        if not add_path:
            die("usage: clauck add <path> [--name NAME] [--when \"schedule\"]")
        cmd_add(add_path, name=add_name, when=add_when)
    elif cmd == "inspect" and rest:
        cmd_inspect(rest[0])
    elif cmd == "doctor":
        # Flag parsing: modes are two pairs with defaults biased toward safety.
        #   --dry (default) / --fix   — analysis-only vs apply fixes
        #   --safe (default) / --unsafe — restrict vs allow system-file mutation
        interactive = "-i" in rest or "--interactive" in rest
        fix_flag = "--fix" in rest
        unsafe_flag = "--unsafe" in rest
        # Explicit --dry and --safe are accepted but are already defaults.
        dry_flag = "--dry" in rest or not fix_flag
        safe_flag = "--safe" in rest or not unsafe_flag
        flag_names = {
            "-i", "--interactive", "--dry", "--fix", "--safe", "--unsafe",
        }
        context_parts = [r for r in rest if not r.startswith("-") and r not in flag_names]
        cmd_doctor(
            dry=dry_flag,
            fix=fix_flag,
            safe=safe_flag,
            unsafe=unsafe_flag,
            interactive=interactive,
            context=" ".join(context_parts),
        )
    elif cmd == "work":
        # `clauck work <text>` is an explicit alias for semantic fallthrough,
        # avoiding conflicts if semantic text starts with a subcommand name.
        cmd_semantic(" ".join(rest) if rest else "show system status")
    elif cmd not in KNOWN_COMMANDS:
        # Semantic fallthrough: anything that isn't a known command is treated
        # as natural-language input for Claude to interpret as a clauck operation.
        cmd_semantic(" ".join(args))
    else:
        print(f"missing argument for: {cmd}", file=sys.stderr)
        print("run `clauck --help` for usage", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
