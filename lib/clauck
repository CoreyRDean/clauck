# ── helpers ──────────────────────────────────────────────────────────────

def jit_update_check() -> None:
    """Print a one-line update notice if a new version is available.
    Reads the state file left by the background update-check; no network.

    Self-healing: if the installed version (.version file) has caught up to
    the 'latest' recorded in the state file, the state is stale — delete it
    silently. This handles cases where an update applied successfully but
    the state file wasn't cleared (e.g., verification step failed due to
    unrelated issues after files were already copied).
    """
    available = STATE_DIR / ".update-available"
    if not available.exists():
        return
    try:
        upd = json.loads(available.read_text())
        latest = upd.get("latest", "?")
        # Read LIVE installed version, not the stale one from the state file
        installed = "?"
        if VERSION_FILE.exists():
            installed = VERSION_FILE.read_text().strip() or "?"
        if installed == latest and installed != "?":
            # Update already applied — clean up stale marker
            available.unlink()
            return
        if installed != latest:
            print(f"\033[33m  update available: {installed} → {latest}"
                  f" (run: clauck update --apply)\033[0m")
    except (OSError, ValueError, KeyError):
        pass


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def load_manifest() -> dict:
    if not MANIFEST.exists():
        die("manifest not found — is clauck installed?")
    return json.loads(MANIFEST.read_text())


def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except (OSError, ValueError):
            return {}
    return {}


def job_state(name: str) -> dict:
    """Collect state info for a single job."""
    info: dict = {}
    lr = STATE_DIR / f"{name}.last-run"
    if lr.exists():
        try:
            ts = int(lr.read_text().strip())
            info["last_run"] = datetime.fromtimestamp(ts).isoformat()
        except (OSError, ValueError):
            pass
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        try:
            info["auto_disabled"] = json.loads(ad.read_text())
        except (OSError, ValueError):
            info["auto_disabled"] = True
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        try:
            info["runs_remaining"] = int(rr.read_text().strip())
        except (OSError, ValueError):
            pass
    sid = STATE_DIR / f"{name}.session-id"
    if sid.exists():
        info["session_id"] = sid.read_text().strip()
    return info


# ── cron helpers (mirrors scheduler.py; duplicated to keep clauck standalone) ──

def _cron_part_matches(part: str, value: int, lo: int, hi: int, aliases=None) -> bool:
    step = 1
    if "/" in part:
        base, _, step_s = part.partition("/")
        step = int(step_s)
    else:
        base = part
    if base in ("*", ""):
        start, end = lo, hi
    elif "-" in base:
        a, _, b = base.partition("-")
        start, end = int(a), int(b)
    else:
        n = int(base)
        if aliases and n in aliases:
            n = aliases[n]
        if step > 1:
            return value == n
        return value == n
    return lo <= value <= hi and start <= value <= end and ((value - start) % step == 0)


def _cron_field_matches(field_expr: str, value: int, lo: int, hi: int, aliases=None) -> bool:
    return any(_cron_part_matches(p, value, lo, hi, aliases) for p in field_expr.split(","))


def _cron_matches(expr: str, dt: datetime) -> bool:
    """Return True if *expr* matches *dt* (minute precision, 5-field cron)."""
    fields = expr.strip().split()
    if len(fields) != 5:
        raise ValueError(f"cron must have 5 fields: {expr!r}")
    minute, hour, dom, month, dow = fields
    wd = dt.isoweekday() % 7  # Mon=1..Sun=7 → Sun=0..Sat=6 (cron convention)
    return (
        _cron_field_matches(minute, dt.minute, 0, 59)
        and _cron_field_matches(hour, dt.hour, 0, 23)
        and _cron_field_matches(dom, dt.day, 1, 31)
        and _cron_field_matches(month, dt.month, 1, 12)
        and _cron_field_matches(dow, wd, 0, 6, {7: 0})
    )


def _cron_next(expr: str, from_dt: datetime) -> "datetime | None":
    """First minute strictly after *from_dt* that matches *expr*.

    Scans minute-by-minute up to 8 days out.  Returns None if the
    expression never matches in that window (broken / extremely sparse cron).
    """
    candidate = from_dt.replace(second=0, microsecond=0) + timedelta(minutes=1)
    limit = from_dt + timedelta(days=8)
    while candidate <= limit:
        try:
            if _cron_matches(expr, candidate):
                return candidate
        except ValueError:
            return None
        candidate += timedelta(minutes=1)
    return None


def _fmt_next_fire(next_dt: datetime, now: datetime) -> str:
    """Human-readable relative + absolute fire time string."""
    delta = next_dt - now
    total_minutes = max(1, int(delta.total_seconds() / 60))

    if total_minutes < 60:
        rel = f"in {total_minutes}m"
    elif total_minutes < 24 * 60:
        hours = total_minutes // 60
        mins = total_minutes % 60
        rel = f"in {hours}h {mins}m" if mins else f"in {hours}h"
    else:
        days = total_minutes // (24 * 60)
        hours = (total_minutes % (24 * 60)) // 60
        rel = f"in {days}d {hours}h" if hours else f"in {days}d"

    if next_dt.date() == now.date():
        abs_str = f"today {next_dt.strftime('%H:%M')}"
    elif next_dt.date() == (now + timedelta(days=1)).date():
        abs_str = f"tomorrow {next_dt.strftime('%H:%M')}"
    else:
        abs_str = next_dt.strftime("%a %H:%M")

    return f"{rel:<12}({abs_str})"


# ── commands ─────────────────────────────────────────────────────────────

def cmd_next() -> None:
    """Show when each job will next fire."""
    m = load_manifest()
    jobs = m.get("jobs", [])
    if not jobs:
        print("No jobs registered.")
        return

    now = datetime.now()
    name_w = max((len(j["name"]) for j in jobs), default=10) + 2

    for j in jobs:
        name = j["name"]
        cron = j.get("cron", "").strip()
        triggers = j.get("external_triggers", [])
        disabled = j.get("disabled", False)
        state = job_state(name)

        paused = disabled or bool(state.get("auto_disabled"))
        if paused:
            ad = state.get("auto_disabled")
            if isinstance(ad, dict):
                reason = ad.get("reason", "auto-disabled")
                status = f"[{reason}]"
            elif ad:
                status = "[auto-disabled]"
            else:
                status = "[paused]"
        elif cron:
            nf = _cron_next(cron, now)
            status = _fmt_next_fire(nf, now) if nf else "(no match in 8d)"
        elif triggers:
            types = sorted({
                t.get("type", "?") if isinstance(t, dict) else "?"
                for t in triggers
            })
            status = f"event-driven  ({', '.join(types)})"
        else:
            status = "ad-hoc only"

        cron_display = cron[:20] if cron else "—"
        print(f"  {name:<{name_w}}  {cron_display:<22}  {status}")


def cmd_list() -> None:
    m = load_manifest()
    jobs = m.get("jobs", [])
    if not jobs:
        print("No jobs registered.")
        return
    for j in jobs:
        name = j["name"]
        cron = j.get("cron") or "(no cron)"
        desc = j.get("description", "")[:60]
        disabled = j.get("disabled", False)
        state = job_state(name)

        status = "active"
        if disabled:
            status = "paused"
        elif state.get("auto_disabled"):
            reason = ""
            if isinstance(state["auto_disabled"], dict):
                reason = f" ({state['auto_disabled'].get('reason', '')})"
            status = f"auto-disabled{reason}"

        extra = ""
        if "runs_remaining" in state:
            extra += f"  runs left: {state['runs_remaining']}"
        if "last_run" in state:
            extra += f"  last: {state['last_run']}"

        print(f"  {name:<25} {cron:<20} [{status}]")
        if desc:
            print(f"    {desc}")
        if extra:
            print(f"   {extra}")


def cmd_status() -> None:
    version = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"
    config = load_config()

    # Check if scheduler is loaded
    result = subprocess.run(
        ["launchctl", "list"],
        capture_output=True, text=True,
    )
    scheduler_running = "claude-scheduler" in result.stdout

    m = load_manifest() if MANIFEST.exists() else {"jobs": []}
    job_count = len(m.get("jobs", []))

    # Count logs
    log_count = len(list(JOBS_DIR.glob("*-[0-9]*.log")))

    auto_update = config.get("auto_update", {})
    repo = config.get("repo", "CoreyRDean/clauck")

    print(f"  clauck {version}")
    print(f"  scheduler: {'running' if scheduler_running else 'NOT RUNNING'}")
    print(f"  jobs: {job_count}")
    print(f"  logs: {log_count}")
    print(f"  repo: {repo}")
    print(f"  auto-update: {'enabled' if auto_update.get('enabled', True) else 'disabled'}"
          f" (auto-apply: {'on' if auto_update.get('auto_apply', False) else 'off'})")

    # Check for pending update
    available = STATE_DIR / ".update-available"
    if available.exists():
        try:
            upd = json.loads(available.read_text())
            print(f"  UPDATE AVAILABLE: {upd.get('installed')} → {upd.get('latest')}")
        except (OSError, ValueError):
            pass


def cmd_fire(name: str, extra_args: list[str] | None = None) -> None:
    if not TRIGGER_SCRIPT.exists():
        die("trigger-job.sh not found")

    args = list(extra_args or [])

    # If any arg is missing '=', treat the tail as semantic context and use the
    # interpreter to convert it to proper KEY=VALUE args.
    if args and any("=" not in a for a in args):
        claude_bin = _find_claude()
        if claude_bin:
            m = load_manifest()
            job_entry = next((j for j in m.get("jobs", []) if j["name"] == name), None)
            declared_inputs = ""
            if job_entry:
                for inp in job_entry.get("inputs", []):
                    if isinstance(inp, dict):
                        iname = inp.get("name", "?")
                        idesc = inp.get("description", "")
                        idefault = inp.get("default", "")
                        declared_inputs += f"  - {iname}: {idesc}"
                        if idefault:
                            declared_inputs += f" (default: {idefault})"
                        declared_inputs += "\n"
                    else:
                        declared_inputs += f"  - {inp}\n"

            semantic_tail = " ".join(args)
            interpret_prompt = (
                f"The user ran: `clauck fire {name} {semantic_tail}`\n"
                f"Job `{name}` declares these inputs:\n{declared_inputs}\n"
                f"Convert the semantic tail into KEY=VALUE args matching the declared inputs.\n"
                f'Return JSON only: {{"args": ["KEY1=VAL1", "KEY2=VAL2"]}}'
            )
            result = subprocess.run(
                [claude_bin, "-p", interpret_prompt,
                 "--max-turns", "3", "--max-budget-usd", "0.05",
                 "--model", "haiku", "--output-format", "text",
                 "--setting-sources", ""],
                capture_output=True, text=True,
            )
            if result.returncode == 0 and result.stdout.strip():
                import re as _re
                raw = result.stdout.strip()
                # Extract JSON from response (may be wrapped in markdown)
                json_match = _re.search(r'\{[^}]+\}', raw)
                if json_match:
                    try:
                        parsed = json.loads(json_match.group(0))
                        resolved = parsed.get("args", [])
                        if resolved and all("=" in a for a in resolved):
                            print(f"  resolved args: {' '.join(resolved)}")
                            args = resolved
                    except (json.JSONDecodeError, KeyError):
                        pass

    cmd = [str(TRIGGER_SCRIPT), name] + args
    result = subprocess.run(cmd, capture_output=True, text=True)
    print(result.stdout.strip())
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)


def cmd_pause(name: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    (STATE_DIR / f"{name}.auto-disabled").write_text(
        json.dumps({"reason": "paused via clauck CLI", "at": datetime.now(timezone.utc).isoformat()})
    )
    print(f"  paused: {name}")


def cmd_resume(name: str) -> None:
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        ad.unlink()
        print(f"  resumed: {name}")
    else:
        print(f"  {name} is not paused/auto-disabled")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_remove(name: str) -> None:
    """Delete a job (standard or module format) + clean up its state.

    Direct filesystem operation — no LLM, no permission prompts.
    """
    import shutil as _shutil
    removed = []

    # Standard format: <name>.md
    flat = JOBS_DIR / f"{name}.md"
    if flat.exists():
        flat.unlink()
        removed.append(str(flat))

    # Module format: <name>/ directory with JOB.md
    module = JOBS_DIR / name
    if module.is_dir() and (module / "JOB.md").exists():
        _shutil.rmtree(module)
        removed.append(f"{module}/ (module)")

    # Clean up state: last-run, session-id, runs-remaining, auto-disabled,
    # producer-outputs, lock.d, trigger state files
    state_patterns = [
        f"{name}.last-run",
        f"{name}.last-start",
        f"{name}.session-id",
        f"{name}.runs-remaining",
        f"{name}.auto-disabled",
    ]
    for pattern in state_patterns:
        f = STATE_DIR / pattern
        if f.exists():
            f.unlink()
    # Glob patterns: lock dirs, producer-outputs, trigger state
    import glob as _glob
    for pat in [
        f"{STATE_DIR}/{name}.lock.d",
        f"{STATE_DIR}/{name}.lock.d/*",
        f"{STATE_DIR}/{name}.producer-outputs-*.json",
        f"{STATE_DIR}/{name}.trigger-*.json",
        f"{STATE_DIR}/{name}.runs-remaining",
    ]:
        for match in _glob.glob(pat):
            p = Path(match)
            if p.is_dir():
                _shutil.rmtree(p)
            elif p.exists():
                p.unlink()

    # Remove logs? User might want them for audit. Leave them — they rotate naturally.

    if not removed:
        die(f"no job found: {name} (checked {flat} and {module}/JOB.md)")

    for r in removed:
        print(f"  removed: {r}")
    print(f"  (logs preserved at {JOBS_DIR}/{name}-*.log)")


def cmd_edit(name: str) -> None:
    """Open job prompt in user's editor, validate on close."""
    job_file = JOBS_DIR / f"{name}.md"
    if not job_file.exists():
        die(f"no job file: {job_file}")

    # Determine editor: VISUAL > EDITOR > fallback
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "nano"

    import shlex
    editor_parts = shlex.split(editor)

    # Record mtime before editing
    mtime_before = job_file.stat().st_mtime

    result = subprocess.run(editor_parts + [str(job_file)])
    if result.returncode != 0:
        print(f"  editor exited with code {result.returncode}", file=sys.stderr)
        return

    # Check if file was modified
    mtime_after = job_file.stat().st_mtime
    if mtime_after == mtime_before:
        print("  no changes detected")
        return

    # Static analysis: check frontmatter parses
    text = job_file.read_text()
    import re
    fm_match = re.match(r"\A---\s*\n(.*?)\n---\s*\n", text, re.DOTALL)
    if not fm_match:
        print("\033[33m  warning: no YAML frontmatter detected (missing --- delimiters)\033[0m")
        return

    # Validate required-ish fields
    fm_text = fm_match.group(1)
    issues = []
    if "cron:" not in fm_text and "external_triggers:" not in fm_text:
        issues.append("no cron or external_triggers — job will only fire via ad-hoc trigger")
    if "max_budget_usd:" not in fm_text:
        issues.append("no max_budget_usd — will use default ($2.00)")
    if "model:" not in fm_text:
        issues.append("no model specified — will use claude default (Opus)")

    if issues:
        print("\033[33m  notes:\033[0m")
        for issue in issues:
            print(f"    - {issue}")
    else:
        print("  \033[32m✓\033[0m saved, looks good. Changes take effect within 60s.")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_logs(name: str, last: int = 5) -> None:
    pattern = f"{name}-[0-9]*.log"
    logs = sorted(JOBS_DIR.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    if not logs:
        print(f"  no logs found for: {name}")
        return
    for log in logs[:last]:
        # Extract key info from log
        text = log.read_text()
        exit_line = ""
        cost = ""
        for line in text.splitlines():
            if "exit_code=" in line:
                exit_line = line.strip()
            if '"total_cost_usd"' in line:
                import re
                m = re.search(r'"total_cost_usd":([\d.]+)', line)
                if m:
                    cost = f"${float(m.group(1)):.4f}"
        ts = log.stem.split("-", 1)[1] if "-" in log.stem else "?"
        print(f"  {ts:<30} {exit_line:<25} {cost}")


def cmd_marketplace(filter_tag: str = "") -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found — run the installer to populate it")
    index = json.loads(index_file.read_text())
    jobs = index.get("jobs", [])

    if filter_tag:
        ft = filter_tag.lower()
        jobs = [j for j in jobs if ft in [t.lower() for t in j.get("tags", [])]]
        if not jobs:
            print(f"  no jobs matching tag: {filter_tag}")
            # Show available tags
            all_tags = set()
            for j in index.get("jobs", []):
                all_tags.update(j.get("tags", []))
            print(f"  available tags: {', '.join(sorted(all_tags))}")
            return

    # Group by first tag (category) for display
    seen_categories: set = set()
    for j in jobs:
        tags = j.get("tags", [])
        category = tags[0] if tags else "uncategorized"
        if category not in seen_categories:
            seen_categories.add(category)
            print(f"\n  [{category}]")
        installed = (JOBS_DIR / f"{j['name']}.md").exists()
        marker = " [installed]" if installed else ""
        cost = j.get("cost_per_run_usd_approx", "?")
        print(f"    {j['name']:<23} ~${cost}/run  {j.get('schedule', '')}{marker}")
        print(f"      {j.get('one_line', '')}")

    # Show all tags
    all_tags = set()
    for j in index.get("jobs", []):
        all_tags.update(j.get("tags", []))
    print(f"\n  filter by tag: clauck marketplace <tag>")
    print(f"  tags: {', '.join(sorted(all_tags))}")


def cmd_install_marketplace(name: str) -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found")
    index = json.loads(index_file.read_text())
    match = [j for j in index.get("jobs", []) if j["name"] == name]
    if not match:
        die(f"no marketplace job named '{name}'. Run `clauck marketplace` to see available jobs.")
    job = match[0]
    src = MARKETPLACE_DIR / job["path"]
    if not src.exists():
        die(f"marketplace file missing: {src}")
    dst = JOBS_DIR / f"{name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or edit directly.")
    import shutil
    shutil.copy2(str(src), str(dst))
    print(f"  installed: {dst}")
    setup = job.get("requires", {}).get("setup", [])
    if setup:
        print(f"  CUSTOMIZE BEFORE FIRST RUN:")
        for step in setup:
            print(f"    - {step}")
    print(f"  test: clauck fire {name}")


def cmd_update(apply: bool = False) -> None:
    if not UPDATE_SCRIPT.exists():
        die("update-check.sh not found")
    args = [str(UPDATE_SCRIPT)]
    if apply:
        args.append("--apply")
    os.execvp(args[0], args)


def cmd_uninstall(wipe: bool = False) -> None:
    """Invoke the LOCAL uninstall.sh that shipped with the installed version.

    Running the remote latest uninstall.sh against an older local install can
    leave orphaned files behind if the file layout changed between versions.
    By always using the local copy, the uninstall step is version-matched
    with the install it's removing.

    Falls back to telling the user how to run it directly if the local copy
    is missing (e.g., an older install that predates this CLI command).
    """
    if not UNINSTALL_SCRIPT.exists():
        print(
            "uninstall.sh not found at expected local path.\n"
            f"  expected: {UNINSTALL_SCRIPT}\n"
            "Your install predates `clauck uninstall`. Re-run the installer "
            "once to pick up the local copy, then retry. Or run the remote "
            "uninstaller:\n"
            "  bash <(curl -sSL https://raw.githubusercontent.com/CoreyRDean/clauck/main/uninstall.sh)"
            + ("  --wipe" if wipe else ""),
            file=sys.stderr,
        )
        sys.exit(1)
    args = ["/bin/bash", str(UNINSTALL_SCRIPT)]
    if wipe:
        args.append("--wipe")
    os.execvp(args[0], args)


def cmd_config(args: list[str]) -> None:
    if not args or args[0] != "set":
        config = load_config()
        print(json.dumps(config, indent=2))
        return
    # clauck config set <dotted.key> <value>
    if len(args) < 3:
        die("usage: clauck config set <key> <value>")
    key_path = args[1].split(".")
    value = args[2]
    # Coerce value
    if value.lower() == "true":
        value = True
    elif value.lower() == "false":
        value = False
    else:
        try:
            value = int(value)
        except ValueError:
            try:
                value = float(value)
            except ValueError:
                pass
    config = load_config()
    # Navigate to the nested key
    d = config
    for k in key_path[:-1]:
        d = d.setdefault(k, {})
    d[key_path[-1]] = value
    CONFIG_FILE.write_text(json.dumps(config, indent=2) + "\n")
    print(f"  set {args[1]} = {value}")


def cmd_peek() -> None:
    """Live-tail all job + scheduler + DAG logs in a unified stream."""
    import signal

    print("  clauck peek — live log stream (Ctrl+C to stop)\n")

    # Build the tail command: scheduler stdout/stderr + all job logs
    targets = [
        str(JOBS_DIR / ".scheduler-stdout.log"),
        str(JOBS_DIR / ".scheduler-stderr.log"),
    ]
    # tail -f on existing + future log files via a glob trick:
    # we tail the scheduler logs and use a polling loop to pick up new job logs
    try:
        proc = subprocess.Popen(
            ["tail", "-f"] + targets + ["-n", "0"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        # Also start a background tail on the most recent job logs
        import threading
        import glob
        import time

        seen_files: set = set()

        def watch_new_logs():
            while True:
                current = set(glob.glob(str(JOBS_DIR / "*-[0-9]*.log")))
                new = current - seen_files
                for f in sorted(new):
                    seen_files.add(f)
                    # Start a tail on the new file
                    subprocess.Popen(
                        ["tail", "-f", "-n", "5", f],
                        stderr=subprocess.DEVNULL,
                    )
                time.sleep(2)

        watcher = threading.Thread(target=watch_new_logs, daemon=True)
        watcher.start()

        # Stream scheduler output to terminal
        for line in proc.stdout:
            print(line, end="", flush=True)
    except KeyboardInterrupt:
        proc.terminate()
        print("\n  peek stopped.")


def cmd_version() -> None:
    """Show version + build-source metadata.

    The stable case (user installed a tagged release) prints one line. Any
    non-stable install (local dev tree, nightly) adds provenance lines so
    the user can tell what they're actually running — critical when files
    diverge from the tag nominally recorded in .version.
    """
    v = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"

    # .build-source is written by install.sh. Absence means a very old
    # install that predates channels — safely assume stable/release.
    build_source_path = JOBS_DIR / ".build-source"
    build: dict = {}
    if build_source_path.exists():
        try:
            build = json.loads(build_source_path.read_text())
        except (OSError, ValueError):
            build = {}

    channel = build.get("channel") or "stable"
    source = build.get("source") or "release"
    git_sha = build.get("git_sha")
    installed_at = build.get("installed_at", "")
    repo = build.get("repo", "CoreyRDean/clauck")

    # Stable-release default: one-line output, no noise.
    if channel == "stable" and source == "release" and not git_sha:
        print(f"clauck {v}")
        return

    # Non-stable installs: print provenance so the user isn't confused
    # about why `clauck version` says v1.5.6 but the behavior differs
    # from a real v1.5.6 release.
    print(f"clauck {v}  [{channel}]")
    if source == "local":
        sha_str = f" @ {git_sha}" if git_sha else ""
        print(f"  source: local checkout{sha_str}")
        print(f"  note:   update checks disabled for local builds")
    elif source == "nightly":
        sha_str = f" @ {git_sha}" if git_sha else ""
        print(f"  source: nightly{sha_str}")
    else:
        print(f"  source: {source}")
    if installed_at:
        print(f"  installed: {installed_at}")
    print(f"  repo:      {repo}")


def cmd_add(path: str, name: str = "", when: str = "") -> None:
    """Import a file as a scheduled job."""
    import shutil
    src = Path(path).expanduser().resolve()
    if not src.exists():
        die(f"file not found: {src}")
    job_name = name or src.stem
    dst = JOBS_DIR / f"{job_name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or use `clauck edit {job_name}`.")
    JOBS_DIR.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(src), str(dst))

    # If the file has no YAML frontmatter, prepend minimal defaults
    text = dst.read_text(encoding="utf-8")
    if not text.startswith("---"):
        header = (
            "---\n"
            f"name: {job_name}\n"
            "max_budget_usd: 2.00\n"
            "effort: high\n"
            "---\n"
        )
        dst.write_text(header + text)

    # If --when provided, use claude to interpret the schedule
    if when:
        claude_bin = _find_claude()
        if claude_bin:
            interpret_prompt = (
                f'The user wants to schedule a job with this timing: "{when}"\n'
                f"Convert this to a 5-field cron expression (minute hour day-of-month month day-of-week).\n"
                f"Reply with ONLY the cron expression, nothing else. Example: 0 9 * * 1-5"
            )
            result = subprocess.run(
                [claude_bin, "-p", interpret_prompt,
                 "--max-turns", "1", "--max-budget-usd", "0.05",
                 "--model", "haiku", "--output-format", "text",
                 "--setting-sources", ""],
                capture_output=True, text=True,
            )
            cron_expr = result.stdout.strip()
            if cron_expr and result.returncode == 0:
                # Insert cron into frontmatter
                text = dst.read_text(encoding="utf-8")
                if "cron:" not in text:
                    # Insert after the opening ---
                    text = text.replace("---\n", f"---\ncron: \"{cron_expr}\"\n", 1)
                    dst.write_text(text)
                print(f"  added: {job_name} (schedule: {cron_expr})")
            else:
                print(f"  added: {job_name} (could not interpret schedule — edit manually)")
        else:
            print(f"  added: {job_name} (claude not found — set cron manually)")
    else:
        print(f"  added: {job_name}")
    print(f"  path: {dst}")
    print(f"  test: clauck fire {job_name}")


def cmd_inspect(name: str) -> None:
    """Inspect a job's full configuration and producer DAG."""
    m = load_manifest()
    jobs = m.get("jobs", [])
    job = None
    for j in jobs:
        if j["name"] == name:
            job = j
            break
    if not job:
        die(f"job not found in manifest: {name}")

    # --- Print full config ---
    print(f"\n  Job: {job['name']}")
    if job.get("description"):
        print(f"  Description: {job['description']}")
    print(f"  Cron: {job.get('cron') or '(none)'}")
    if job.get("module_root"):
        print(f"  Module root: {job['module_root']}")
    print(f"  Prompt: {job.get('prompt_path', '')}")
    print(f"  Disabled: {job.get('disabled', False)}")

    # Show tags
    tags = job.get("tags", [])
    if tags:
        print(f"  Tags: {', '.join(str(t) for t in tags)}")

    # Show triggers
    triggers = job.get("external_triggers", [])
    if triggers:
        print(f"  External triggers:")
        for t in triggers:
            if isinstance(t, dict):
                parts = [f"{k}={v}" for k, v in t.items()]
                print(f"    - {', '.join(parts)}")
            else:
                print(f"    - {t}")

    hooks = job.get("semantic_hooks", [])
    if hooks:
        print(f"  Semantic hooks:")
        for h in hooks:
            print(f"    - {h}")

    # Show inputs
    inputs = job.get("inputs", [])
    if inputs:
        print(f"  Inputs:")
        for inp in inputs:
            if isinstance(inp, dict):
                iname = inp.get("name", "?")
                idefault = inp.get("default", "")
                idesc = inp.get("description", "")
                line = f"    - {iname}"
                if idefault:
                    line += f"  (default: {idefault})"
                if idesc:
                    line += f"  — {idesc}"
                print(line)
            else:
                print(f"    - {inp}")

    # Show producers/consumers
    producers = job.get("producers", [])
    consumers = job.get("consumers", [])
    if producers:
        print(f"  Producers: {', '.join(p['name'] if isinstance(p, dict) else str(p) for p in producers)}")
    if consumers:
        print(f"  Consumers: {', '.join(str(c) for c in consumers)}")

    # --- DAG tree visualization ---
    if producers:
        # Build a lookup from name -> job dict
        job_by_name = {j["name"]: j for j in jobs}

        def build_tree(jname: str, depth: int, visited: set) -> list[tuple[str, int, bool]]:
            """Returns list of (display_name, depth, is_module) tuples."""
            nodes: list[tuple[str, int, bool]] = []
            jobj = job_by_name.get(jname)
            if not jobj:
                return nodes
            prods = jobj.get("producers", [])
            for p in prods:
                pname = p["name"] if isinstance(p, dict) else str(p)
                pobj = job_by_name.get(pname)
                is_mod = bool(pobj.get("module_root", "")) if pobj else False
                nodes.append((pname, depth, is_mod))
                if pname not in visited and depth < 10:
                    visited.add(pname)
                    nodes.extend(build_tree(pname, depth + 1, visited))
            return nodes

        tree = build_tree(name, 0, {name})

        if tree:
            print(f"\n  Producer DAG:")
            print(f"  {name}")

            # Group by parent for proper tree drawing
            # We need to know which items are last at each depth
            # Simpler approach: walk linearly, tracking depth transitions
            for i, (node_name, depth, is_mod) in enumerate(tree):
                # Determine if this is the last sibling at this depth
                is_last = True
                for future_name, future_depth, _ in tree[i + 1:]:
                    if future_depth == depth:
                        is_last = False
                        break
                    if future_depth < depth:
                        break

                # Build prefix
                prefix = ""
                for d in range(depth):
                    # Check if there's still a continuing branch at this depth
                    has_continuation = False
                    for fn, fd, _ in tree[i + 1:]:
                        if fd == d:
                            has_continuation = True
                            break
                        if fd < d:
                            break
                    prefix += "│  " if has_continuation else "   "

                connector = "└─ " if is_last else "├─ "
                suffix = " (module)" if is_mod else ""
                print(f"  {prefix}{connector}{node_name}{suffix}")

            # Show internal files for modules in the tree
            all_tree_names = {node_name for node_name, _, _ in tree}
            all_tree_names.add(name)
            # Show internals only for modules OTHER than the inspected job itself
            # (the inspected job's own internals are shown separately below).
            inspected_root = job.get("module_root", "")
            for tname in sorted(all_tree_names):
                tobj = job_by_name.get(tname)
                if not tobj or not tobj.get("module_root"):
                    continue
                if tobj["module_root"] == inspected_root:
                    continue  # skip — this is the inspected job itself
                mod_root = Path(tobj["module_root"])
                if mod_root.is_dir():
                    internal_mds = sorted(
                        p for p in mod_root.glob("*.md")
                        if p.name != "JOB.md" and not p.name.startswith(".")
                    )
                    if internal_mds:
                        print(f"\n  Module internals: {tname}")
                        for md in internal_mds:
                            print(f"    [internal] {md.stem}")

    # --- Module internals for the inspected job itself (shown once) ---
    if job.get("module_root"):
        mod_root = Path(job["module_root"])
        if mod_root.is_dir():
            internal_mds = sorted(
                p for p in mod_root.glob("*.md")
                if p.name != "JOB.md" and not p.name.startswith(".")
            )
            if internal_mds:
                print(f"\n  Module internals:")
                for md in internal_mds:
                    print(f"    [internal] {md.stem}")

    print()


def _build_doctor_interpreter_prompt(mode_label: str, context: str) -> str:
    """Stage-1 doctor interpreter: pick complexity-scaled execution params.

    Unlike the general semantic interpreter, doctor's interpreter only emits
    the execution parameters (model/effort/turns/budget). There's no
    deterministic branch — doctor always runs a Claude session.
    """
    ctx_line = context.strip() or "(no user context — general health check)"
    return f"""You are the clauck doctor parameter classifier.

Your job: read the user's context and decide how much firepower the diagnostic session needs.

# Mode
{mode_label}

# User context
{ctx_line}

# Complexity rubric

- **Trivial** (system looks healthy, user wants a quick status check, specific known-good question):
  haiku, low effort, 5 turns, $0.10
- **Standard** (general diagnostic sweep with fixes, unclear failure, most real-world invocations):
  sonnet, medium effort, 20 turns, $0.60
- **Complex** (multi-job pipeline failure, producer graph broken, DAG investigation across many logs, deep architectural suspicion):
  sonnet, high effort, 40 turns, $1.50

Lean toward Standard if uncertain — doctor is usually asked when something is already weird.

# Output

Return ONLY valid JSON, no prose, no markdown fences:

{{"interpretation": "<distilled one-line diagnostic directive>", "exec_model": "haiku"|"sonnet", "exec_effort": "low"|"medium"|"high", "exec_max_turns": <int>, "exec_max_budget_usd": <float>}}

The `interpretation` field describes what doctor will investigate — imperative mood, 6-14 words, names the concrete suspicion if context gave one. Example good: "Trace pe-pipeline DAG for missing producer resolution". Example bad: "Run doctor to check things".
"""


def _build_doctor_exec_prompt(dry: bool, safe: bool, context: str) -> str:
    """Build the doctor execution system prompt with mode constraints baked in.

    Four mode combinations:
      --dry --safe    : analysis only, no mutations, no system file touches
      --dry --unsafe  : analysis only (unsafe doesn't matter in dry mode)
      --fix --safe    : may edit user job files; system files read-only → escalate
      --fix --unsafe  : may edit anything, including system files
    """
    if dry:
        mode_block = """# Mode: DRY (analysis only)

You are in DRY mode. DO NOT mutate any files. No Write, no Edit, no rm, no mv, no file-modifying Bash commands. Read everything you need; propose fixes as a plan for the human to apply.

If you notice fixes that obviously should be applied, list them in a "## Recommended fixes" block at the end with exact commands or diffs. Do not apply them."""
    elif safe:
        mode_block = f"""# Mode: FIX / SAFE

You may edit USER job files: `.md` files directly under {JOBS_DIR}/ (flat jobs) and within module directories (e.g. {JOBS_DIR}/<module>/*.md).

You MUST NOT modify these clauck system files:
  - {JOBS_DIR}/scheduler.py
  - {JOBS_DIR}/dag-runner.py
  - {JOBS_DIR}/run-job.sh
  - {JOBS_DIR}/trigger-job.sh
  - {JOBS_DIR}/update-check.sh
  - {JOBS_DIR}/uninstall.sh
  - {JOBS_DIR}/.version
  - ~/.claude/hooks/scheduled-jobs-notice.sh
  - ~/.claude/scheduled-jobs-prompt.md
  - ~/.local/bin/clauck
  - ~/.claude/skills/clauck/SKILL.md
  - ~/Library/LaunchAgents/com.*.claude-scheduler.plist

If the root cause lives in a system file, STOP touching it. Write a "## Escalation: system file mutation requested" block with:
  - Which system file(s) need changing
  - The exact diff or change required
  - Why the change is needed (root cause)
  - Why this can't be worked around at the user-job layer

The human will review and decide whether to re-run with --unsafe or apply the fix manually. This is a feature, not a limitation: system files affect every user, so changes are gated."""
    else:
        mode_block = f"""# Mode: FIX / UNSAFE

You may edit anything under {JOBS_DIR}/ including system files (scheduler.py, dag-runner.py, run-job.sh, etc.) and other clauck components. The user explicitly opted in with --unsafe.

Still prefer minimal-blast-radius fixes. If a user-job fix and a system-file fix would both resolve the issue, pick the user-job fix. System file changes should be deliberate, explained, and tied to a concrete failure — not speculative cleanup."""

    return f"""You are `clauck doctor` — a diagnostic and repair agent for the clauck workflow automation system on this machine.

{mode_block}

# Diagnostic surface

Inspect in order of likelihood:
1. **LaunchAgent** — `launchctl list | grep claude-scheduler`. If not loaded, that's a blocker.
2. **Scheduler output** — `tail -50 {JOBS_DIR}/.scheduler-stderr.log` and `{JOBS_DIR}/.scheduler-stdout.log`.
3. **Manifest freshness** — `stat {MANIFEST}` and compare mtime to now; if older than ~2 minutes the scheduler isn't ticking.
4. **Manifest errors** — read `{MANIFEST}` and check for `dag_errors` key (cycle detection or missing-producer errors).
5. **Auto-disabled jobs** — `ls {STATE_DIR}/*.auto-disabled 2>/dev/null`; read each file for the reason.
6. **Recent failures** — scan `{JOBS_DIR}/*.log` for recent non-zero exit_code tombstones.
7. **DAG invocation logs** — `{JOBS_DIR}/*-dag-*.log` for pipeline failures.
8. **Frontmatter errors** — parse each job .md; report malformed YAML.
9. **Version / update state** — `cat {JOBS_DIR}/.version` and `{STATE_DIR}/.update-available` if present.

# User context
{context.strip() or "(none — run a general health sweep)"}

# Output shape

Keep output tight. Prefer:

```
## Health summary
<one-line overall status>

## Findings
1. <Issue>: <root cause>. <Fix applied | Recommended fix>.
2. ...

## Recommended fixes / Escalations
<only if dry or escalating>
```

If everything is healthy: a single line. Do not pad.
"""


def cmd_doctor(
    dry: bool = True,
    fix: bool = False,
    safe: bool = True,
    unsafe: bool = False,
    interactive: bool = False,
    context: str = "",
) -> None:
    """Diagnose clauck health with mode-gated repair.

    Modes:
      --dry (default) vs --fix   — analysis-only vs apply fixes to user jobs
      --safe (default) vs --unsafe — restrict vs allow system-file mutation

    Routes through a stage-1 interpreter that picks model/effort/turns/budget
    based on the context complexity, matching how `clauck work` scales. Shows
    a spinner so long-running sessions are visible.
    """
    import threading
    import time as _time

    # Flag resolution: --fix overrides the default --dry; --unsafe overrides
    # the default --safe. The defaults bias toward the safest combination.
    if fix:
        dry = False
    if unsafe:
        safe = False

    mode_label = f"--{'fix' if not dry else 'dry'} --{'unsafe' if not safe else 'safe'}"

    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — clauck doctor requires claude on PATH")

    # ── Spinner ──────────────────────────────────────────────────────────
    spinner_running = [True]
    spinner_label = [f"mining intent ({mode_label})"]
    start_time = _time.time()

    def spinner() -> None:
        chars = "\u280b\u2819\u2839\u2838\u283c\u2834\u2826\u2827\u2807\u280f"
        i = 0
        while spinner_running[0]:
            elapsed = int(_time.time() - start_time)
            sys.stderr.write(f"\r  {chars[i % len(chars)]} {spinner_label[0]}... ({elapsed}s)")
            sys.stderr.flush()
            i += 1
            _time.sleep(0.1)
        sys.stderr.write("\r" + " " * 70 + "\r")
        sys.stderr.flush()

    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # ── Stage 1: complexity classifier ───────────────────────────────────
    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        empty_mcp.write_text('{"mcpServers":{}}')

    interpreter_prompt = _build_doctor_interpreter_prompt(mode_label, context)
    user_prompt = "Classify this doctor invocation."

    import re as _re
    try:
        result_s1 = subprocess.run(
            [claude_bin, "-p", user_prompt,
             "--append-system-prompt", interpreter_prompt,
             "--model", "sonnet",
             "--max-turns", "2",
             "--max-budget-usd", "0.15",
             "--output-format", "json",
             "--setting-sources", "",
             "--strict-mcp-config",
             "--mcp-config", str(empty_mcp)],
            capture_output=True, text=True,
        )
    except Exception:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        raise

    routing: dict = {}
    interpreter_error = ""
    if result_s1.returncode == 0 and result_s1.stdout.strip():
        try:
            envelope = json.loads(result_s1.stdout)
            inner = envelope.get("result", "").strip()
            match = _re.search(r'\{[\s\S]*\}', inner)
            if match:
                routing = json.loads(match.group(0))
            else:
                interpreter_error = f"no JSON in interpreter output: {inner[:200]}"
        except (json.JSONDecodeError, ValueError) as e:
            interpreter_error = f"interpreter JSON parse failed: {e}"
    elif result_s1.returncode != 0:
        interpreter_error = f"interpreter exit {result_s1.returncode}: {result_s1.stderr[:200]}"

    if not routing:
        if interpreter_error:
            sys.stderr.write(f"\r  ! interpreter fallback: {interpreter_error[:120]}\n")
            sys.stderr.flush()
        routing = {
            "interpretation": "Run standard diagnostic sweep",
            "exec_model": "sonnet",
            "exec_effort": "medium",
            "exec_max_turns": 20,
            "exec_max_budget_usd": 0.60,
        }

    interpretation = routing.get("interpretation", "Run diagnostic sweep")
    exec_model = routing.get("exec_model", "sonnet")
    exec_effort = routing.get("exec_effort", "medium")
    exec_max_turns = str(routing.get("exec_max_turns", 20))
    exec_max_budget = str(routing.get("exec_max_budget_usd", 0.60))

    # Print interpretation + separator, then resume spinner with new label.
    spinner_running[0] = False
    spin_thread.join(timeout=0.5)
    print(f"  \u2192 {interpretation} [{mode_label}]")
    print(f"  {'─' * 60}")

    # ── Stage 2: diagnostic execution ────────────────────────────────────
    exec_prompt = _build_doctor_exec_prompt(dry=dry, safe=safe, context=context)

    spinner_running[0] = True
    spinner_label[0] = f"diagnosing ({exec_model}, {exec_effort} effort)"
    start_time = _time.time()
    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # Permission strategy:
    #   dry  → no bypass, default permission mode (tools that mutate prompt
    #          and would fail in non-interactive). Read tools work.
    #   fix  → bypass with allowlist scoped to the writable surface.
    cli = [claude_bin, "-p", "Run the doctor diagnostic per your system prompt.",
           "--append-system-prompt", exec_prompt,
           "--max-turns", exec_max_turns,
           "--max-budget-usd", exec_max_budget,
           "--model", exec_model,
           "--output-format", "json",
           "--setting-sources", ""]

    if not dry:
        # Fix mode: need write permission. --safe keeps the allowlist tight to
        # .md files; --unsafe opens the full scheduled-jobs tree.
        if safe:
            allowlist = {
                "permissions": {
                    "defaultMode": "bypassPermissions",
                    "allow": [
                        "Read(**)",
                        "Bash(launchctl *)",
                        "Bash(ls *)",
                        "Bash(cat *)",
                        "Bash(tail *)",
                        "Bash(stat *)",
                        "Bash(grep *)",
                        "Bash(find *)",
                        # User-job writes only — not system scripts.
                        f"Write({JOBS_DIR}/*.md)",
                        f"Edit({JOBS_DIR}/*.md)",
                        f"Write({JOBS_DIR}/*/**.md)",
                        f"Edit({JOBS_DIR}/*/**.md)",
                    ],
                }
            }
        else:
            allowlist = {
                "permissions": {
                    "defaultMode": "bypassPermissions",
                    "allow": [
                        "Bash(*)", "Read(**)", "Write(**)", "Edit(**)",
                        f"Write({JOBS_DIR}/**)",
                        f"Edit({JOBS_DIR}/**)",
                    ],
                }
            }
        cli += ["--dangerously-skip-permissions",
                "--permission-mode", "bypassPermissions",
                "--settings", json.dumps(allowlist)]

    try:
        result = subprocess.run(cli, capture_output=True, text=True)
    finally:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)

    try:
        envelope = json.loads(result.stdout) if result.stdout else {}
    except (json.JSONDecodeError, ValueError):
        envelope = {}

    claude_result = envelope.get("result", "").strip()
    is_error = envelope.get("is_error", result.returncode != 0)
    session_id = envelope.get("session_id", "")

    if claude_result:
        print(claude_result)

    if is_error:
        err_text = envelope.get("errors") or result.stderr
        if err_text:
            if isinstance(err_text, list):
                err_text = "; ".join(str(e) for e in err_text)
            print(str(err_text).strip(), file=sys.stderr)
        sys.exit(1)

    # Optional interactive follow-up on a resolvable session.
    if interactive and session_id:
        print("\n  Opening interactive session for follow-up...")
        os.execvp(claude_bin, [claude_bin, "--resume", session_id])


def _find_claude() -> str | None:
    """Locate the claude binary."""
    for p in [HOME / ".local" / "bin" / "claude", Path("/usr/local/bin/claude")]:
        if p.exists():
            return str(p)
    import shutil
    return shutil.which("claude")


def _build_interpreter_prompt() -> str:
    """Build the stage-1 interpreter system prompt with live manifest data."""
    subcommands = (
        "list, status, fire, pause, resume, edit, logs, marketplace, install, "
        "update, config, doctor, peek, version, add, inspect, work, "
        "remove (aliases: delete, rm)"
    )

    # Read manifest for job descriptions + inputs
    job_descriptions = ""
    if MANIFEST.exists():
        try:
            m = json.loads(MANIFEST.read_text())
            for j in m.get("jobs", []):
                name = j["name"]
                desc = (j.get("description") or "")[:120]
                inputs_list = j.get("inputs", [])
                input_names = []
                for inp in inputs_list:
                    if isinstance(inp, dict):
                        input_names.append(inp.get("name", "?"))
                    else:
                        input_names.append(str(inp))
                inputs_str = ", ".join(input_names) if input_names else "(none)"
                job_descriptions += f"  - {name}: {desc}  [inputs: {inputs_str}]\n"
        except (OSError, ValueError):
            job_descriptions = "  (manifest unreadable)\n"
    else:
        job_descriptions = "  (no manifest found)\n"

    return f"""You are the clauck CLI interpreter (stage 1). Your ONLY job is to classify a user's natural-language input and return a JSON routing decision.

# Known clauck subcommands
{subcommands}

# Registered jobs (from manifest)
{job_descriptions}
# Routing rules

**Pick "deterministic" when the user's intent maps directly to an existing clauck subcommand or job trigger:**
- "Run jobA" / "fire jobA" / "trigger jobA" -> deterministic (clauck fire jobA)
- "show me jobA's last run" / "logs for jobA" -> deterministic (clauck logs jobA)
- "Pause jobA" / "disable jobA" -> deterministic (clauck pause jobA)
- "Resume jobA" / "enable jobA" -> deterministic (clauck resume jobA)
- "Delete jobA" / "remove jobA" / "rm jobA" -> deterministic (clauck remove jobA). Direct filesystem op — always prefer this over Write/Delete via the execution agent.
- "What jobs are running" / "list jobs" -> deterministic (clauck list)
- "System status" / "how is clauck doing" -> deterministic (clauck status)
- "Fire jobA with the source at ~/file.md" -> deterministic; convert to KEY=VALUE args using the job's declared inputs

**Pick "semantic" when the user's intent requires Claude to create, modify, or reason about jobs:**
- "Do X every morning" / "Build a pipeline that..." -> semantic
- "Change heartbeat to every 2 hours" -> semantic
- "Create a job that watches for new PDFs" -> semantic
- "What ran today and were there any failures?" -> semantic (needs log analysis)

# Complexity hints for semantic commands
- Trivial (simple query, single status check): haiku, low effort, 3 turns, $0.05 budget
- Standard (create/modify a single job): sonnet, medium effort, 15 turns, $0.50 budget
- Complex (multi-stage pipeline, module creation, DAG wiring): sonnet or opus, high effort, 40 turns, $2.00 budget

# CRITICAL: Quality of `interpretation` field

The `interpretation` field is the value you add. It is shown to the user as feedback proving you understood their intent. It MUST:

1. **Be a distillation, not a copy.** Never echo the user's words verbatim. Rewrite in your own words capturing the intent.
2. **Read like a CLI directive.** Imperative mood, 6–14 words, no filler, no pronouns ("Create hourly job...", not "I will create...").
3. **Name the concrete artifact.** When creating a job, include the inferred job name. When firing, include the resolved args.
4. **Expose inferred details.** Name the schedule in human terms ("every hour on the hour"), the model tier, and the job type (standard vs module) when relevant.
5. **Never be generic.** "Execute semantic command" or "Run user request" are failures. Be specific about the what and where.

Bad interpretation: "execute: every hour invoke a claude code session to mine..."
Good interpretation: "Create hourly module 'intent-miner' (sonnet, medium budget) that opens a draft PR"

Bad interpretation: "I want to see my jobs"
Good interpretation: "List all registered jobs with schedules and status"

# CRITICAL: Quality of `enhanced_prompt` field (semantic only)

The `enhanced_prompt` is what the execution agent receives. It must:
1. **Preserve all intent** the user expressed.
2. **Add prescriptive structure** the user didn't say but that the execution agent needs (file path, frontmatter fields, module vs standard choice, cron expression).
3. **Remove conversational filler** and reformulate as a task brief.
4. **Scale detail with complexity.** A trivial request stays terse. A complex pipeline gets a structured breakdown.

# Output format

Return ONLY valid JSON, no markdown fencing, no explanation:

For deterministic:
{{"command_type": "deterministic", "interpretation": "<distilled CLI directive>", "deterministic_argv": ["clauck", "fire", "jobA", "KEY=value"]}}

**CRITICAL — use `deterministic_argv` (JSON array), NOT a single string, whenever any arg value contains spaces, quotes, newlines, or shell metacharacters.** Each token is ONE element of the array. Multi-word arg values go in ONE element: `"SOURCE_CONTENT=This is a long source document."`, not split across multiple elements. There is no shell tokenization pass — what you put in the array is what the CLI receives.

Single-string `deterministic_cmd` is still accepted for simple cases (`"clauck list"`, `"clauck fire jobA"`), parsed with shell-style quoting. Prefer `deterministic_argv` by default — it cannot be misparsed.

For semantic:
{{"command_type": "semantic", "interpretation": "<distilled CLI directive>", "enhanced_prompt": "<prescriptive task brief>", "exec_model": "haiku"|"sonnet"|"opus", "exec_effort": "low"|"medium"|"high", "exec_max_turns": <int>, "exec_max_budget_usd": <float>}}"""


SEMANTIC_EXEC_SYSTEM_PROMPT = """You are the clauck CLI executing a user's natural-language command.

