    match = [j for j in index.get("jobs", []) if j["name"] == name]
    if not match:
        die(f"no marketplace job named '{name}'. Run `clauck marketplace` to see available jobs.")
    job = match[0]
    src = MARKETPLACE_DIR / job["path"]
    if not src.exists():
        die(f"marketplace entry missing: {src}")
    if src.is_dir():
        # Module format: directory containing JOB.md (plus optional stages / support files)
        if not (src / "JOB.md").exists():
            die(f"module missing JOB.md entry point: {src}")
        dst = JOBS_DIR / name
        if dst.exists():
            if not update:
                die(f"job already exists: {dst}/. Remove it first or use --update to overwrite.")
            installed_ver = _parse_frontmatter_version(dst / "JOB.md")
            backup = JOBS_DIR / f".{name}.backup-v{installed_ver or 'unknown'}"
            if backup.exists():
                shutil.rmtree(str(backup))
            shutil.move(str(dst), str(backup))
            print(f"  backed up: {backup}/")
        shutil.copytree(str(src), str(dst))
        print(f"  installed: {dst}/ (module)")
    else:
        dst = JOBS_DIR / f"{name}.md"
        if dst.exists():
            if not update:
                die(f"job already exists: {dst}. Remove it first or use --update to overwrite.")
            installed_ver = _parse_frontmatter_version(dst)
            backup = JOBS_DIR / f".{name}.md.backup-v{installed_ver or 'unknown'}"
            shutil.copy2(str(dst), str(backup))
            print(f"  backed up: {backup}")
        shutil.copy2(str(src), str(dst))
        print(f"  installed: {dst}")
    setup = job.get("requires", {}).get("setup", [])
    if setup:
        print("  CUSTOMIZE BEFORE FIRST RUN:")
        for step in setup:
            print(f"    - {step}")
    print(f"  test: clauck fire {name}")


def cmd_marketplace_updates() -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found — run the installer to populate it")
    index = json.loads(index_file.read_text())

    updates: list[tuple[str, str, str]] = []
    not_versioned: list[str] = []

    for job in index.get("jobs", []):
        jname = job["name"]
        catalog_ver = job.get("version", "")
        dst = _installed_job_path(jname)
        if dst is None:
            continue
        if not catalog_ver:
            not_versioned.append(jname)
            continue
        installed_ver = _parse_frontmatter_version(dst)
        if installed_ver != catalog_ver:
            updates.append((jname, installed_ver or "unknown", catalog_ver))

    if not updates:
        print("  All installed marketplace jobs are up to date.")
        if not_versioned:
            print(f"  (no version info for: {', '.join(not_versioned)})")
        return

    print(f"  {len(updates)} update(s) available:\n")
    for jname, inst, latest in updates:
        print(f"    {jname:<24}  installed: {inst:<10}  latest: {latest}")
    print("\n  run: clauck install <name> --update")


def cmd_update(apply: bool = False) -> None:
    if not UPDATE_SCRIPT.exists():
        die("update-check.sh not found")
    args = [str(UPDATE_SCRIPT)]
    if apply:
        args.append("--apply")
    os.execvp(args[0], args)


def cmd_uninstall(wipe: bool = False) -> None:
    """Invoke the LOCAL uninstall.sh that shipped with the installed version.

    Running the remote latest uninstall.sh against an older local install can
    leave orphaned files behind if the file layout changed between versions.
    By always using the local copy, the uninstall step is version-matched
    with the install it's removing.

    Falls back to telling the user how to run it directly if the local copy
    is missing (e.g., an older install that predates this CLI command).
    """
    if not UNINSTALL_SCRIPT.exists():
        print(
            "uninstall.sh not found at expected local path.\n"
            f"  expected: {UNINSTALL_SCRIPT}\n"
            "Your install predates `clauck uninstall`. Re-run the installer "
            "once to pick up the local copy, then retry. Or run the remote "
            "uninstaller:\n"
            "  bash <(curl -sSL https://raw.githubusercontent.com/CoreyRDean/clauck/main/uninstall.sh)"
            + ("  --wipe" if wipe else ""),
            file=sys.stderr,
        )
        sys.exit(1)
    args = ["/bin/bash", str(UNINSTALL_SCRIPT)]
    if wipe:
        args.append("--wipe")
    os.execvp(args[0], args)


def cmd_config(args: list[str]) -> None:
    # `clauck config doctor [key [value]]` — dedicated view/edit for the
    # doctor sizing block. Shows defaults-merged view (so users see what's
    # actually in effect, not just what's been overridden) and accepts
    # targeted edits without needing dotted-key syntax.
    if args and args[0] == "doctor":
        rest_doctor = args[1:]
        if not rest_doctor:
            cfg = sizing.load_doctor_config()
            print("  doctor sizing config (defaults merged):")
            for k, v in cfg.items():
                print(f"    {k}: {v}")
            return
        if len(rest_doctor) == 1:
            cfg = sizing.load_doctor_config()
            key = rest_doctor[0]
            if key not in cfg:
                die(
                    f"unknown doctor config key: {key!r}. "
                    f"Valid keys: {', '.join(sorted(sizing.DEFAULT_DOCTOR_CONFIG))}"
                )
            print(f"  {key}: {cfg[key]}")
            return
        key, raw_value = rest_doctor[0], rest_doctor[1]
        if key not in sizing.DEFAULT_DOCTOR_CONFIG:
            die(
                f"unknown doctor config key: {key!r}. "
                f"Valid keys: {', '.join(sorted(sizing.DEFAULT_DOCTOR_CONFIG))}"
            )
        default_val = sizing.DEFAULT_DOCTOR_CONFIG[key]
        try:
            if isinstance(default_val, bool):
                value: object = raw_value.lower() in ("1", "true", "yes")
            elif isinstance(default_val, int):
                value = int(raw_value)
            elif isinstance(default_val, float):
                value = float(raw_value)
            else:
                value = raw_value
        except ValueError:
            die(
                f"invalid value {raw_value!r} for {key} "
                f"(expected {type(default_val).__name__})"
            )
        new_cfg = sizing.save_doctor_config({key: value})
        print(f"  set doctor.{key} = {new_cfg[key]}")
        return

    if not args or args[0] != "set":
        config = load_config()
        print(json.dumps(config, indent=2))
        return
    # clauck config set <dotted.key> <value>
    if len(args) < 3:
        die("usage: clauck config set <key> <value>")
    key_path = args[1].split(".")
    value = args[2]
    # Coerce value
    if value.lower() == "true":
        value = True
    elif value.lower() == "false":
        value = False
    else:
        try:
            value = int(value)
        except ValueError:
            try:
                value = float(value)
            except ValueError:
                pass
    config = load_config()
    # Navigate to the nested key
    d = config
    for k in key_path[:-1]:
        d = d.setdefault(k, {})
    d[key_path[-1]] = value
    CONFIG_FILE.write_text(json.dumps(config, indent=2) + "\n")
    print(f"  set {args[1]} = {value}")


def cmd_size(
    scale_raw: str,
    ctx_tokens: int = 0,
    model_override: str = "auto",
    strict_mcp: bool = False,
) -> None:
    """Show what the sizing formula derives for a given complexity scale.

    Exists so humans and agents can introspect sizing without firing a session.
    Useful when authoring a new job (`clauck size 0.35` tells you the derived
    model/turns/budget before you commit complexity: 0.35 to frontmatter) or
    debugging a surprising doctor sizing.

    By default assumes `strict_mcp=False` — matching the common case where a
    job loads the user's full MCP surface and haiku auto-promotes to sonnet.
    Pass --strict-mcp to preview the haiku-eligible derivation for jobs with
    `strict_mcp_config: true` in their frontmatter.
    """
    try:
        scale = float(scale_raw)
    except ValueError:
        die(f"invalid scale {scale_raw!r} — expected float in [0.0, 1.0]")
    if scale < 0.0 or scale > 1.0:
        die(f"scale {scale} out of range — must be in [0.0, 1.0]")

    cfg = sizing.load_doctor_config()
    sized = sizing.compute_sizing(scale, int(ctx_tokens), cfg, strict_mcp=strict_mcp)

    if model_override != "auto" and model_override != sized["model"]:
        print(f"  note: formula picked {sized['model']}; your override = {model_override!r}")
        print(f"        (override the model in frontmatter with `model: {model_override}`)")
        print()

    print(f"  scale:     {scale}")
    print(f"  skew:      {cfg.get('scale_skew', 0.0):+.2f} "
          f"(effective scale: {sized['scale_effective']:.2f})")
    print(f"  strict_mcp: {strict_mcp}"
          + ("  (haiku auto-promote ACTIVE)" if not strict_mcp else "  (haiku eligible)"))
    if sized.get("mcp_promoted"):
        print(f"  \u2191 haiku auto-promoted to {sized['model']} — MCP surface is loaded")
    print(f"  model:     {sized['model']}")
    print(f"  effort:    {sized['effort']}")
    print(f"  max_turns: {sized['max_turns']}")
    print(f"  max_budget_usd: ${sized['max_budget_usd']:.2f}")

    # Surface clamps visibly. "Clamped" means the raw derivation exceeded
    # max_budget_usd (or fell below min_budget_usd) and the output is NOT
    # what the formula naturally produced. Users who don't see this warning
    # can be misled about what their scale actually buys.
    raw_total = (sized["base_cost"] + sized["context_cost"]) * sized["headroom"]
    if abs(raw_total - sized["max_budget_usd"]) > 0.01:
        print(f"  \u26a0 budget clamped: raw derivation ${raw_total:.2f} → "
              f"capped at ${sized['max_budget_usd']:.2f}")
        print("    raise the ceiling with: "
              "clauck config doctor max_budget_usd <value>")

    print()
    print(f"  breakdown: {sized['explanation']}")
    print()
    print(f"  config (from {CONFIG_FILE}):")
    for k in ("min_budget_usd", "max_budget_usd", "headroom_multiplier",
              "scale_skew", "auto_skew_increment", "auto_skew_cap"):
        print(f"    {k}: {cfg.get(k)}")
    print()
    print(f"  to pin in a job: add `complexity: {scale}` to frontmatter.")


def _list_tombstones() -> list[dict]:
    """Return all tombstones sorted newest-first."""
    if not BROKEN_DIR.exists():
        return []
    stones = []
    for p in sorted(BROKEN_DIR.glob("*.json"), reverse=True):
        try:
            stones.append(json.loads(p.read_text()))
        except Exception:
            pass
    return stones


def _find_tombstone(name: str) -> dict | None:
    """Return the most recent tombstone for job *name*, or None."""
    for stone in _list_tombstones():
        if stone.get("job") == name:
            return stone
    return None


def _tombstone_age_hours(stone: dict) -> float:
    """Return the age of a tombstone in hours."""
    ts_str = stone.get("ts", "")
    try:
        ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        age = datetime.now(timezone.utc) - ts
        return age.total_seconds() / 3600
    except Exception:
        return float("inf")


def _format_age(hours: float) -> str:
    if hours < 1:
        return f"{int(hours * 60)}m ago"
    if hours < 24:
        return f"{hours:.1f}h ago"
    return f"{hours / 24:.1f}d ago"


def cmd_broken() -> None:
    """List jobs in the budget/turn circuit-breaker state."""
    stones = _list_tombstones()
    if not stones:
        print("  no broken jobs")
        return
    print(f"  {'job':<22} {'reason':<12} {'spend':>8}  {'age':<10}  session")
    print(f"  {'-'*22} {'-'*12} {'-'*8}  {'-'*10}  {'-'*36}")
    for s in stones:
        job = s.get("job", "?")
        reason = s.get("trip_reason", "?")
        spend = s.get("spend_usd")
        spend_str = f"${spend:.4f}" if spend is not None else "?"
        age_h = _tombstone_age_hours(s)
        age_str = _format_age(age_h)
        sid = s.get("session_id", "")[:36]
        stale = " [stale]" if age_h > BROKEN_RETENTION_HOURS else ""
        print(f"  {job:<22} {reason:<12} {spend_str:>8}  {age_str:<10}  {sid}{stale}")
    print("\n  revive: clauck revive <name> [--budget <usd>] [--turns <n>]")
    print("  discard: clauck discard <name>")


def cmd_revive(name: str, budget: float | None = None, turns: int | None = None) -> None:
    """Resume a broken job session with augmented budget/turns."""
    stone = _find_tombstone(name)
    if stone is None:
        print(f"  no broken tombstone found for: {name}", file=sys.stderr)
        sys.exit(1)

    age_h = _tombstone_age_hours(stone)
    if age_h > BROKEN_RETENTION_HOURS:
        print(
            f"  tombstone for '{name}' is {_format_age(age_h)} old (retention: {BROKEN_RETENTION_HOURS}h).",
            file=sys.stderr,
        )
        print(f"  session may no longer be resumable. Use: clauck discard {name}", file=sys.stderr)
        sys.exit(1)

    session_id = stone.get("session_id", "")
    if not session_id:
        print(f"  tombstone for '{name}' has no session_id — cannot resume.", file=sys.stderr)
        sys.exit(1)

    claude_bin = _find_claude()
    if not claude_bin:
        print("  claude binary not found", file=sys.stderr)
        sys.exit(1)

    orig_budget = stone.get("orig_max_budget_usd", 2.0)
    orig_turns = stone.get("orig_max_turns", 50)
    trip_reason = stone.get("trip_reason", "?")
    spend = stone.get("spend_usd")

    new_budget = budget if budget is not None else round(orig_budget * 2, 2)
    new_turns = turns if turns is not None else orig_turns * 2

    spend_str = f"${spend:.4f}" if spend is not None else "unknown"
    print(f"  reviving '{name}' (tripped: {trip_reason}, spent: {spend_str})")
    print(f"  session: {session_id[:36]}")
    print(f"  budget: ${orig_budget} → ${new_budget}  turns: {orig_turns} → {new_turns}")
    print()

    # Remove tombstone before resuming so the job isn't listed as broken while running
    for p in BROKEN_DIR.glob(f"{name}-*.json"):
        try:
            p.unlink()
        except OSError:
            pass

    os.execvp(claude_bin, [
        claude_bin,
        "--resume", session_id,
        "--max-budget-usd", str(new_budget),
        "--max-turns", str(new_turns),
    ])


def cmd_discard(name: str) -> None:
    """Discard the broken tombstone for a job."""
    removed = 0
    if BROKEN_DIR.exists():
        for p in BROKEN_DIR.glob(f"{name}-*.json"):
            try:
                p.unlink()
                removed += 1
            except OSError:
                pass
    if removed:
        print(f"  discarded {removed} tombstone(s) for: {name}")
    else:
        print(f"  no tombstone found for: {name}")


def cmd_peek() -> None:
    """Live-tail all job + scheduler + DAG logs in a unified stream."""

    print("  clauck peek — live log stream (Ctrl+C to stop)\n")

    # Build the tail command: scheduler stdout/stderr + all job logs
    targets = [
        str(JOBS_DIR / ".scheduler-stdout.log"),
        str(JOBS_DIR / ".scheduler-stderr.log"),
    ]
    # tail -f on existing + future log files via a glob trick:
    # we tail the scheduler logs and use a polling loop to pick up new job logs
    try:
        proc = subprocess.Popen(
            ["tail", "-f"] + targets + ["-n", "0"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        # Also start a background tail on the most recent job logs
        import threading
        import glob
        import time

        seen_files: set = set()

        def watch_new_logs():
            while True:
                current = set(glob.glob(str(JOBS_DIR / "*-[0-9]*.log")))
                new = current - seen_files
                for f in sorted(new):
                    seen_files.add(f)
                    # Start a tail on the new file
                    subprocess.Popen(
                        ["tail", "-f", "-n", "5", f],
                        stderr=subprocess.DEVNULL,
                    )
                time.sleep(2)

        watcher = threading.Thread(target=watch_new_logs, daemon=True)
        watcher.start()

        # Stream scheduler output to terminal
        for line in proc.stdout:
            print(line, end="", flush=True)
    except KeyboardInterrupt:
        proc.terminate()
        print("\n  peek stopped.")


def cmd_version() -> None:
    """Show version + build-source metadata.

    The stable case (user installed a tagged release) prints one line. Any
    non-stable install (local dev tree, nightly) adds provenance lines so
    the user can tell what they're actually running — critical when files
    diverge from the tag nominally recorded in .version.
    """
    v = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"

    # .build-source is written by install.sh. Absence means a very old
    # install that predates channels — safely assume stable/release.
    build_source_path = JOBS_DIR / ".build-source"
    build: dict = {}
    if build_source_path.exists():
        try:
            build = json.loads(build_source_path.read_text())
        except (OSError, ValueError):
            build = {}

    channel = build.get("channel") or "stable"
    source = build.get("source") or "release"
    git_sha = build.get("git_sha")
    installed_at = build.get("installed_at", "")
    repo = build.get("repo", "CoreyRDean/clauck")

    # Stable-release default: one-line output, no noise.
    if channel == "stable" and source == "release" and not git_sha:
        print(f"clauck {v}")
        return

    # Non-stable installs: print provenance so the user isn't confused
    # about why `clauck version` says v1.5.6 but the behavior differs
    # from a real v1.5.6 release.
    print(f"clauck {v}  [{channel}]")
    if source == "local":
        sha_str = f" @ {git_sha}" if git_sha else ""
        print(f"  source: local checkout{sha_str}")
        print("  note:   update checks disabled for local builds")
    elif source == "nightly":
        sha_str = f" @ {git_sha}" if git_sha else ""
        print(f"  source: nightly{sha_str}")
    else:
        print(f"  source: {source}")
    if installed_at:
        print(f"  installed: {installed_at}")
    print(f"  repo:      {repo}")


def _strip_stale_mcp_entry(cfg_path: Path, server_key: str = "clauck") -> bool:
    """Remove a previously-written `mcpServers.<key>` entry from a JSON config.

    Prior versions of cmd_mcp_install wrote clauck entries directly into
    `~/.claude/settings.json` and `~/Library/Application Support/Claude/
    claude_desktop_config.json`. Neither path is authoritative anymore:
    Claude Code uses `claude mcp add` (which writes to ~/.claude.json), and
    Claude Desktop uses .mcpb bundles opened via the GUI. Leaving the stale
    entries behind creates ghost registrations that either silently do
    nothing or conflict with the current-API registration. This helper
    removes the stale key and preserves the rest of the file.

    Returns True when something was removed, False when no stale entry
    existed (including when the file is absent).
    """
    if not cfg_path.exists():
        return False
    try:
        data = json.loads(cfg_path.read_text())
    except (OSError, ValueError):
        return False
    servers = data.get("mcpServers")
    if not isinstance(servers, dict) or server_key not in servers:
        return False
    servers.pop(server_key, None)
    if not servers:
        data.pop("mcpServers", None)
    try:
        cfg_path.write_text(json.dumps(data, indent=2) + "\n")
    except OSError:
        return False
    return True


def _build_mcpb_bundle(
    clauck_bin: str,
    bundle_path: Path,
    version: str,
) -> None:
    """Generate a minimal .mcpb bundle pointing at an already-installed clauck.

    Structure:
      clauck.mcpb/
        manifest.json       # MCPB v0.3 manifest
        launch.py           # Real entry_point — 3-line exec shim to clauck

    The launch.py shim actually does what `entry_point` promises per the
    MCPB spec (a real executable entrypoint in the bundle). Claude Desktop
    invokes it via the mcp_config command (python3 launch.py); launch.py
    execs the already-installed clauck binary so updates stay aligned
    with clauck's own release cadence (the bundle never embeds the clauck
    runtime itself). This is the "thin shim" pattern done spec-correctly
    rather than relying on undocumented loader leniency.

    `compatibility.platforms: ["darwin"]` matches INTENT.md §7 (macOS-only).

    Built with stdlib zipfile rather than `@anthropic-ai/mcpb`'s `mcpb
    pack` — preserves clauck's "no npm dependency" non-negotiable. Output
    format is indistinguishable from `mcpb pack`'s from Claude Desktop's
    perspective (spec defines `.mcpb` as "a zip archive containing the
    local MCP server as well as a manifest.json").

    Overwrites any existing bundle at bundle_path. Caller is responsible
    for invoking `open` on the finished bundle.
    """
    import zipfile

    manifest = {
        "manifest_version": "0.3",
        "name": "clauck",
        "version": version,
        "description": (
            "clauck MCP server — expose scheduled jobs and system health "
            "as MCP tools (list_jobs, fire_job, get_status, etc.)"
        ),
        "author": {"name": "CoreyRDean"},
        "compatibility": {
            # INTENT.md §7: macOS is the only supported platform. Declaring
            # this explicitly means Claude Desktop on Linux/Windows won't
            # offer to install the bundle at all.
            "platforms": ["darwin"],
        },
        "server": {
            "type": "python",
            "entry_point": "launch.py",
            "mcp_config": {
                "command": "python3",
                # ${__dirname} is the MCPB runtime variable that expands to
                # the extracted bundle directory. Without it, Claude Desktop
                # runs `python3 launch.py` from an arbitrary cwd (observed
                # as `/` in practice), resolving to `//launch.py` → ENOENT.
                # The Anthropic-shipped Filesystem MCP manifest uses this
                # exact pattern (`${__dirname}/dist/index.js`), confirming
                # it's the intended mechanism for referencing in-bundle
                # entry points.
                "args": ["${__dirname}/launch.py"],
            },
        },
    }

    # Real 3-line exec shim. The clauck binary path is baked in at build
    # time, so the shim has zero runtime dependencies beyond /usr/bin/env
    # python3 — already a clauck non-negotiable.
    launcher = (
        "#!/usr/bin/env python3\n"
        f"# clauck MCP launcher — execs the installed clauck binary.\n"
        f"# Built by clauck's cmd_mcp_install; regenerate by re-running\n"
        f"# `clauck mcp --install`.\n"
        f"import os\n"
        f"os.execv({clauck_bin!r}, [{clauck_bin!r}, 'mcp'])\n"
    )

    bundle_path.parent.mkdir(parents=True, exist_ok=True)
    with zipfile.ZipFile(bundle_path, "w", zipfile.ZIP_DEFLATED) as z:
        z.writestr("manifest.json", json.dumps(manifest, indent=2))
        # Launcher needs to be readable by Claude Desktop; zip doesn't
        # preserve the +x bit but python3 interprets by invocation.
        z.writestr("launch.py", launcher)


def cmd_mcp_install() -> None:
    """Register the clauck MCP server with Claude Code and Claude Desktop.

    Claude Code: uses `claude mcp add --scope user` (authoritative).
    Claude Desktop: builds a .mcpb bundle and opens it via `open`, which
    triggers Claude Desktop's install dialog. The user clicks Install.

    Also removes stale entries from the legacy config files that earlier
    versions of clauck wrote to directly.
    """
    import shutil as _shutil

    config = load_config()
    if config.get("no_mcp_install"):
        print("  MCP auto-install is opted out (no_mcp_install=true in config).")
        print("  To re-enable: clauck config set no_mcp_install false")
        return

    clauck_bin = _shutil.which("clauck") or str(HOME / ".local" / "bin" / "clauck")

    # ── Clean up stale entries written by prior versions ─────────────────
    # These paths are no longer authoritative for either Claude Code or
    # Claude Desktop; leaving old clauck entries there produces ghost
    # registrations that do nothing but confuse `claude mcp list` output
    # and Claude Desktop's server list.
    stale_paths = [
        HOME / ".claude" / "settings.json",
        HOME / "Library" / "Application Support" / "Claude" / "claude_desktop_config.json",
    ]
    for p in stale_paths:
        if _strip_stale_mcp_entry(p, "clauck"):
            print(f"  cleaned stale entry: {p}")

    # ── Claude Code: use `claude mcp add --scope user` ───────────────────
    # --scope user registers the server globally across all projects for
    # the current user. We remove-then-add rather than skip-if-present
    # because `claude mcp add`'s idempotency is keyed on server NAME, not
    # args — a stale registration pointing at a now-missing clauck binary
    # (e.g., user moved /opt/homebrew/bin/clauck → ~/.local/bin/clauck)
    # would make skip-if-present print "already registered" while
    # `claude mcp list` returns connection failures forever. Re-running
    # `clauck mcp --install` must always converge the state with what we
    # just printed to the user.
    claude_bin_path = _shutil.which("claude")
    if claude_bin_path:
        # Best-effort remove. Non-fatal: ignore returncode. If the server
        # isn't registered, remove errors cleanly; if some other registration
        # exists, remove clears it so the add below fully overwrites.
        try:
            subprocess.run(
                [claude_bin_path, "mcp", "remove", "clauck", "-s", "user"],
                capture_output=True, text=True, timeout=10,
            )
        except (subprocess.SubprocessError, OSError):
            pass

        try:
            result = subprocess.run(
                [
                    claude_bin_path, "mcp", "add",
                    "--scope", "user",
                    "clauck", clauck_bin, "mcp",
                ],
                capture_output=True, text=True, timeout=15,
            )
            if result.returncode == 0:
                print(f"  Claude Code: registered clauck → {clauck_bin} mcp")
            else:
                # Print the full error — truncation can cut off the
                # actionable part of a CLI diagnostic. The user is staring
                # at the terminal anyway.
                err = (result.stderr or result.stdout or "").strip()
                print(f"  Claude Code: registration failed — {err}")
                print("  (run manually: "
                      f"claude mcp add --scope user clauck {clauck_bin} mcp)")
        except (subprocess.SubprocessError, OSError) as exc:
            print(f"  Claude Code: registration failed — {exc}")
    else:
        print("  Claude Code: `claude` CLI not on PATH; skipping")
        print("  (install Claude Code or run manually: "
              f"claude mcp add --scope user clauck {clauck_bin} mcp)")

    # ── Claude Desktop: build .mcpb bundle + open it ─────────────────────
    # The modern Claude Desktop MCP install flow is `open foo.mcpb`, which
    # triggers the app's GUI install dialog. The user clicks Install and
    # Claude Desktop handles registration. We can't bypass the confirmation
    # (by design; the new flow is explicit, not automatic), so the best
    # clauck can do is minimize friction: generate a per-install bundle
    # with an absolute command path, invoke `open`, and tell the user
    # what to expect.
    version = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "0.0.0"
    # VERSION file may start with "v"; the manifest semver field expects a
    # bare version. Strip a single leading 'v' if present.
    if version.startswith("v"):
        version = version[1:]
    # Append semver build metadata so every rebuild looks like a distinct
    # version to Claude Desktop. Without this, re-opening the `.mcpb` after
    # any code change (e.g., a manifest fix) is a silent no-op: Desktop
    # sees the same `name` + `version` and keeps the already-installed
    # (potentially stale) copy. Build metadata is semver-compliant
    # (PEP 440-adjacent; `1.5.7+build.20260418T143059Z` is valid) and is
    # ignored by precedence rules — it's the documented mechanism for
    # "same release, different build" signaling. Timestamp granularity is
    # seconds; two rebuilds in the same second shouldn't happen in any
    # realistic install flow, but if they did, the second would no-op
    # exactly as today.
    version = f"{version}+build.{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}"
    bundle_path = JOBS_DIR / "clauck.mcpb"
    try:
        _build_mcpb_bundle(clauck_bin, bundle_path, version)
        print(f"  Claude Desktop: built bundle {bundle_path}")
        try:
            subprocess.run(
                ["open", str(bundle_path)],
                capture_output=True, text=True, timeout=10,
            )
            print("  (Claude Desktop should prompt you to install — click Install)")
        except (subprocess.SubprocessError, OSError) as exc:
            print(f"  (auto-open failed: {exc}; open manually: open {bundle_path})")
    except OSError as exc:
        print(f"  Claude Desktop: bundle build failed — {exc}")

    print()
    print("  tools: list_jobs · get_status · fire_job · get_logs")
    print("         inspect_job · pause_job · resume_job · marketplace_list")


def cmd_mcp() -> None:
    """Start the clauck MCP stdio server (called by Claude Desktop at startup).

    Execs the installed clauck-mcp script. You can also pipe MCP JSON-RPC
    messages to it directly for testing:
        echo '{"jsonrpc":"2.0","id":1,"method":"tools/list"}' | clauck mcp
    """
    mcp_script = JOBS_DIR / "clauck-mcp"
    if not mcp_script.exists():
        die(
            "clauck-mcp not found — re-run the installer to deploy it:\n"
            "  curl -sSL "
            "https://raw.githubusercontent.com/CoreyRDean/clauck/main/install.sh | bash"
        )
    os.execv(sys.executable, [sys.executable, str(mcp_script)])


def cmd_add(path: str, name: str = "", when: str = "") -> None:
    """Import a file as a scheduled job."""
    import shutil
    src = Path(path).expanduser().resolve()
    if not src.exists():
        die(f"file not found: {src}")
    job_name = name or src.stem
    dst = JOBS_DIR / f"{job_name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or use `clauck edit {job_name}`.")
    JOBS_DIR.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(src), str(dst))

    # If the file has no YAML frontmatter, prepend minimal defaults
    text = dst.read_text(encoding="utf-8")
    if not text.startswith("---"):
        header = (
            "---\n"
            f"name: {job_name}\n"
            "max_budget_usd: 2.00\n"
            "effort: high\n"
            "---\n"
        )
        dst.write_text(header + text)

    # If --when provided, use claude to interpret the schedule
    if when:
        claude_bin = _find_claude()
        if claude_bin:
            interpret_prompt = (
                f'The user wants to schedule a job with this timing: "{when}"\n'
                f"Convert this to a 5-field cron expression (minute hour day-of-month month day-of-week).\n"
                f"Reply with ONLY the cron expression, nothing else. Example: 0 9 * * 1-5"
            )
            result = subprocess.run(
                [claude_bin, "-p", interpret_prompt,
                 "--max-turns", "1", "--max-budget-usd", "0.05",
                 "--model", "haiku", "--output-format", "text",
                 "--setting-sources", ""],
                capture_output=True, text=True,
            )
            cron_expr = result.stdout.strip()
            if cron_expr and result.returncode == 0:
                # Insert cron into frontmatter
                text = dst.read_text(encoding="utf-8")
                if "cron:" not in text:
                    # Insert after the opening ---
                    text = text.replace("---\n", f"---\ncron: \"{cron_expr}\"\n", 1)
                    dst.write_text(text)
                print(f"  added: {job_name} (schedule: {cron_expr})")
            else:
                print(f"  added: {job_name} (could not interpret schedule — edit manually)")
        else:
            print(f"  added: {job_name} (claude not found — set cron manually)")
    else:
        print(f"  added: {job_name}")
    print(f"  path: {dst}")
    print(f"  test: clauck fire {job_name}")


# ── validate helpers (mirrors scheduler.py subset; duplicated to keep clauck standalone) ──

_KNOWN_FM_FIELDS: "set[str]" = {
    "name", "description", "cron", "max_turns", "max_budget_usd",
    "cwd", "effort", "model", "setting_sources", "strict_mcp_config",
    "debounce_seconds", "disabled", "run_once", "max_runs",
    "valid_after", "expires_after", "session_persist", "interactive",
    "trace_tool_calls", "external_triggers", "semantic_hooks",
    "tags", "producers", "consumers", "inputs", "version",
    # Sizing: `complexity` is a float 0.0–1.0 that derives model/effort/
    # max_turns/max_budget_usd at run time via lib/sizing.py. Any explicit
    # field overrides its derived counterpart (override semantics are per
    # field, so a job can pin max_turns while leaving everything else
    # derived). See CLAUDE.md "Cost policy" for details.
    "complexity",
}

_EFFORT_VALUES: "set[str]" = {"low", "medium", "high"}


def _suggest_field(unknown: str) -> "str | None":
    """Return the closest known frontmatter field within edit distance 2, or None."""
    best: "str | None" = None
    best_dist = 3
    for k in _KNOWN_FM_FIELDS:
        if abs(len(k) - len(unknown)) > 2:
            continue
        min_len = min(len(k), len(unknown))
        dist = (
            sum(a != b for a, b in zip(k[:min_len], unknown[:min_len]))
            + abs(len(k) - len(unknown))
        )
        if dist < best_dist:
            best_dist, best = dist, k
    return best


def _strip_inline_comment(value: str) -> str:
    """Strip trailing YAML inline comment (` #...`), respecting quotes.

    Mirrors scheduler._strip_inline_comment so both parsers agree. `#` starts
    a comment only when preceded by whitespace (or at start) AND not inside a
    quoted string.
    """
    in_single = False
    in_double = False
    for i, ch in enumerate(value):
        if ch == "'" and not in_double:
            in_single = not in_single
        elif ch == '"' and not in_single:
            in_double = not in_double
        elif ch == "#" and not in_single and not in_double:
            if i == 0 or value[i - 1].isspace():
                return value[:i].rstrip()
    return value


def _parse_fm_block(fm_text: str) -> dict:
    """Parse scheduler-compatible YAML frontmatter subset into a dict."""
    data: dict = {}
    cur_list: "str | None" = None
    for raw in fm_text.splitlines():
        s = raw.strip()
        if not s or s.startswith("#"):
            continue
        if s.startswith("- ") and cur_list is not None:
            item = _strip_inline_comment(s[2:].strip())
            if isinstance(data.get(cur_list), list):
                if item.startswith("{") and item.endswith("}"):
                    obj: dict = {}
                    for part in item[1:-1].split(","):
                        part = part.strip()
                        if ":" in part:
                            k, _, v = part.partition(":")
                            obj[k.strip()] = v.strip().strip('"').strip("'")
                    data[cur_list].append(obj)
                else:
                    data[cur_list].append(item.strip('"').strip("'"))
            continue
        if ":" in s:
            key, _, val = s.partition(":")
            key = key.strip()
            val = _strip_inline_comment(val.strip())
            if val == "":
                data[key] = []
                cur_list = key
            else:
                v: object = val.strip('"').strip("'")
                try:
                    v = int(v)  # type: ignore[assignment]
                except (ValueError, TypeError):
                    try:
                        v = float(v)  # type: ignore[assignment]
                    except (ValueError, TypeError):
                        lv = str(v).lower()
                        if lv == "true":
                            v = True
                        elif lv == "false":
                            v = False
                data[key] = v
                cur_list = None
    return data


def _validate_job_file(
    path: Path, manifest_names: "set[str]"
) -> "list[tuple[str, str]]":
    """Return (level, message) findings. level in {error, warning, ok, info}."""
    import re as _re

    findings: "list[tuple[str, str]]" = []

    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        findings.append(("error", f"cannot read file: {exc}"))
        return findings

    fm_match = _re.match(r"\A---\s*\n(.*?)\n---\s*\n?", text, _re.DOTALL)
    if not fm_match:
        findings.append(("error", "no YAML frontmatter (file must begin with ---)"))
        return findings

    fm = _parse_fm_block(fm_match.group(1))

    # Unrecognized fields
    for key in fm:
        if key not in _KNOWN_FM_FIELDS:
            sug = _suggest_field(key)
            hint = f" (did you mean '{sug}'?)" if sug else ""
            findings.append(("warning", f"unrecognized field '{key}'{hint}"))

    # Cron
    cron = str(fm.get("cron", "")).strip()
    if cron:
        try:
            _cron_matches(cron, datetime.now())
        except (ValueError, IndexError) as exc:
            findings.append(("error", f"invalid cron '{cron}': {exc}"))
        else:
            try:
                nxt = _cron_next(cron, datetime.now(timezone.utc))
                label = _fmt_next_fire(nxt, datetime.now(timezone.utc)) if nxt else "never fires"
                findings.append(("ok", f"cron: '{cron}' — next: {label}"))
            except Exception:
                findings.append(("ok", f"cron: '{cron}'"))
    else:
        if not fm.get("external_triggers"):
            findings.append(("info", "no cron or external_triggers — fires ad-hoc only"))

    # Complexity (new primary sizing input)
    raw_complexity = fm.get("complexity")
    has_complexity = False
    if raw_complexity is not None:
        try:
            c = float(raw_complexity)
            if c < 0.0 or c > 1.0:
                findings.append(("error", f"complexity must be in [0.0, 1.0] (got {c})"))
            else:
                has_complexity = True
                # Route through resolve_params so the validator reports the
                # same derivation the scheduler will actually produce — the
                # scheduler reads strict_mcp_config from frontmatter and
                # passes it through. Prior code called compute_sizing
                # directly without the flag, so a job with strict_mcp_config:
                # true would validate as "promoted to sonnet" but actually
                # run on haiku — validator and runtime disagreed.
                resolved = sizing.resolve_params(fm, 0, sizing.load_doctor_config())
                sized_view = resolved.get("sizing") or {}
                promo_note = (
                    " [haiku auto-promoted → MCP surface]"
                    if sized_view.get("mcp_promoted")
                    else ""
                )
                findings.append((
                    "ok",
                    f"complexity: {c} → derives {resolved['model']}/{resolved['effort']}, "
                    f"{resolved['max_turns']} turns, ${float(resolved['max_budget_usd']):.2f} budget"
                    f"{promo_note}"
                ))
        except (ValueError, TypeError):
            findings.append(("error", f"complexity must be a number (got {raw_complexity!r})"))

    # Budget (still accepted as explicit override, or standalone if no complexity)
    raw_budget = fm.get("max_budget_usd")
    if raw_budget is not None:
        try:
            b = float(raw_budget)
            if b <= 0:
                findings.append(("error", f"max_budget_usd must be > 0 (got {b})"))
            elif b > 10:
                findings.append(("warning", f"max_budget_usd ${b:.2f} is unusually high (> $10)"))
            else:
                label = "budget override" if has_complexity else "budget"
                findings.append(("ok", f"{label}: ${b:.2f}/run"))
        except (ValueError, TypeError):
            findings.append(("error", f"max_budget_usd must be a number (got {raw_budget!r})"))

    # Turns (still accepted as explicit override)
    raw_turns = fm.get("max_turns")
    if raw_turns is not None:
        try:
            t = int(raw_turns)
            if t <= 0:
                findings.append(("error", f"max_turns must be > 0 (got {t})"))
            elif t > 200:
                findings.append(("warning", f"max_turns {t} is unusually high (> 200)"))
        except (ValueError, TypeError):
            findings.append(("error", f"max_turns must be an integer (got {raw_turns!r})"))

    # At least one sizing input required. A job with literally nothing sized
    # falls through to LEGACY_DEFAULTS (max_turns=50, max_budget_usd=$2.00),
    # which is what pre-complexity jobs always did — so this is a warning, not
    # an error, to preserve backward compat. New jobs should declare complexity.
    if raw_complexity is None and raw_turns is None and raw_budget is None:
        findings.append((
            "warning",
            "no sizing declared — falls back to legacy defaults "
            "(max_turns=50, max_budget_usd=$2.00). Add `complexity: <0.0-1.0>` "
            "to frontmatter to pick a derived sizing.",
        ))

    # Effort
    effort = str(fm.get("effort", "")).strip()
    if effort and effort not in _EFFORT_VALUES:
        findings.append(("warning", f"effort '{effort}' not recognized — expected: low / medium / high"))

    # ISO dates
    now_dt = datetime.now(timezone.utc)
    for field in ("valid_after", "expires_after"):
        val = str(fm.get(field, "")).strip()
        if val:
            try:
                dt = datetime.fromisoformat(val)
                if dt.tzinfo is None:
                    dt = dt.replace(tzinfo=timezone.utc)
                if field == "expires_after" and dt < now_dt:
                    findings.append(("warning", f"{field}: '{val}' is already in the past — job is auto-disabled"))
            except ValueError:
                findings.append(("error", f"{field}: '{val}' is not a valid ISO date"))

    # Producer references
    producers = fm.get("producers", [])
    if isinstance(producers, list) and manifest_names:
        for p in producers:
            p_name = p.get("name", "") if isinstance(p, dict) else str(p)
            p_name = str(p_name).strip().strip('"').strip("'")
            if p_name and p_name not in manifest_names:
                findings.append(("error", f"producer '{p_name}' is not an installed job"))

    # External trigger paths
    ext = fm.get("external_triggers", [])
    if isinstance(ext, list):
        for trig in ext:
            if isinstance(trig, dict):
                ttype = str(trig.get("type", ""))
                tpath = str(trig.get("path", "")).strip().strip('"').strip("'")
                if ttype in ("file_added", "file_changed") and tpath:
                    if not Path(os.path.expanduser(tpath)).exists():
                        findings.append(
                            ("warning", f"external_trigger path not found: {tpath}")
                        )

    return findings


def cmd_validate(names: "list[str]", all_jobs: bool = False) -> None:
    """Validate job frontmatter schema, cron syntax, and producer references."""
    manifest_names: "set[str]" = set()
    if MANIFEST.exists():
        try:
            m = json.loads(MANIFEST.read_text())
            manifest_names = {j["name"] for j in m.get("jobs", [])}
        except (OSError, ValueError):
            pass

    paths: "list[tuple[str, Path]]" = []
    if all_jobs:
        for md in sorted(JOBS_DIR.glob("*.md")):
            if not md.name.startswith("."):
                paths.append((md.stem, md))
        for jd in sorted(JOBS_DIR.iterdir()):
            if jd.is_dir() and not jd.name.startswith("."):
                jmd = jd / "JOB.md"
                if jmd.exists():
                    paths.append((jd.name, jmd))
        if not paths:
            print("  no jobs installed")
            return
    else:
        for name in names:
            flat = JOBS_DIR / f"{name}.md"
            module_entry = JOBS_DIR / name / "JOB.md"
            if flat.exists():
                paths.append((name, flat))
            elif module_entry.exists():
                paths.append((name, module_entry))
            else:
                die(f"job not found: {name}")

    n_errors = n_warnings = 0
    for job_name, path in paths:
        print(f"  validating {job_name}...")
        findings = _validate_job_file(path, manifest_names)

        for level, msg in findings:
            if level == "error":
                print(f"  \033[31m✗\033[0m {msg}")
            elif level == "warning":
                print(f"  \033[33m⚠\033[0m {msg}")
            elif level == "ok":
                print(f"  \033[32m✓\033[0m {msg}")
            else:
                print(f"    {msg}")

        ne = sum(1 for lv, _ in findings if lv == "error")
        nw = sum(1 for lv, _ in findings if lv == "warning")
        n_errors += ne
        n_warnings += nw

        if ne == 0 and nw == 0:
            print("  \033[32m✓ all checks passed\033[0m")
        else:
            parts = []
            if ne:
                parts.append(f"{ne} error{'s' if ne != 1 else ''}")
            if nw:
                parts.append(f"{nw} warning{'s' if nw != 1 else ''}")
            print(f"  {', '.join(parts)}")

        if len(paths) > 1:
            print()

    if len(paths) > 1:
        if n_errors == 0 and n_warnings == 0:
            print(f"\033[32m  all {len(paths)} jobs valid\033[0m")
        else:
            print(f"  total: {n_errors} error(s), {n_warnings} warning(s) across {len(paths)} jobs")

    if n_errors > 0:
        sys.exit(1)


def cmd_inspect(name: str) -> None:
    """Inspect a job's full configuration and producer DAG."""
    m = load_manifest()
    jobs = m.get("jobs", [])
    job = None
    for j in jobs:
        if j["name"] == name:
            job = j
            break
    if not job:
        die(f"job not found in manifest: {name}")

    # --- Print full config ---
    print(f"\n  Job: {job['name']}")
    if job.get("description"):
        print(f"  Description: {job['description']}")
    print(f"  Cron: {job.get('cron') or '(none)'}")
    if job.get("module_root"):
        print(f"  Module root: {job['module_root']}")
    print(f"  Prompt: {job.get('prompt_path', '')}")
    print(f"  Disabled: {job.get('disabled', False)}")

    # --- Sizing: resolved params with per-field provenance ---
    # Reads the frontmatter directly so inspect shows the truth of the .md
    # file, not the manifest cache (which is resolved once at scheduler tick
    # time and may lag if the file was edited since). Uses an empty context
    # token count — inspection is a static view; fire-time sizing adds the
    # actual body + producer outputs tax.
    prompt_path = job.get("prompt_path", "")
    fm_for_sizing: dict = {}
    if prompt_path and Path(prompt_path).exists():
        try:
            import re as _re_fm
            text = Path(prompt_path).read_text(encoding="utf-8")
            fm_match = _re_fm.match(r"\A---\s*\n(.*?)\n---\s*\n?", text, _re_fm.DOTALL)
            if fm_match:
                fm_for_sizing = _parse_fm_block(fm_match.group(1))
        except OSError:
            pass
    resolved = sizing.resolve_params(fm_for_sizing, 0, sizing.load_doctor_config())
    prov = resolved["provenance"]
    print("  Sizing:")
    if fm_for_sizing.get("complexity") is not None:
        print(f"    complexity: {fm_for_sizing['complexity']}"
              + (f" (sizing: {resolved['sizing']['explanation']})"
                 if resolved["sizing"] else ""))
    print(f"    model:          {resolved['model'] or '(default)'}  [{prov['model']}]")
    print(f"    effort:         {resolved['effort']}  [{prov['effort']}]")
    print(f"    max_turns:      {resolved['max_turns']}  [{prov['max_turns']}]")
    print(f"    max_budget_usd: ${float(resolved['max_budget_usd']):.2f}  [{prov['max_budget_usd']}]")

    # Show tags
    tags = job.get("tags", [])
    if tags:
        print(f"  Tags: {', '.join(str(t) for t in tags)}")

    # Show triggers
    triggers = job.get("external_triggers", [])
    if triggers:
        print("  External triggers:")
        for t in triggers:
            if isinstance(t, dict):
                parts = [f"{k}={v}" for k, v in t.items()]
                print(f"    - {', '.join(parts)}")
            else:
                print(f"    - {t}")

    hooks = job.get("semantic_hooks", [])
    if hooks:
        print("  Semantic hooks:")
        for h in hooks:
            print(f"    - {h}")

    # Show inputs
    inputs = job.get("inputs", [])
    if inputs:
        print("  Inputs:")
        for inp in inputs:
            if isinstance(inp, dict):
                iname = inp.get("name", "?")
                idefault = inp.get("default", "")
                idesc = inp.get("description", "")
                line = f"    - {iname}"
                if idefault:
                    line += f"  (default: {idefault})"
                if idesc:
                    line += f"  — {idesc}"
                print(line)
            else:
                print(f"    - {inp}")

    # Show producers/consumers
    producers = job.get("producers", [])
    consumers = job.get("consumers", [])
    if producers:
        print(f"  Producers: {', '.join(p['name'] if isinstance(p, dict) else str(p) for p in producers)}")
    if consumers:
        print(f"  Consumers: {', '.join(str(c) for c in consumers)}")

    # --- DAG tree visualization ---
    if producers:
        # Build a lookup from name -> job dict
        job_by_name = {j["name"]: j for j in jobs}

        def build_tree(jname: str, depth: int, visited: set) -> list[tuple[str, int, bool]]:
            """Returns list of (display_name, depth, is_module) tuples."""
            nodes: list[tuple[str, int, bool]] = []
            jobj = job_by_name.get(jname)
            if not jobj:
                return nodes
            prods = jobj.get("producers", [])
            for p in prods:
                pname = p["name"] if isinstance(p, dict) else str(p)
                pobj = job_by_name.get(pname)
                is_mod = bool(pobj.get("module_root", "")) if pobj else False
                nodes.append((pname, depth, is_mod))
                if pname not in visited and depth < 10:
                    visited.add(pname)
                    nodes.extend(build_tree(pname, depth + 1, visited))
            return nodes

        tree = build_tree(name, 0, {name})

        if tree:
            print("\n  Producer DAG:")
            print(f"  {name}")

            # Group by parent for proper tree drawing
            # We need to know which items are last at each depth
            # Simpler approach: walk linearly, tracking depth transitions
            for i, (node_name, depth, is_mod) in enumerate(tree):
                # Determine if this is the last sibling at this depth
                is_last = True
                for future_name, future_depth, _ in tree[i + 1:]:
                    if future_depth == depth:
                        is_last = False
                        break
                    if future_depth < depth:
                        break

                # Build prefix
                prefix = ""
                for d in range(depth):
                    # Check if there's still a continuing branch at this depth
                    has_continuation = False
                    for fn, fd, _ in tree[i + 1:]:
                        if fd == d:
                            has_continuation = True
                            break
                        if fd < d:
                            break
                    prefix += "│  " if has_continuation else "   "

                connector = "└─ " if is_last else "├─ "
                suffix = " (module)" if is_mod else ""
                print(f"  {prefix}{connector}{node_name}{suffix}")

            # Show internal files for modules in the tree
            all_tree_names = {node_name for node_name, _, _ in tree}
            all_tree_names.add(name)
            # Show internals only for modules OTHER than the inspected job itself
            # (the inspected job's own internals are shown separately below).
            inspected_root = job.get("module_root", "")
            for tname in sorted(all_tree_names):
                tobj = job_by_name.get(tname)
                if not tobj or not tobj.get("module_root"):
                    continue
                if tobj["module_root"] == inspected_root:
                    continue  # skip — this is the inspected job itself
                mod_root = Path(tobj["module_root"])
                if mod_root.is_dir():
                    internal_mds = sorted(
                        p for p in mod_root.glob("*.md")
                        if p.name != "JOB.md" and not p.name.startswith(".")
                    )
                    if internal_mds:
                        print(f"\n  Module internals: {tname}")
                        for md in internal_mds:
                            print(f"    [internal] {md.stem}")

    # --- Internal stage DAG for the inspected job itself ---
    if job.get("module_root"):
        mod_root = Path(job["module_root"])
        if mod_root.is_dir():
            internal_mds = sorted(
                p for p in mod_root.glob("*.md")
                if p.name != "JOB.md" and not p.name.startswith(".")
            )
            if internal_mds:
                import re as _re

                def _stage_producers(md_path: Path) -> list[str]:
                    """Parse the producers list from a stage file's frontmatter."""
                    try:
                        text = md_path.read_text(encoding="utf-8")
                    except OSError:
                        return []
                    fm_m = _re.match(r"\A---\s*\n(.*?)\n---\s*\n?", text, _re.DOTALL)
                    if not fm_m:
                        return []
                    result: list[str] = []
                    in_prods = False
                    for line in fm_m.group(1).splitlines():
                        stripped = line.strip()
                        if stripped.startswith("producers:"):
                            tail = stripped[len("producers:"):].strip()
                            if tail.startswith("["):
                                for p in tail.strip("[]").split(","):
                                    p = p.strip().strip("\"'")
                                    if p:
                                        result.append(p)
                            in_prods = True
                            continue
                        if in_prods:
                            if stripped.startswith("- "):
                                item = stripped[2:].strip()
                                if item.startswith("{"):
                                    for part in item.strip("{}").split(","):
                                        part = part.strip()
                                        if ":" in part:
                                            k, _, v = part.partition(":")
                                            if k.strip() == "name":
                                                result.append(v.strip().strip("\"'"))
                                                break
                                else:
                                    result.append(item.strip("\"'"))
                            elif stripped and not stripped.startswith("#"):
                                in_prods = False
                    return result

                # Map stage_name -> [producer_names], anchored at JOB.md
                stage_deps: dict[str, list[str]] = {
                    md.stem: _stage_producers(md) for md in internal_mds
                }
                stage_deps["JOB.md"] = [
                    p["name"] if isinstance(p, dict) else str(p)
                    for p in job.get("producers", [])
                ]

                def _render_internal_dag(node: str, prefix: str, is_last: bool, seen: set) -> None:
                    """Recursively render the internal stage DAG with ASCII connectors."""
                    if node == "JOB.md":
                        print(f"  {node}")
                    else:
                        connector = "└─ " if is_last else "├─ "
                        suffix = " (seen, ref)" if node in seen else " (internal)"
                        print(f"  {prefix}{connector}{node}{suffix}")
                    if node in seen:
                        return
                    seen.add(node)
                    children = stage_deps.get(node, [])
                    for idx, child in enumerate(children):
                        child_is_last = idx == len(children) - 1
                        child_prefix = "" if node == "JOB.md" else prefix + ("   " if is_last else "│  ")
                        _render_internal_dag(child, child_prefix, child_is_last, seen)

                print("\n  Internal stage DAG:")
                _render_internal_dag("JOB.md", "", False, set())

    # --- Runtime state ---
    lock_dir = STATE_DIR / f"{name}.lock.d"
    pid_file = lock_dir / "pid"
    last_start_file = STATE_DIR / f"{name}.last-start"
    state = job_state(name)

    running_pid: int | None = None
    if lock_dir.is_dir() and pid_file.exists():
        try:
            p = int(pid_file.read_text().strip())
            os.kill(p, 0)
            running_pid = p
        except (OSError, ValueError, ProcessLookupError):
            pass  # stale lock — process gone

    last_start_ts: int | None = None
    if last_start_file.exists():
        try:
            last_start_ts = int(last_start_file.read_text().strip())
        except (OSError, ValueError):
            pass

    print("  Runtime state:")
    if running_pid is not None:
        print(f"  Status:     RUNNING (PID {running_pid})")
    elif job.get("disabled"):
        print("  Status:     paused (manually disabled)")
    elif state.get("auto_disabled"):
        ad = state["auto_disabled"]
        if isinstance(ad, dict):
            reason = ad.get("reason", "auto-disabled")
            when = ad.get("at", "")
            suffix = f" (since {when})" if when else ""
            print(f"  Status:     auto-disabled — {reason}{suffix}")
        else:
            print("  Status:     auto-disabled")
    else:
        print("  Status:     idle")

    if state.get("last_run"):
        print(f"  Last run:   {state['last_run']}")

    if last_start_ts is not None:
        print(f"  Last start: {datetime.fromtimestamp(last_start_ts).isoformat()}")

    if state.get("session_id"):
        persist_flag = job.get("session_persist", False)
        label = "persist enabled" if persist_flag else "stale (persist disabled)"
        print(f"  Session:    {state['session_id']} ({label})")

    if state.get("runs_remaining") is not None:
        print(f"  Runs left:  {state['runs_remaining']}")

    print()


def _parse_interpreter_result(
    result: "subprocess.CompletedProcess[str]",
    _re,
) -> tuple[dict, str]:
    """Parse stage-1 interpreter output into (routing_dict, error_string).

    Handles both success (returncode 0) and failure (returncode != 0) by
    reading the JSON envelope from stdout.  claude -p --output-format json
    puts ALL diagnostics in the stdout envelope — stderr is typically empty.
    """
    routing: dict = {}
    interpreter_error = ""

    envelope: dict = {}
    if result.stdout and result.stdout.strip():
        try:
            envelope = json.loads(result.stdout)
        except (json.JSONDecodeError, ValueError):
            pass

    if result.returncode == 0 and envelope:
        inner = envelope.get("result", "").strip()
        json_match = _re.search(r'\{[\s\S]*\}', inner)
        if json_match:
            try:
                routing = json.loads(json_match.group(0))
            except (json.JSONDecodeError, ValueError) as e:
                interpreter_error = f"interpreter JSON parse failed: {e}"
        else:
            interpreter_error = f"no JSON in interpreter output: {inner[:200]}"
    elif result.returncode != 0:
        # Extract error details from the stdout JSON envelope — that's
        # where claude -p --output-format json puts them.  stderr is
        # typically empty for this invocation pattern.
        diag_parts: list[str] = []
        subtype = envelope.get("subtype", "")
        errors = envelope.get("errors", [])
        if subtype:
            diag_parts.append(subtype)
        if errors:
            diag_parts.append("; ".join(str(e) for e in errors))
        if not diag_parts and result.stderr.strip():
            diag_parts.append(result.stderr.strip()[:200])
        interpreter_error = (
            f"interpreter exited {result.returncode}: "
            f"{' — '.join(diag_parts) or '(no diagnostic output)'}"
        )
    elif not envelope:
        interpreter_error = "interpreter produced no output"

    return routing, interpreter_error


def _log_interpreter_failure(
    interpreter_error: str,
    result: "subprocess.CompletedProcess[str]",
    context_label: str,
) -> None:
    """Write the full interpreter failure to a debug file for post-hoc analysis."""
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        debug_path = STATE_DIR / ".interpreter-last-failure.json"
        debug_path.write_text(json.dumps({
            "context": context_label,
            "error": interpreter_error,
            "returncode": result.returncode,
            "stdout": result.stdout[:2000] if result.stdout else "",
            "stderr": result.stderr[:2000] if result.stderr else "",
            "timestamp": datetime.now(timezone.utc).isoformat(),
        }, indent=2) + "\n")
    except Exception:
        pass  # debug logging must never mask the primary failure


def _build_doctor_interpreter_prompt(mode_label: str, context: str) -> str:
    """Stage-1 doctor interpreter: pick a task complexity scale.

    Emits only the scale and a distilled interpretation. Python code
    (lib/sizing.py) derives model, effort, turns, and budget from the scale.
    Doing dollar arithmetic in the prompt produced literal-anchoring
    failures — classifiers grab the nearest dollar value in the prompt
    rather than computing. Moving the math out of the prompt eliminates
    that class of failure structurally.
    """
    ctx_line = context.strip() or "(no user context — general health check)"
    return f"""You are the clauck doctor complexity classifier.

Your ONLY job: read the user's context and emit a JSON object with two fields — `interpretation` and `task_complexity_scale`. Do NOT emit model, turns, budget, or any dollar values. Python computes those from the scale.

# Mode
{mode_label}

# User context (this is what you size)
{ctx_line}

# Pick a scale in [0.00, 1.00]

The scale captures how hard the diagnostic session will be. Reason from the specific context above. Use the example anchors below as calibration, not as a lookup table — interpolate between them.

- **0.05** — trivial state check, one bash call. "is the plist loaded", "is the LaunchAgent active". Haiku/low, 3 turns.
- **0.10** — focused state query with small synthesis. "show me today's log count for job X", "what's the last run time for Y". Haiku/medium, 4 turns.
- **0.20** — focused single-target lookup. "find where X last logged", "is my delegate-scout job running as expected", "why did Y not post". One subsystem, one small log search, some synthesis. Haiku/high, 8 turns.
- **0.35** — single-subsystem deep dive. "pe-pipeline artifact is empty", "why is one job failing after last week's change". One pipeline/module, several files, hypothesis-testing. Haiku/high, 14 turns.
- **0.55** — multi-subsystem investigation OR cross-referencing across independently-maintained state. "intent-miner is silent AND delegate-scout has no successful runs", "check scheduler output AND every cron AND the manifest for drift". Two+ real entities, synthesis across them. Sonnet/medium→high, 18–25 turns.
- **0.75** — module-DAG walk or multi-file architectural trace. "inspect pe-pipeline's 10-stage DAG and tell me which producer is missing the prompt reconstruction directive". Enumerate all stages, trace the chain, locate the fault. Sonnet/high, 40 turns.
- **0.95** — full-system audit or multi-hypothesis architectural analysis. "audit every job, every log, every state file for consistency; produce a risk register". Opus/high, 60+ turns.

# Mode adjustments (applied on top of the base scale)

- `--dry`: read-heavy, no writes. Leave the base scale unchanged.
- `--fix`: adds apply + verify turns per distinct fix named in context. Bump the base scale by +0.10 to +0.20 depending on how many fixes the context names (count each `rm`, each diff block, each file to edit as one fix). If context does not name specific fixes, bump by +0.10 as a floor because `--fix` implies mutation work.
- `--safe` / `--unsafe`: the permission scope does not change the complexity.

# Multi-entity rule (hard)

If the context names **two or more distinct jobs, subsystems, modules, or pipelines** as substantive investigation targets, the MINIMUM scale is 0.50. Multi-entity investigations require cross-reference synthesis that undersizes at lower scales. Treat these terms as **scaffolding**, NOT a second entity when paired with one real target: `scheduler`, `launchd`, `plist`, `hooks`, `the CLI`, `the runtime`, `update-check`, `launch agent`. Two targets both outside the scaffolding list trip this rule; one real target plus scaffolding does not.

# Large context rule

If the user context above is visibly long (multi-hundred lines, looks like a shell-expanded file paste), bump the base scale by +0.10. The context inlines into every turn's input and you want the budget to absorb that — Python will also pay the context-injection tax based on token count, but the extra turns/model capacity is your responsibility to size in.

# Remediation-directive rule

If the context is structured markdown with `## Findings`, `## Recommended fix`, `## Escalation`, or explicit shell commands to apply — that is, it's the output of a prior `--dry` doctor handed back to `--fix` — the minimum scale is 0.45. Low-scale sessions on structured input risk "silent text-completion" (rewriting the findings instead of applying them).

# Bias

When unsure between two adjacent scales, pick the higher one. Doctor is invoked when something is already weird; undersizing wastes both runs. The budget is capped elsewhere — your scale just expresses intent magnitude.

# Output

Return ONLY valid JSON, no prose, no markdown fences:

{{"interpretation": "<distilled one-line diagnostic directive>", "task_complexity_scale": <float 0.0-1.0>}}

The `interpretation` field describes what doctor will investigate — imperative mood, 6–14 words, names the concrete suspicion when context gave one. Example good: "Trace pe-pipeline DAG for missing producer resolution". Example bad: "Run doctor to check things".
"""


def _build_doctor_exec_prompt(dry: bool, safe: bool, context: str) -> str:
    """Build the doctor execution system prompt with mode constraints baked in.

    Four mode combinations:
      --dry --safe    : analysis only, no mutations, no system file touches
      --dry --unsafe  : analysis only (unsafe doesn't matter in dry mode)
      --fix --safe    : may edit user job files; system files read-only → escalate
      --fix --unsafe  : may edit anything, including system files
    """
    if dry:
        mode_block = """# Mode: DRY (analysis only)

You are in DRY mode. DO NOT mutate any files. No Write, no Edit, no rm, no mv, no file-modifying Bash commands. Read everything you need; propose fixes as a plan for the human to apply.

If you notice fixes that obviously should be applied, list them in a "## Recommended fixes" block at the end with exact commands or diffs. Do not apply them.

For each **actionable, non-optional** finding, include a one-line code block under the finding with a ready-to-run command of the form `clauck doctor --fix "<concise imperative instruction that applies ONLY this finding>"`. The instruction is a natural-language directive for the fix agent (not shell), so keep it a single line with no embedded double-quotes. Findings that are purely advisory / optional / informational get NO per-finding fix command — do not coax the user into optional work."""
    elif safe:
        mode_block = f"""# Mode: FIX / SAFE

**Your job is to APPLY fixes, not recommend them.** This is --fix mode, not --dry mode. You have Edit, Write, and Bash available in this session specifically so you can make the repairs yourself. Writing "Recommended fix" or "here is the diff to apply" instead of actually applying it is a failure of this mode.

**Mandatory behavior:**
- If you identify a fix: **apply it now** using Edit/Write/Bash. Then re-read the changed file (or re-run the affected command) to verify the change took. Report what you applied AND what verification showed.
- If you examine the issue and determine no fix is needed (already resolved, false alarm, user misconception): say so explicitly with the evidence. This is distinct from "recommending a fix without applying it" — the former is valid, the latter is a mode violation.
- Do NOT produce a "## Recommended fixes" section in your output. Recommendations are --dry mode's job.
- Do NOT ask the user for confirmation before applying. Confirmation was granted by invoking --fix. The session runs to completion and reports what it did.

**Scope — you MAY edit USER job files:**
  - `.md` files directly under {JOBS_DIR}/ (flat jobs)
  - `.md` files within module directories (e.g. {JOBS_DIR}/<module>/*.md, including nested modules)
  - State files under {JOBS_DIR}/.state/ (e.g., stale trigger state, auto-disable markers)

**Scope — you MUST NOT modify these clauck system files:**
  - {JOBS_DIR}/scheduler.py
  - {JOBS_DIR}/dag-runner.py
  - {JOBS_DIR}/run-job.sh
  - {JOBS_DIR}/trigger-job.sh
  - {JOBS_DIR}/update-check.sh
  - {JOBS_DIR}/uninstall.sh
  - {JOBS_DIR}/.version
  - ~/.claude/hooks/scheduled-jobs-notice.sh
  - ~/.claude/scheduled-jobs-prompt.md
  - ~/.local/bin/clauck
  - ~/.claude/skills/clauck/SKILL.md
  - ~/Library/LaunchAgents/com.*.claude-scheduler.plist

**Escalation path (the ONLY legitimate reason not to apply a fix in this mode):** if the root cause lives in a system file above, STOP touching it and write a "## Escalation: system file mutation requested" block with:
  - Which system file(s) need changing
  - The exact diff or change required
  - Why the change is needed (root cause)
  - Why this can't be worked around at the user-job layer

The human will re-run with --unsafe or apply the fix manually. This is a feature, not a limitation: system files affect every user, so changes are gated. Anything fixable within the user-job scope is YOUR responsibility to apply in this session."""
    else:
        mode_block = f"""# Mode: FIX / UNSAFE

**Your job is to APPLY fixes, not recommend them.** This is --fix mode. You have Edit, Write, and Bash available across the full {JOBS_DIR}/ tree including system files (scheduler.py, dag-runner.py, run-job.sh, etc.). The user explicitly opted in with --unsafe. Writing "Recommended fix" instead of actually applying it is a mode violation.

**Mandatory behavior:**
- If you identify a fix: **apply it now** using Edit/Write/Bash. Re-read or re-run to verify. Report what you applied AND what verification showed.
- If you determine no fix is needed (already resolved, false alarm): say so with evidence.
- Do NOT produce a "## Recommended fixes" section. Do NOT ask the user for confirmation before applying — confirmation was granted by invoking --fix --unsafe.

**Scope:** the entire clauck install. Still prefer minimal-blast-radius fixes. If a user-job fix and a system-file fix would both resolve the issue, pick the user-job fix. System file changes should be deliberate, explained, and tied to a concrete failure — not speculative cleanup."""

    return f"""You are `clauck doctor` — a diagnostic and repair agent for the clauck workflow automation system on this machine.

{mode_block}

# User context (this is your task — read it first)
{context.strip() or "(none — run a general health sweep)"}

# How to use the context

**If the context is specific** — it names files, describes concrete findings, lists fixes to apply, or is clearly the output of a prior `--dry` doctor being handed back to `--fix` — then the context **is** your task. Do NOT run a general health sweep. Go directly to the files/operations the context names. Read only what you need to apply and verify the specified fixes. The diagnostic menu below is **not** a checklist — it is a fallback for the vague-context case. Walking it in addition to specific fixes burns turns you need for applying and verifying. Turn budgets assume you skip the menu when context is specific.

**If the context is vague** ("something's weird", "check health", or empty) — then yes, walk the diagnostic menu below in priority order until you find something actionable, then stop the sweep and focus on what you found.

# Diagnostic surface (fallback menu for vague-context sessions only)

Priority order — not a mandatory checklist:
1. **LaunchAgent** — `launchctl list | grep claude-scheduler`. If not loaded, that's a blocker.
2. **Scheduler output** — `tail -50 {JOBS_DIR}/.scheduler-stderr.log` and `{JOBS_DIR}/.scheduler-stdout.log`.
3. **Manifest freshness** — `stat {MANIFEST}` and compare mtime to now; if older than ~2 minutes the scheduler isn't ticking.
4. **Manifest errors** — read `{MANIFEST}` and check for `dag_errors` key (cycle detection or missing-producer errors).
5. **Auto-disabled jobs** — `ls {STATE_DIR}/*.auto-disabled 2>/dev/null`; read each file for the reason.
6. **Recent failures** — scan `{JOBS_DIR}/*.log` for recent non-zero exit_code tombstones.
7. **DAG invocation logs** — `{JOBS_DIR}/*-dag-*.log` for pipeline failures.
8. **Frontmatter errors** — parse each job .md; report malformed YAML.
9. **Version / update state** — `cat {JOBS_DIR}/.version` and `{STATE_DIR}/.update-available` if present.

Stop walking the menu as soon as you have a concrete issue to address. Finding one real problem in items 1–3 means items 4–9 are not your business for this session.

# Output shape

Keep output tight. Template depends on mode:

**DRY mode — your final message MUST be a single JSON object (no prose, no markdown fences around the object itself) matching this schema:**

```
{{
  "report": "<the full human-readable markdown report — summary, findings (with per-item `clauck doctor --fix \"...\"` code blocks under each actionable finding), and Recommended fixes section>",
  "fix_instruction": "<single-line imperative covering ALL non-optional findings, suitable for passing as the argument of `clauck doctor --fix \"...\"`>" | null
}}
```

Rules:
- `report` is a JSON-escaped string. Newlines in the markdown must be encoded as `\n`. Double-quotes in the markdown must be escaped as `\"`. Backticks, `#`, and other markdown syntax need no escaping.
- `fix_instruction` is `null` if the report is healthy or contains only advisory/optional items. Otherwise it is a concise imperative that, when handed back to `clauck doctor --fix "..."`, captures all non-optional fixes as a single directive.
- `fix_instruction`, when non-null, must be a single line (no newlines) and must not contain double-quote characters (so it renders cleanly inside the outer `"..."` on the user's terminal and in a re-invocation).
- Nothing outside the JSON object. No preamble, no trailing prose, no code fences around the outermost `{{...}}`.

The inner `report` is the markdown shape the user will see. Target structure for `report` content:

```
## Health summary
<one-line overall status>

## Findings
1. <Issue>: <root cause>. <Recommended fix: exact command or diff>.
   `clauck doctor --fix "<per-item instruction>"`
2. ...

## Recommended fixes
<exact commands or diffs, grouped and deduplicated>
```

(Omit the per-item `clauck doctor --fix` line for any finding that is purely advisory / optional. If the whole report is healthy, the `report` markdown can be a single line and `fix_instruction` is `null`.)

**FIX mode (safe or unsafe):**
```
## Health summary
<one-line overall status>

## Findings
1. <Issue>: <root cause>. <Applied: what you did>. <Verified: what you checked after>.
2. ...

## Applied fixes
<list of each mutation actually performed: file path + summary of change. One entry per Edit/Write/Bash that mutated state.>

## Escalations (only if system-file fix blocked by --safe)
<format from mode block>

## No-op verifications (only if a finding needed no action)
<finding + evidence that confirmed no fix needed>
```

A "## Recommended fixes" section in FIX mode output is a bug. If you would have written one, apply it instead.

If everything is healthy: a single line. Do not pad.
"""


def cmd_doctor(
    dry: bool = True,
    fix: bool = False,
    safe: bool = True,
    unsafe: bool = False,
    interactive: bool = False,
    context: str = "",
) -> None:
    """Diagnose clauck health with mode-gated repair.

    Modes:
      --dry (default) vs --fix   — analysis-only vs apply fixes to user jobs
      --safe (default) vs --unsafe — restrict vs allow system-file mutation

    Routes through a stage-1 interpreter that picks model/effort/turns/budget
    based on the context complexity, matching how `clauck work` scales. Shows
    a spinner so long-running sessions are visible.
    """
    import threading
    import time as _time

    # Flag resolution: --fix overrides the default --dry; --unsafe overrides
    # the default --safe. The defaults bias toward the safest combination.
    if fix:
        dry = False
    if unsafe:
        safe = False

    mode_label = f"--{'fix' if not dry else 'dry'} --{'unsafe' if not safe else 'safe'}"

    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — clauck doctor requires claude on PATH")

    # ── Spinner ──────────────────────────────────────────────────────────
    spinner_running = [True]
    spinner_label = [f"mining intent ({mode_label})"]
    start_time = _time.time()

    def spinner() -> None:
        chars = "\u280b\u2819\u2839\u2838\u283c\u2834\u2826\u2827\u2807\u280f"
        i = 0
        while spinner_running[0]:
            elapsed = int(_time.time() - start_time)
            sys.stderr.write(f"\r  {chars[i % len(chars)]} {spinner_label[0]}... ({elapsed}s)")
            sys.stderr.flush()
            i += 1
            _time.sleep(0.1)
        sys.stderr.write("\r" + " " * 70 + "\r")
        sys.stderr.flush()

    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # ── Stage 1: complexity classifier ───────────────────────────────────
    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        empty_mcp.write_text('{"mcpServers":{}}')

    interpreter_prompt = _build_doctor_interpreter_prompt(mode_label, context)
    user_prompt = "Classify this doctor invocation."

    import re as _re
    try:
        result_s1 = subprocess.run(
            [claude_bin, "-p", user_prompt,
             "--append-system-prompt", interpreter_prompt,
             "--model", "sonnet",
             "--effort", "low",
             "--max-turns", "2",
             "--max-budget-usd", "0.25",
             "--output-format", "json",
             "--setting-sources", "",
             "--strict-mcp-config",
             "--mcp-config", str(empty_mcp)],
            capture_output=True, text=True,
        )
    except Exception:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        raise

    routing, interpreter_error = _parse_interpreter_result(result_s1, _re)

    # Classifier emits {interpretation, task_complexity_scale}. Python
    # derives model/effort/turns/budget from the scale via sizing.compute_sizing
    # so literal dollar values in the prompt can't anchor the classifier.
    doctor_cfg = sizing.load_doctor_config()
    ctx_tokens = sizing.estimate_tokens(context or "")

    scale: float = 0.5  # fallback midpoint if classifier fails
    if routing:
        raw_scale = routing.get("task_complexity_scale")
        if raw_scale is None:
            # Accept legacy fallback routes (fallback below emits old shape).
            raw_scale = routing.get("scale")
        try:
            scale = float(raw_scale) if raw_scale is not None else 0.5
        except (TypeError, ValueError):
            scale = 0.5
    else:
        if interpreter_error:
            _log_interpreter_failure(interpreter_error, result_s1, "doctor")
            sys.stderr.write(f"\r  ! interpreter fallback: {interpreter_error[:120]}\n")
            sys.stderr.flush()
        routing = {
            "interpretation": "Run standard diagnostic sweep",
            "task_complexity_scale": 0.5,
        }

    interpretation = routing.get("interpretation", "Run diagnostic sweep")
    # Doctor's stage-2 does NOT pass --strict-mcp-config — the diagnostic
    # agent needs the user's MCP surface available (for --fix mode to post
    # Slack escalations, query GitHub, etc.). So strict_mcp=False here,
    # which lets compute_sizing auto-promote haiku → sonnet to avoid the
    # compaction loop on MCP-heavy context.
    sized = sizing.compute_sizing(scale, ctx_tokens, doctor_cfg, strict_mcp=False)
    exec_model = sized["model"]
    exec_effort = sized["effort"]
    exec_max_turns = str(sized["max_turns"])
    exec_max_budget = str(sized["max_budget_usd"])

    # Print interpretation + sizing transparency + separator, then resume
    # spinner with new label. Every doctor run shows its sizing math so cost
    # is a first-class transparent policy (INTENT.md §3 #4).
    spinner_running[0] = False
    spin_thread.join(timeout=0.5)
    print(f"  \u2192 {interpretation} [{mode_label}]")
    print(f"  \u2192 {sized['explanation']}")
    print(f"  {'─' * 60}")

    # ── Stage 2: diagnostic execution ────────────────────────────────────
    exec_prompt = _build_doctor_exec_prompt(dry=dry, safe=safe, context=context)

    spinner_running[0] = True
    spinner_label[0] = f"diagnosing ({exec_model}, {exec_effort} effort)"
    start_time = _time.time()
    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # Permission strategy: always inject --dangerously-skip-permissions +
    # --permission-mode bypassPermissions + an explicit --settings allowlist.
    # Recent claude CLI sandbox guards block reads outside CWD (e.g. ~/.claude/,
    # ~/Library/LaunchAgents/) even in --dry mode unless the settings allowlist
    # explicitly permits them. This matches the pattern used by `clauck work`.
    #
    #   dry    → read-oriented allowlist. Reads anywhere + read-only bash.
    #            The exec prompt forbids mutation; no Write/Edit allow rules
    #            mean the sandbox is defense-in-depth on top of that.
    #   fix/safe   → adds user-job .md writes (module + flat).
    #   fix/unsafe → opens full Bash/Write/Edit surface.
    cli = [claude_bin, "-p", "Run the doctor diagnostic per your system prompt.",
           "--append-system-prompt", exec_prompt,
           "--max-turns", exec_max_turns,
           "--max-budget-usd", exec_max_budget,
           "--model", exec_model,
           "--effort", exec_effort,
           "--output-format", "json",
           "--setting-sources", ""]

    read_only_allow = [
        "Read(**)",
        "Bash(launchctl *)",
        "Bash(ls *)",
        "Bash(cat *)",
        "Bash(tail *)",
        "Bash(head *)",
        "Bash(stat *)",
        "Bash(grep *)",
        "Bash(find *)",
        "Bash(wc *)",
        "Bash(pgrep *)",
        "Bash(ps *)",
        "Bash(date *)",
        "Bash(plutil *)",
        "Bash(file *)",
    ]

    if dry:
        allowlist = {
            "permissions": {
                "defaultMode": "bypassPermissions",
                "allow": read_only_allow,
            }
        }
    else:
        # Fix mode (both --safe and --unsafe): use the same broad permission
        # surface as `clauck work`. Three attempts at glob-scoped allowlists
        # for --safe (*.md, /*/**.md, **/*.md) all failed to match module-
        # depth paths in Claude Code's settings matcher — producing permission
        # blocks on user job files that doctor was explicitly supposed to edit.
        # The safe/unsafe distinction is now enforced entirely by the exec
        # prompt, which explicitly lists forbidden system files in --safe mode.
        # This matches how `clauck work` operates (full bypass, prompt-scoped).
        allowlist = {
            "permissions": {
                "defaultMode": "bypassPermissions",
                "allow": [
                    "Bash(*)", "Read(**)", "Write(**)", "Edit(**)",
                    f"Write({JOBS_DIR}/**)",
                    f"Edit({JOBS_DIR}/**)",
                    f"Bash(rm *{STATE_DIR}/*)",
                    f"Bash(mkdir *{JOBS_DIR}/*)",
                ],
            }
        }
    cli += ["--dangerously-skip-permissions",
            "--permission-mode", "bypassPermissions",
            "--settings", json.dumps(allowlist)]

    try:
        result = subprocess.run(cli, capture_output=True, text=True)
    finally:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)

    try:
        envelope = json.loads(result.stdout) if result.stdout else {}
    except (json.JSONDecodeError, ValueError):
        envelope = {}

    claude_result = envelope.get("result", "").strip()
    is_error = envelope.get("is_error", result.returncode != 0)
    session_id = envelope.get("session_id", "")

    # Auto-skew: detect budget truncation from the envelope's structured
    # fields (subtype + errors list), NOT by substring-matching the whole
    # combined output. The latter would false-positive on any diagnostic
    # whose report text happens to mention budget truncation (extremely
    # common once users start debugging this feature). The Claude CLI emits
    # {"subtype": "error_max_budget_usd", "is_error": true,
    #  "errors": ["Reached maximum budget ($X)"]} on the actual hit.
    envelope_subtype = envelope.get("subtype", "") if isinstance(envelope, dict) else ""
    envelope_errors = envelope.get("errors") if isinstance(envelope, dict) else None
    if isinstance(envelope_errors, list):
        errors_joined = " ".join(str(e) for e in envelope_errors)
    else:
        errors_joined = str(envelope_errors or "")
    budget_hit = (
        envelope_subtype == "error_max_budget_usd"
        or "Reached maximum budget" in errors_joined
    )
    # Short-circuit auto-skew when the budget was already clamped by the
    # config ceiling — bumping skew cannot help if max_budget_usd is the
    # binding constraint (it would just inflate the un-clamped intermediate).
    # Compare raw-derived against the clamped value; if they differ, the
    # clamp already fired and a warning belongs here instead of a silent bump.
    budget_was_clamped = False
    if sized and isinstance(sized, dict):
        raw_total = (sized.get("base_cost", 0.0) + sized.get("context_cost", 0.0)) * sized.get("headroom", 1.3)
        budget_was_clamped = abs(raw_total - sized.get("max_budget_usd", 0.0)) > 0.05

    try:
        if budget_hit and budget_was_clamped:
            print(
                f"  \u26a0 budget hit AND budget was clamped to max_budget_usd "
                f"(${doctor_cfg.get('max_budget_usd', 10.0):.2f}). "
                f"Raise it with: clauck config doctor max_budget_usd <value>",
                file=sys.stderr,
            )
        elif budget_hit:
            new_cfg = sizing.apply_auto_skew_on_budget_hit()
            new_skew = new_cfg.get("scale_skew", 0.0)
            print(
                f"  \u26a0 budget hit — scale_skew auto-bumped to +{new_skew:.2f} "
                f"(next run will size larger)",
                file=sys.stderr,
            )
        elif not is_error and float(doctor_cfg.get("scale_skew", 0.0)) > 0.0:
            new_cfg = sizing.apply_auto_skew_decay()
            new_skew = new_cfg.get("scale_skew", 0.0)
            if new_skew < float(doctor_cfg.get("scale_skew", 0.0)):
                print(
                    f"  \u2713 clean run — scale_skew decayed to +{new_skew:.2f}",
                    file=sys.stderr,
                )
    except Exception as exc:  # noqa: BLE001 — config tuning must never mask primary output
        print(f"  (scale_skew adjust failed: {exc})", file=sys.stderr)

    # In DRY mode the exec prompt requires the final message to be a JSON
    # object of shape {"report": "<markdown>", "fix_instruction": "<str>|null}.
    # Parse it to extract the display report and the optional queued fix. If
    # parsing fails (malformed JSON, model drift), fall back to treating the
    # whole result as markdown with no queued fix — graceful degradation to
    # the pre-schema behaviour.
    fix_instruction = ""
    if dry and claude_result:
        import re as _re_json
        inner_obj = None
        try:
            inner_obj = json.loads(claude_result)
        except (json.JSONDecodeError, ValueError):
            # Tolerate markdown fences or leading/trailing prose by grabbing
            # the outermost {...} span, matching the stage-1 interpreter's
            # parser in _parse_interpreter_result.
            span = _re_json.search(r"\{[\s\S]*\}", claude_result)
            if span:
                try:
                    inner_obj = json.loads(span.group(0))
                except (json.JSONDecodeError, ValueError):
                    inner_obj = None
        if isinstance(inner_obj, dict) and isinstance(inner_obj.get("report"), str):
            claude_result = inner_obj["report"].strip()
            candidate = inner_obj.get("fix_instruction")
            if isinstance(candidate, str):
                candidate = candidate.strip()
                # Guard rails: single line, no embedded double-quotes (display
                # sanity when echoed inside `clauck doctor --fix "..."`).
                if candidate and "\n" not in candidate and '"' not in candidate:
                    fix_instruction = candidate

    if claude_result:
        print(claude_result)

    if is_error:
        err_text = envelope.get("errors") or result.stderr
        if err_text:
            if isinstance(err_text, list):
                err_text = "; ".join(str(e) for e in err_text)
            print(str(err_text).strip(), file=sys.stderr)
        sys.exit(1)

    # Auto-prompt: if the diagnostic model queued a fix instruction and we're
    # running attached to a tty, offer to run it without the user retyping. The
    # instruction is passed as a single argv element to a re-invocation of this
    # same CLI — no shell interpretation, so fix_instruction can't expand to
    # arbitrary commands.
    if fix_instruction and sys.stdin.isatty() and sys.stdout.isatty():
        print()
        print(f'  Queued fix: clauck doctor --fix "{fix_instruction}"')
        try:
            resp = input("  Proceed with fix? [Y/n] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return
        if resp in ("", "y", "yes"):
            fix_argv = [sys.argv[0], "doctor", "--fix"]
            if not safe:
                # Preserve --unsafe only if the original invocation was --unsafe.
                # Never elevate a --safe dry run to --unsafe auto-fix.
                fix_argv.append("--unsafe")
            fix_argv.append(fix_instruction)
            os.execvp(sys.argv[0], fix_argv)

    # Optional interactive follow-up on a resolvable session.
    if interactive and session_id:
        print("\n  Opening interactive session for follow-up...")
        os.execvp(claude_bin, [claude_bin, "--resume", session_id])


def _find_claude() -> str | None:
    """Locate the claude binary."""
    for p in [HOME / ".local" / "bin" / "claude", Path("/usr/local/bin/claude")]:
        if p.exists():
            return str(p)
    import shutil
    return shutil.which("claude")


def _build_interpreter_prompt() -> str:
    """Build the stage-1 interpreter system prompt with live manifest data.

    KNOWN COMPLIANCE GAP vs INTENT.md §4 (Cost transparency, v2): the
    semantic interpreter still emits exec_model/exec_effort/exec_max_turns/
    exec_max_budget_usd directly in its routing JSON, rather than a
    task_complexity_scale that Python derives from. The doctor interpreter
    was migrated to the scale-only contract in this release; the semantic
    path is tracked for migration before v3 of the INTENT contract. The
    job-creation guidance inside this prompt already directs created jobs
    to use `complexity:` in frontmatter, so the gap is only the
    interpreter's OWN stage-2 sizing, not the jobs it creates.
    """
    subcommands = (
        "list, status, fire, pause, resume, edit, logs, marketplace, install, "
        "update, config, doctor, peek, version, add, inspect, work, "
        "remove (aliases: delete, rm)"
    )

    # Read manifest for job descriptions + inputs
    job_descriptions = ""
    if MANIFEST.exists():
        try:
            m = json.loads(MANIFEST.read_text())
            for j in m.get("jobs", []):
                name = j["name"]
                desc = (j.get("description") or "")[:120]
                inputs_list = j.get("inputs", [])
                input_names = []
                for inp in inputs_list:
                    if isinstance(inp, dict):
                        input_names.append(inp.get("name", "?"))
                    else:
                        input_names.append(str(inp))
                inputs_str = ", ".join(input_names) if input_names else "(none)"
                job_descriptions += f"  - {name}: {desc}  [inputs: {inputs_str}]\n"
        except (OSError, ValueError):
            job_descriptions = "  (manifest unreadable)\n"
    else:
        job_descriptions = "  (no manifest found)\n"

    return f"""You are the clauck CLI interpreter (stage 1). Your ONLY job is to classify a user's natural-language input and return a JSON routing decision.

# Known clauck subcommands
{subcommands}

# Registered jobs (from manifest)
{job_descriptions}
# Routing rules

**Pick "deterministic" when the user's intent maps directly to an existing clauck subcommand or job trigger:**
- "Run jobA" / "fire jobA" / "trigger jobA" -> deterministic (clauck fire jobA)
- "show me jobA's last run" / "logs for jobA" -> deterministic (clauck logs jobA)
- "Pause jobA" / "disable jobA" -> deterministic (clauck pause jobA)
- "Resume jobA" / "enable jobA" -> deterministic (clauck resume jobA)
- "Delete jobA" / "remove jobA" / "rm jobA" -> deterministic (clauck remove jobA). Direct filesystem op — always prefer this over Write/Delete via the execution agent.
- "What jobs are running" / "list jobs" -> deterministic (clauck list)
- "System status" / "how is clauck doing" -> deterministic (clauck status)
- "Fire jobA with the source at ~/file.md" -> deterministic; convert to KEY=VALUE args using the job's declared inputs

**Pick "semantic" when the user's intent requires Claude to create, modify, or reason about jobs:**
- "Do X every morning" / "Build a pipeline that..." -> semantic
- "Change heartbeat to every 2 hours" -> semantic
- "Create a job that watches for new PDFs" -> semantic
- "What ran today and were there any failures?" -> semantic (needs log analysis)

# Sizing the semantic execution (for command_type="semantic")

Reason from the specific request, not from tiers. Every invocation has a different shape.

**Cost anchors** (approximate):
- haiku: $1/M input, $5/M output, fast. Good for status queries, lookups, pure-reasoning tasks with small context.
- sonnet: $3/M input, $15/M output. Good for anything that requires synthesis, code authoring, multi-file work.
- opus: $15/M input, $75/M output. Reach for this only when deep reasoning across tangled code or architecture is unavoidable.
- Tool-chain turn with tool calls + reasoning overhead: ~$0.02 on haiku, ~$0.08 on sonnet, ~$0.40 on opus.

**Sizing dimensions:**
- Read cost: how many files must the session open? How large are they? Manifest is ~1KB; a single job .md is ~3–6KB; a log can be hundreds of KB.
- Write cost: how much new code/config will the session produce? 50 lines is small; 500 lines of new job scaffolding is not.
- Reasoning depth: can the agent answer after one read, or must it synthesize across multiple files? Multi-step reasoning needs sonnet.
- Verification: does the request include "make sure it works" or "test it"? Add turns for re-reading and validating.

**Model selection heuristics (not rules):**
- Status query, single lookup, list-and-filter → haiku is usually enough.
- Create/modify a single job, answer a code question from context → sonnet.
- Multi-file refactor, DAG wiring, module creation with internal stages, anything requiring careful cross-referencing → sonnet at high effort.
- Genuinely architectural decisions or tricky debugging with many unknowns → opus, sparingly.

**Turns and budget:**
- Turns = roughly (reads + writes + verifications) × 1.3 for reasoning overhead.
- Budget = sum of per-turn cost estimates × 1.3 for headroom. Hitting the budget ceiling truncates output; one that runs a few cents over is fine.
- A session that lands at 60% of its budget ceiling did it right. 100% is too tight.

**Hard floors and ceilings** (guardrails, not targets):
- Minimum: 3 turns, $0.05, haiku.
- Maximum: 60 turns, $3.00, sonnet (or opus if genuinely warranted).
- Above the ceiling, reconsider the request — suggest breaking into multiple invocations in the interpretation field.

# When the execution will CREATE or EDIT a job file — use `complexity:` in the frontmatter

The shared sizing formula (lib/sizing.py) lets jobs declare their sizing via a single `complexity:` field (float 0.0–1.0). The scheduler derives model/effort/max_turns/max_budget_usd from it at fire time. This is the **preferred** way to size any new job:

```yaml
complexity: 0.35   # single-source digest, moderate synthesis
cron: "0 13 * * 1-5"
setting_sources: ""
```

**Complexity scale for jobs** (interpolate between):
- **0.10** — heartbeat-style state check, one bash call + report.
- **0.25** — focused single-source digest, one-subsystem log scan, small Slack/Gmail query.
- **0.40** — multi-source digest or routine synthesis across 2–3 sources (Slack + Calendar + Jira).
- **0.55** — investigation across multiple state stores, "why did X happen" questions, multi-file read-and-correlate.
- **0.75** — multi-stage module, producer/consumer DAG, cross-subsystem audit with synthesis.
- **0.95** — deep architectural workflow, major multi-hour scheduled process.

**Per-field overrides:** explicit `max_turns`, `max_budget_usd`, `effort`, or `model` in frontmatter act as overrides for that field only — they win over the derived value, but leave the others derived. Use only when a specific value is genuinely required (e.g., a job that needs `model: haiku` for cost control on a high-frequency cron).

**Do NOT** emit a job with both `complexity:` AND redundant explicit `max_turns`/`max_budget_usd`/`effort`/`model` that match what the formula would derive — it clutters the frontmatter and divorces the declared intent from the derivation. Emit complexity alone, with overrides only where needed.

Legacy jobs with explicit `max_turns`/`max_budget_usd`/`effort`/`model` and no `complexity:` continue to work unchanged — the resolver falls back to the explicit values. Prefer migrating them to `complexity:` when editing, but do not force-migrate on unrelated edits.

# CRITICAL: Quality of `interpretation` field

The `interpretation` field is the value you add. It is shown to the user as feedback proving you understood their intent. It MUST:

1. **Be a distillation, not a copy.** Never echo the user's words verbatim. Rewrite in your own words capturing the intent.
2. **Read like a CLI directive.** Imperative mood, 6–14 words, no filler, no pronouns ("Create hourly job...", not "I will create...").
3. **Name the concrete artifact.** When creating a job, include the inferred job name. When firing, include the resolved args.
4. **Expose inferred details.** Name the schedule in human terms ("every hour on the hour"), the model tier, and the job type (standard vs module) when relevant.
5. **Never be generic.** "Execute semantic command" or "Run user request" are failures. Be specific about the what and where.

Bad interpretation: "execute: every hour invoke a claude code session to mine..."
Good interpretation: "Create hourly module 'intent-miner' (sonnet, medium budget) that opens a draft PR"

Bad interpretation: "I want to see my jobs"
Good interpretation: "List all registered jobs with schedules and status"

# CRITICAL: Quality of `enhanced_prompt` field (semantic only)

The `enhanced_prompt` is what the execution agent receives. It must:
1. **Preserve all intent** the user expressed.
2. **Add prescriptive structure** the user didn't say but that the execution agent needs (file path, frontmatter fields, module vs standard choice, cron expression).
3. **Remove conversational filler** and reformulate as a task brief.
4. **Scale detail with complexity.** A trivial request stays terse. A complex pipeline gets a structured breakdown.

# Output format

Return ONLY valid JSON, no markdown fencing, no explanation:

For deterministic:
{{"command_type": "deterministic", "interpretation": "<distilled CLI directive>", "deterministic_argv": ["clauck", "fire", "jobA", "KEY=value"]}}

**CRITICAL — use `deterministic_argv` (JSON array), NOT a single string, whenever any arg value contains spaces, quotes, newlines, or shell metacharacters.** Each token is ONE element of the array. Multi-word arg values go in ONE element: `"SOURCE_CONTENT=This is a long source document."`, not split across multiple elements. There is no shell tokenization pass — what you put in the array is what the CLI receives.

Single-string `deterministic_cmd` is still accepted for simple cases (`"clauck list"`, `"clauck fire jobA"`), parsed with shell-style quoting. Prefer `deterministic_argv` by default — it cannot be misparsed.

For semantic:
{{"command_type": "semantic", "interpretation": "<distilled CLI directive>", "enhanced_prompt": "<prescriptive task brief>", "exec_model": "haiku"|"sonnet"|"opus", "exec_effort": "low"|"medium"|"high", "exec_max_turns": <int>, "exec_max_budget_usd": <float>}}"""


SEMANTIC_EXEC_SYSTEM_PROMPT = """You are the clauck CLI executing a user's natural-language command.

# ABSOLUTE RULES — VIOLATING ANY OF THESE IS INCORRECT BEHAVIOR

1. **THE USER EXPLICITLY CHOSE CLAUCK.** They installed clauck, typed `clauck`, and gave you input. Their intent is unambiguous: use clauck. Any other interpretation is wrong.

2. **DO NOT USE ANY NATIVE CLAUDE SCHEDULING MECHANISM.** This includes but is not limited to:
   - `scheduled_task_create` or any `scheduled_task_*` tool
   - `/loop`, native cron tasks, Claude Desktop scheduled tasks, Claude Cloud scheduled tasks
   - Creating `trig_*` or similar Anthropic-managed triggers
   - The `claude.ai/code/scheduled/` management UI
   - ANY tool that creates a schedule outside of clauck's filesystem

3. **If the user's request involves scheduling, reminders, recurring tasks, pipelines, event triggers, chained prompts, workflows, or any form of deferred/repeated/orchestrated execution, the ONLY valid action is to create/modify clauck jobs in `{JOBS_DIR}/`.**

4. **Two job formats are available — pick the right one:**

   **a) Standard format** — a single file at `{JOBS_DIR}/<name>.md`. Use for:
   - Single-purpose scheduled tasks (daily digest, reminder, status check)
   - Jobs triggered by events (file_added, process_starts, etc.)
   - Any job whose logic fits in a single prompt

   **b) Module format** — a folder `{JOBS_DIR}/<name>/` containing `JOB.md` plus internal `.md` files. Use for:
   - Multi-stage pipelines where the stages are implementation details
   - DAG-based workflows with multiple producer/consumer relationships
   - Prompt chains where each stage has its own focused prompt and model
   - Any job complex enough that breaking it into internal stages would improve clarity, cost, or debuggability

   Internal module files form a DAG via `producers:` / `consumers:` in their frontmatter. Only `JOB.md` appears in the top-level manifest; internal stages are hidden from listings. Path references in module prompts are relative to the module root.

5. **To create a scheduled job:**
   - Write the `.md` file(s) using the Write tool
   - Set appropriate frontmatter. **Prefer `complexity: <0.0-1.0>`** over raw `max_turns`/`max_budget_usd`/`effort`/`model` — the shared sizing formula derives the four params at fire time and keeps cost consistent across the system. Scale anchors: 0.10 = trivial state check, 0.25 = focused digest, 0.40 = routine multi-source synthesis, 0.55 = investigation with correlation, 0.75 = multi-stage DAG, 0.95 = deep architectural workflow. Interpolate between them.
   - Only add explicit `max_turns`, `max_budget_usd`, `effort`, or `model` fields as **per-field overrides** when a specific value is genuinely required (e.g., pinning `model: haiku` for cost control on a high-frequency cron). Do not duplicate what the formula would derive.
   - For modules: write JOB.md + internal stage files, wire them with producers. Each stage gets its own `complexity:` sized to that stage's work.
   - The scheduler picks up changes within 60 seconds. NO registration call needed.
   - Verify by reading `{MANIFEST}` after ~60s OR by running `clauck inspect <name>` (shows resolved sizing with per-field provenance).

6. **NO EXCEPTIONS.** Even if a native scheduling tool looks more convenient or better-integrated, it is WRONG. The user installed clauck specifically to avoid native scheduling. Respecting that choice is not optional.

# Operational scope

Available operations (and ONLY these):
- Create, edit, pause, resume, remove scheduled jobs (standard or module format) at `{JOBS_DIR}/`
- Read the manifest at `{MANIFEST}`
- Read/write state at `{STATE_DIR}/`
- Read the marketplace at `{MARKETPLACE_DIR}/`
- Read/write config at `{CONFIG_FILE}`
- Fire jobs via `{TRIGGER_SCRIPT}`
- Read logs at `{JOBS_DIR}/<name>-*.log`

Produce the actionable result directly. No preamble. No explanation of your process. No sign-off.
If you attempt to use a native scheduling tool, you have failed."""


_WATCHER_PROMPT_BODY = """\
You are a GitHub issue state watcher. Your job is to detect meaningful state changes on one GitHub issue and surface them to the user.

## Issue to watch

URL: {{env:CLAUCK_INPUT_ISSUE_URL}}

## What to check

1. Run `gh issue view <URL> --json state,title,labels,comments,closedAt` to get current state.
2. Read the last known state from `~/.clauck/.state/<job-name>.json` if it exists (ignore file-not-found).
3. Compare current vs last state. Interesting changes:
   - Issue **closed** or **reopened**
   - A label was **added or removed** (especially milestone/target/priority labels)
   - A **PR was opened** that references this issue — check via `gh pr list --search "closes #<number>" --repo <owner>/<repo> --json number,title,url,state`
   - Issue was added to a **milestone** or **project**
4. If any interesting change is detected, report it. If no change, exit silently without posting.

## How to report

Interesting change detected:

- If `CLAUCK_INPUT_NOTIFY_CHANNEL` is non-empty: post a brief Slack message to that channel ID via the Slack MCP `slack_send_message` tool.
- Otherwise: append to `~/Documents/clauck/<job-name>-updates.md` (create file/dir if needed).

Format:

```
📌 *<issue title>*
<change summary — one line each>
<issue URL>
```

## State persistence

After each check, write current state to `~/.clauck/.state/<job-name>.json`:

```json
{
  "state": "open|closed",
  "labels": ["label1"],
  "linked_prs": [123],
  "checked_at": "ISO-8601 timestamp"
}
```

`<job-name>` is the `name:` field from this job's frontmatter.

## Rules

- Do not post if nothing changed since last check.
- Do not post the issue body — only state changes.
- If `gh` is not on PATH, write a one-line error to the updates file and exit.
- If the issue URL is the default placeholder (`/issues/0`), write a setup reminder to the updates file and exit.
"""


def _install_issue_watcher(issue_url: str, notify_channel: str = "") -> str:
    """Install a watcher job for a GitHub issue. Returns the job name."""
    import re as _re

    m = _re.search(r"github\.com/([^/]+/[^/]+)/issues/(\d+)", issue_url)
    if not m:
        raise ValueError(f"Cannot parse issue URL: {issue_url}")
    repo = m.group(1)
    number = m.group(2)

    job_name = f"gh-watch-{number}"
    job_path = JOBS_DIR / f"{job_name}.md"

    notify_default = notify_channel or ""
    frontmatter = f"""\
---
name: {job_name}
description: "Watch github.com/{repo}/issues/{number} for state changes"
cron: "0 12 * * *"
max_turns: 12
max_budget_usd: 0.15
effort: low
model: haiku
strict_mcp_config: false
tags:
  - github
  - monitoring
  - issue-watcher
inputs:
  - name: ISSUE_URL
    default: "{issue_url}"
  - name: NOTIFY_CHANNEL
    default: "{notify_default}"
---
"""
    job_path.write_text(frontmatter + "\n" + _WATCHER_PROMPT_BODY)
    return job_name


def _find_pending_drafts() -> list:
    """Return list of draft paths in REPORTS_DIR, newest first."""
    if not REPORTS_DIR.exists():
        return []
    return sorted(
        REPORTS_DIR.glob("*-draft.json"),
        key=lambda p: p.stat().st_mtime,
        reverse=True,
    )


def _build_interactive_mining_prompt(draft_path: "Path", prefilled: dict | None = None) -> str:
    """System prompt for an interactive intent-mining session.

    Instructs the agent to mine user intent conversationally, save drafts to
    disk at draft_path, and submit via gh when the user is satisfied.
    """
    prefill_block = ""
    if prefilled and isinstance(prefilled.get("title"), str):
        import json as _json
        prefill_block = f"""
## Pre-loaded draft (from initial description)
Use this as a starting point and refine it with the user:

```json
{_json.dumps(prefilled, indent=2)}
```
"""

    return f"""You are the clauck issue reporter in interactive mining mode.

Your goal: collaborate with the user to draft a high-quality GitHub issue.
{prefill_block}
## Your process

1. **Introduce yourself briefly** — one sentence. Ask the user to describe their issue or feature request.
2. **Mine intent** — ask focused follow-up questions. Prefer binary or short-answer questions over open-ended ones. For bugs: Steps to reproduce, expected vs actual. For features: the motivation/why, acceptance criteria.
3. **Offer exit ramps** — after each exchange, mention "say 'draft it' when you're ready". Don't force extra turns.
4. **Save the draft** whenever you have a reasonable version. Use:
```bash
python3 -c "import json, pathlib; pathlib.Path('{draft_path}').parent.mkdir(parents=True, exist_ok=True); pathlib.Path('{draft_path}').write_text(json.dumps({{'title': 'TITLE', 'body': 'BODY', 'labels': ['enhancement'], 'classification': 'feature', 'related': []}}, indent=2))"
```
   Replace TITLE and BODY with the actual values. Update the file on each refinement.
5. **Show and submit** when the user is satisfied:
   - Show a one-line summary of the title
   - Ask: "Submit to GitHub? [y/N]"
   - On yes: run `gh issue create --title "TITLE" --body "BODY" --label LABEL`
   - Report the issue URL

## Constraints
- Only `gh` CLI and `python3 -c` for draft writing are permitted.
- Do not open PRs. This session is for issue drafting only.
- If the user says "quit", "exit", or "cancel": save whatever draft exists and exit gracefully.
- Keep the draft body under 500 words. Focus on clarity, not exhaustiveness.
"""


def _launch_interactive_mining(draft_path: "Path", prefilled: dict | None = None) -> None:
    """Spawn an interactive Claude session for intent mining."""
    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — clauck report requires claude on PATH")

    REPORTS_DIR.mkdir(parents=True, exist_ok=True)
    STATE_DIR.mkdir(parents=True, exist_ok=True)

    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        empty_mcp.write_text('{"mcpServers":{}}')

    prompt = _build_interactive_mining_prompt(draft_path, prefilled)
    allowlist = json.dumps({
        "permissions": {
            "defaultMode": "bypassPermissions",
            "allow": [
                "Bash(gh *)",
                "Bash(python3 -c *)",
            ],
        }
    })

    cli = [
        claude_bin,
        "--append-system-prompt", prompt,
        "--setting-sources", "",
        "--strict-mcp-config",
        "--mcp-config", str(empty_mcp),
        "--dangerously-skip-permissions",
        "--permission-mode", "bypassPermissions",
        "--settings", allowlist,
    ]

    try:
        subprocess.run(cli)
    except KeyboardInterrupt:
        pass


def _build_report_exec_prompt(tail: str) -> str:
    """System prompt for the report-writing session.

    The session fetches existing issues for duplicate detection, then drafts a
    structured ticket. Output must be a single JSON object — no prose.
    """
    description_block = tail.strip() or "(no description provided)"
    return f"""You are the clauck issue reporter. Draft a high-quality GitHub issue from the user's description.

# User description
{description_block}

# Steps (execute in order)

1. **Fetch existing issues** — run:
   `gh issue list --state all --limit 100 --json number,title,labels,state`
   If `gh` is unavailable or returns an error, skip duplicate detection and proceed.
   For any issue whose title strongly overlaps the description, run:
   `gh issue view <N> --json number,title,state,body`
   to read the body before classifying overlap.

2. **Classify** — pick one: bug / feature / idea / question / regression

3. **Draft the ticket**:
   - `title`: concise imperative phrase, under 70 characters
   - `body`: full GitHub-flavored markdown body ready for `gh issue create --body`.
     For bugs: include ## Summary, ## Steps to Reproduce, ## Expected, ## Actual.
     For features/ideas: include ## Summary, ## Motivation, ## Acceptance Criteria.
     Do NOT repeat the title in the body. Keep under 500 words.
   - `labels`: exactly one of ["bug", "enhancement", "security"]
     - bug / regression → "bug"
     - feature / idea / question → "enhancement"
     - security issue → "security"
   - `related`: list of close matches found in step 1. Each entry:
     {{"number": <int>, "title": "<str>", "overlap": "duplicate|related|stale"}}
     Only include issues with genuine overlap. Empty list if none.
   - `mine`: set to `true` if the description is too vague to draft a quality ticket
     and interactive refinement would help; `false` otherwise.

4. **Output ONLY valid JSON, no prose, no markdown fences**:
{{"title": "...", "body": "...", "labels": ["..."], "classification": "bug|feature|idea|question|regression", "related": [{{"number": 0, "title": "...", "overlap": "..."}}], "mine": false}}

Guidelines:
- If a near-duplicate exists with overlap "duplicate": flag it and still draft the ticket; the user decides whether to proceed.
- The body field must be the complete markdown body — not a summary of it.
- Set `mine: true` only when the description genuinely lacks enough detail to produce a useful ticket.
- Never add fields not in the schema above.
"""


def _handle_report_inbox() -> None:
    """Surface pending report drafts and let the user review/submit/discard each."""
    import shutil as _shutil

    drafts = _find_pending_drafts()
    if not drafts:
        print("  no pending drafts")
        return

    sep = "\u2500" * 60
    for i, path in enumerate(drafts, 1):
        try:
            draft = json.loads(path.read_text())
        except (json.JSONDecodeError, OSError):
            print(f"  {i}. {path.name}  [unreadable — skipping]")
            continue

        title = draft.get("title", "(untitled)")
        classification = draft.get("classification", "feature")
        mtime = datetime.fromtimestamp(path.stat().st_mtime, tz=timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
        print(f"\n  [{i}/{len(drafts)}] {classification}: {title}")
        print(f"  saved: {mtime}")
        print(f"  {sep}")
        body_preview = (draft.get("body") or "")[:300]
        for line in body_preview.splitlines()[:8]:
            print(f"  {line}")
        print()

        if not (sys.stdin.isatty() and sys.stdout.isatty()):
            continue

        try:
            resp = input("  [s]ubmit  [d]iscard  [skip/Enter] ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return

        if resp in ("d", "discard"):
            path.unlink(missing_ok=True)
            print("  discarded")
        elif resp in ("s", "submit"):
            gh_bin = _shutil.which("gh")
            if not gh_bin:
                die("gh not found on PATH — install the GitHub CLI to submit issues")
            labels = draft.get("labels") or ["enhancement"]
            label = labels[0] if isinstance(labels, list) and labels else "enhancement"
            body = draft.get("body", "")
            result = subprocess.run(
                [gh_bin, "issue", "create", "--title", title, "--body", body, "--label", label],
                capture_output=True, text=True,
            )
            if result.returncode != 0:
                print(f"  ! submit failed: {result.stderr.strip()}", file=sys.stderr)
            else:
                print(f"  \u2713 submitted: {result.stdout.strip()}")
                path.unlink(missing_ok=True)


def cmd_report(tail: str = "", inbox: bool = False) -> None:
    """Draft and optionally submit a GitHub issue from a free-text description.

    With no args and an interactive tty, launches an intent-mining session.
    With --inbox, surfaces pending drafts from prior sessions.
    With a text argument, runs a headless drafting session.
    """
    if inbox:
        _handle_report_inbox()
        return

    import re as _re
    import threading
    import time as _time

    # No args + interactive tty → check for pending drafts or launch mining
    if not tail and sys.stdin.isatty() and sys.stdout.isatty():
        pending = _find_pending_drafts()
        if pending:
            print(f"  {len(pending)} pending draft(s) — run `clauck report --inbox` to review")
            print()
        import datetime as _dt
        ts = _dt.datetime.now().strftime("%Y%m%dT%H%M%S")
        draft_path = REPORTS_DIR / f"{ts}-draft.json"
        print("  Starting interactive intent-mining session...")
        print("  Describe your issue to Claude. Say 'draft it' when ready to commit.")
        print()
        _launch_interactive_mining(draft_path)
        if draft_path.exists():
            try:
                saved = json.loads(draft_path.read_text())
                title = saved.get("title", "(untitled)")
                print(f"\n  Draft saved: {title}")
                print("  Run `clauck report --inbox` to submit or discard it.")
            except (json.JSONDecodeError, OSError):
                pass
        return

    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — clauck report requires claude on PATH")

    spinner_running = [True]
    start_time = _time.time()

    def spinner() -> None:
        chars = "\u280b\u2819\u2839\u2838\u283c\u2834\u2826\u2827\u2807\u280f"
        i = 0
        while spinner_running[0]:
            elapsed = int(_time.time() - start_time)
            sys.stderr.write(f"\r  {chars[i % len(chars)]} drafting issue... ({elapsed}s)")
            sys.stderr.flush()
            i += 1
            _time.sleep(0.1)
        sys.stderr.write("\r" + " " * 60 + "\r")
        sys.stderr.flush()

    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        empty_mcp.write_text('{"mcpServers":{}}')

    exec_prompt = _build_report_exec_prompt(tail)
    allowlist = {
        "permissions": {
            "defaultMode": "bypassPermissions",
            "allow": ["Bash(gh *)"],
        }
    }

    cli = [claude_bin, "-p", "Draft the GitHub issue per your system prompt.",
           "--append-system-prompt", exec_prompt,
           "--max-turns", "10",
           "--max-budget-usd", "0.40",
           "--model", "haiku",
           "--output-format", "json",
           "--setting-sources", "",
           "--strict-mcp-config",
           "--mcp-config", str(empty_mcp),
           "--dangerously-skip-permissions",
           "--permission-mode", "bypassPermissions",
           "--settings", json.dumps(allowlist)]

    try:
        result = subprocess.run(cli, capture_output=True, text=True)
    finally:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)

    envelope: dict = {}
    if result.stdout and result.stdout.strip():
        try:
            envelope = json.loads(result.stdout)
        except (json.JSONDecodeError, ValueError):
            pass

    is_error = envelope.get("is_error", result.returncode != 0)
    claude_result = envelope.get("result", "").strip()

    draft: dict = {}
    if claude_result:
        try:
            draft = json.loads(claude_result)
        except (json.JSONDecodeError, ValueError):
            span = _re.search(r'\{[\s\S]*\}', claude_result)
            if span:
                try:
                    draft = json.loads(span.group(0))
                except (json.JSONDecodeError, ValueError):
                    pass

    if is_error and not draft:
        err_text = envelope.get("errors") or result.stderr
        if err_text:
            if isinstance(err_text, list):
                err_text = "; ".join(str(e) for e in err_text)
            print(str(err_text).strip(), file=sys.stderr)
        if claude_result:
            print(claude_result)
        sys.exit(1)

    if not draft or not isinstance(draft.get("title"), str):
        if claude_result:
            print(claude_result)
        else:
            die("report: no draft produced — check that gh is on PATH and you're authenticated")
        return

    # Stage 1 flagged description as too vague → offer interactive refinement
    if draft.get("mine") and sys.stdin.isatty() and sys.stdout.isatty():
        import datetime as _dt
        ts = _dt.datetime.now().strftime("%Y%m%dT%H%M%S")
        draft_path = REPORTS_DIR / f"{ts}-draft.json"
        print("  \u2192 description needs more context; launching interactive refinement...")
        print()
        _launch_interactive_mining(draft_path, prefilled=draft)
        if draft_path.exists():
            try:
                saved = json.loads(draft_path.read_text())
                saved_title = saved.get("title", "(untitled)")
                print(f"\n  Draft saved: {saved_title}")
                print("  Run `clauck report --inbox` to submit or discard it.")
            except (json.JSONDecodeError, OSError):
                pass
        return

    title = draft.get("title", "").strip()
    body = draft.get("body", "").strip()
    classification = draft.get("classification", "feature")
    labels = draft.get("labels") or ["enhancement"]
    related = draft.get("related") or []

    sep = "\u2500" * 60
    print(f"  \u2192 {classification}: {title}")
    print(f"  {sep}")
    print()
    body_lines = body.split("\n")
    preview_lines = body_lines[:60]
    for line in preview_lines:
        print(f"  {line}")
    if len(body_lines) > 60:
        print(f"  [... {len(body_lines) - 60} more lines ...]")
    print()
    if related:
        rel_strs = []
        for r in related:
            if isinstance(r, dict) and r.get("number"):
                snippet = str(r.get("title", ""))[:50]
                overlap = r.get("overlap", "related")
                rel_strs.append(f"#{r['number']} {snippet} [{overlap}]")
        if rel_strs:
            print(f"  Related: {', '.join(rel_strs)}")
    print(f"  {sep}")

    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        return

    print()
    try:
        resp = input("  Submit to GitHub? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if resp not in ("y", "yes"):
        return

    import shutil as _shutil
    gh_bin = _shutil.which("gh")
    if not gh_bin:
        die("gh not found on PATH — install the GitHub CLI to submit issues")

    label = labels[0] if isinstance(labels, list) and labels else "enhancement"
    create_result = subprocess.run(
        [gh_bin, "issue", "create", "--title", title, "--body", body, "--label", label],
        capture_output=True, text=True,
    )
    if create_result.returncode != 0:
        print(f"  ! gh issue create failed: {create_result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    issue_url = create_result.stdout.strip()
    print(f"  \u2713 submitted: {issue_url}")

    _offer_issue_watcher(issue_url)


def _offer_issue_watcher(issue_url: str) -> None:
    """Prompt the user to install a daily watcher job for the submitted issue."""
    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        return
    if not issue_url.startswith("https://github.com/"):
        return

    print()
    try:
        resp = input(
            "  Watch this issue? I'll post updates when it closes, gets a PR, or changes labels. [Y/n] "
        ).strip().lower()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if resp in ("n", "no"):
        return

    try:
        job_name = _install_issue_watcher(issue_url)
        print(f"  \u2713 watcher installed: {job_name} (daily at noon UTC)")
        print(f"    Updates → ~/Documents/clauck/{job_name}-updates.md")
        print(f"    Pause anytime: clauck pause {job_name}")
    except Exception as exc:
        print(f"  ! could not install watcher: {exc}", file=sys.stderr)


def cmd_semantic(text: str) -> None:
    """Two-stage natural-language command pipeline.

    Stage 1: Cheap Haiku interpreter classifies the command (~$0.01).
    Stage 2: Either run a deterministic command or execute with the
             interpreter-chosen model/effort/turns/budget.
    """
    import re as _re
    import threading
    import time as _time

    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — semantic commands require claude on PATH")

    # ── Spinner (wraps both stages) ──────────────────────────────────────
    spinner_running = [True]
    spinner_label = ["mining intent"]
    start_time = _time.time()

    def spinner():
        chars = "\u280b\u2819\u2839\u2838\u283c\u2834\u2826\u2827\u2807\u280f"
        i = 0
        while spinner_running[0]:
            elapsed = int(_time.time() - start_time)
            label = spinner_label[0]
            sys.stderr.write(f"\r  {chars[i % len(chars)]} {label}... ({elapsed}s)")
            sys.stderr.flush()
            i += 1
            _time.sleep(0.1)
        sys.stderr.write("\r" + " " * 50 + "\r")
        sys.stderr.flush()

    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # ── Stage 1: Interpreter ────────────────────────────────────────────
    interpreter_prompt = _build_interpreter_prompt()
    user_prompt = f"The user ran: `clauck {text}`"

    # Use strict-mcp-config with empty config so the interpreter runs bare
    # (no MCP surface cache-creation cost). Without this, $0.05 budget is
    # consumed immediately by MCP tool prompt.
    empty_mcp = STATE_DIR / ".empty-mcp-config.json"
    if not empty_mcp.exists():
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        empty_mcp.write_text('{"mcpServers":{}}')

    try:
        # Use Sonnet for reliability — Haiku was generating explanatory prose
        # instead of strict JSON on edge cases. Cost increase is marginal
        # (~$0.03-0.05 vs $0.01) and the reliability is worth it.
        result_s1 = subprocess.run(
            [claude_bin, "-p", user_prompt,
             "--append-system-prompt", interpreter_prompt,
             "--model", "sonnet",
             "--max-turns", "3",
             "--max-budget-usd", "0.30",
             "--output-format", "json",
             "--setting-sources", "",
             "--strict-mcp-config",
             "--mcp-config", str(empty_mcp)],
            capture_output=True, text=True,
        )
    except Exception:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        raise

    routing, interpreter_error = _parse_interpreter_result(result_s1, _re)

    if not routing or "command_type" not in routing:
        if interpreter_error:
            _log_interpreter_failure(interpreter_error, result_s1, f"semantic: {text[:80]}")
            sys.stderr.write(f"\r  ! interpreter fallback: {interpreter_error[:120]}\n")
            sys.stderr.flush()
        routing = {
            "command_type": "semantic",
            "interpretation": "(interpreter failed — raw request passed through)",
            "enhanced_prompt": text,
            "exec_model": "sonnet",
            "exec_effort": "medium",
            "exec_max_turns": 15,
            "exec_max_budget_usd": 0.50,
        }

    interpretation = routing.get("interpretation", text)

    # ── Stage 2: Dispatch ───────────────────────────────────────────────

    if routing["command_type"] == "deterministic":
        # Stop spinner, print interpretation, then run the deterministic command
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)
        print(f"  \u2192 {interpretation}")

        # Two supported formats from the interpreter, in priority order:
        #
        # 1. `deterministic_argv`: a JSON array of tokens, e.g.
        #    ["clauck", "fire", "pe-pipeline", "SOURCE_CONTENT=long text with spaces"]
        #    This is the preferred format because it's unambiguous — no
        #    tokenization pass, no quoting rules for the model to get right.
        #
        # 2. `deterministic_cmd`: a single shell-style string (legacy).
        #    We parse with shlex.split so quoted values survive:
        #    `clauck fire pe-pipeline SOURCE_CONTENT="long text with spaces"`
        #    A naive .split() (which this used to do) truncated multi-word
        #    arg values at the first space, causing pipelines like pe-pipeline
        #    to receive only the first word of SOURCE_CONTENT.
        argv = routing.get("deterministic_argv")
        if isinstance(argv, list) and argv:
            parts = [str(a) for a in argv]
        else:
            det_cmd = routing.get("deterministic_cmd", "").strip()
            if not det_cmd:
                die("interpreter returned deterministic but no command/argv")
            import shlex as _shlex
            try:
                parts = _shlex.split(det_cmd)
            except ValueError as e:
                # Malformed quoting. Fall back to naive split with a loud
                # warning so the bug is visible, not silent truncation.
                print(
                    f"  ! shlex parse failed ({e}); falling back to naive split — "
                    f"multi-word arg values will be truncated",
                    file=sys.stderr,
                )
                parts = det_cmd.split()

        if parts and parts[0] == "clauck":
            parts = parts[1:]
        if parts and parts[0] == "bash":
            # Direct trigger-job.sh invocation
            result = subprocess.run(parts, capture_output=True, text=True)
            print(result.stdout.strip())
            if result.returncode != 0:
                print(result.stderr.strip(), file=sys.stderr)
                sys.exit(result.returncode)
        elif parts:
            # Re-enter clauck's own main dispatch
            sys.argv = ["clauck"] + parts
            main()
        else:
            die(f"could not parse deterministic command: argv={argv!r} cmd={routing.get('deterministic_cmd', '')!r}")
        return

    # semantic path — run execution pass with interpreter-chosen parameters
    # Temporarily pause spinner to print interpretation, then resume with new label
    spinner_running[0] = False
    spin_thread.join(timeout=0.5)
    print(f"  \u2192 {interpretation}")
    print(f"  {'─' * 60}")

    exec_model = routing.get("exec_model", "sonnet")
    exec_effort = routing.get("exec_effort", "medium")
    exec_max_turns = str(routing.get("exec_max_turns", 15))
    exec_max_budget = str(routing.get("exec_max_budget_usd", 0.50))
    enhanced_prompt = routing.get("enhanced_prompt", text)

    system_prompt = SEMANTIC_EXEC_SYSTEM_PROMPT.replace("{JOBS_DIR}", str(JOBS_DIR))
    system_prompt = system_prompt.replace("{MANIFEST}", str(MANIFEST))
    system_prompt = system_prompt.replace("{STATE_DIR}", str(STATE_DIR))
    system_prompt = system_prompt.replace("{MARKETPLACE_DIR}", str(MARKETPLACE_DIR))
    system_prompt = system_prompt.replace("{CONFIG_FILE}", str(CONFIG_FILE))
    system_prompt = system_prompt.replace("{TRIGGER_SCRIPT}", str(TRIGGER_SCRIPT))

    # Restart spinner for stage 2 with updated label
    spinner_running[0] = True
    spinner_label[0] = f"executing ({exec_model}, {exec_effort} effort)"
    start_time = _time.time()
    spin_thread = threading.Thread(target=spinner, daemon=True)
    spin_thread.start()

    # Explicit permission allowlist for the scheduled-jobs directory.
    # Recent claude CLI versions added extra guards on .claude/ paths that
    # --dangerously-skip-permissions + --permission-mode bypassPermissions
    # don't override. --settings injects explicit allow rules that do.
    allowlist_settings = json.dumps({
        "permissions": {
            "defaultMode": "bypassPermissions",
            "allow": [
                "Bash(*)",
                "Write(**)",
                "Edit(**)",
                "Read(**)",
                f"Write({JOBS_DIR}/**)",
                f"Edit({JOBS_DIR}/**)",
                f"Bash(rm *{JOBS_DIR}/*)",
                f"Bash(mkdir *{JOBS_DIR}/*)",
            ],
        }
    })

    try:
        result = subprocess.run(
            [claude_bin, "-p", enhanced_prompt,
             "--append-system-prompt", system_prompt,
             "--dangerously-skip-permissions",
             "--permission-mode", "bypassPermissions",
             "--settings", allowlist_settings,
             "--max-turns", exec_max_turns,
             "--max-budget-usd", exec_max_budget,
             "--model", exec_model,
             "--effort", exec_effort,
             "--output-format", "json",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
    finally:
        spinner_running[0] = False
        spin_thread.join(timeout=0.5)

    # Parse Claude's JSON envelope
    try:
        envelope = json.loads(result.stdout) if result.stdout else {}
    except (json.JSONDecodeError, ValueError):
        envelope = {}

    is_error = envelope.get("is_error", result.returncode != 0)
    claude_result = envelope.get("result", "").strip()

    if claude_result:
        print(claude_result)

    if is_error:
        err_text = envelope.get("errors") or result.stderr
        if err_text:
            if isinstance(err_text, list):
                err_text = "; ".join(str(e) for e in err_text)
            print(str(err_text).strip(), file=sys.stderr)
        sys.exit(1)


# ── main ─────────────────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    # JIT update notice (reads local state file, no network)
    jit_update_check()

    cmd = args[0]
    rest = args[1:]

    if cmd == "list":
        tag_filter = ""
        if "--tag" in rest:
            idx = rest.index("--tag")
            if idx + 1 < len(rest):
                tag_filter = rest[idx + 1]
        cmd_list(tag_filter=tag_filter)
    elif cmd == "next":
        cmd_next()
    elif cmd == "history":
        h_job = ""
        h_last = 30
        h_days = 0
        h_all = "--all" in rest
        if "--last" in rest:
            idx = rest.index("--last")
            if idx + 1 < len(rest):
                h_last = int(rest[idx + 1])
            rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
        if "--days" in rest:
            idx = rest.index("--days")
            if idx + 1 < len(rest):
                h_days = int(rest[idx + 1])
            rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
        rest = [r for r in rest if r != "--all"]
        if rest:
            h_job = rest[0]
        cmd_history(h_job, h_last, h_days, h_all)
    elif cmd == "trace" and rest:
        cmd_trace(rest[0])
    elif cmd == "trace":
        die("usage: clauck trace <invocation-id>")
    elif cmd == "status":
        cmd_status()
    elif cmd == "fire" and rest:
        cmd_fire(rest[0], extra_args=rest[1:])
    elif cmd == "pause" and rest:
        cmd_pause(rest[0])
    elif cmd == "resume" and rest:
        cmd_resume(rest[0])
    elif cmd == "edit" and rest:
        cmd_edit(rest[0])
    elif cmd in ("remove", "delete", "rm") and rest:
        cmd_remove(rest[0])
    elif cmd in ("rename", "mv") and len(rest) >= 2:
        cmd_rename(rest[0], rest[1])
    elif cmd in ("rename", "mv"):
        die(f"usage: clauck {cmd} <old-name> <new-name>")
    elif cmd == "logs" and rest:
        last = 5
        show = 0
        follow = False
        if "--last" in rest:
            idx = rest.index("--last")
            if idx + 1 < len(rest):
                last = int(rest[idx + 1])
            rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
        if "--show" in rest:
            idx = rest.index("--show")
            # Optional N after --show; default to 1 (most recent)
            if idx + 1 < len(rest) and rest[idx + 1].isdigit():
                show = int(rest[idx + 1])
                rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
            else:
                show = 1
                rest = [r for i, r in enumerate(rest) if i != idx]
        if "--follow" in rest or "--tail" in rest:
            follow = True
            rest = [r for r in rest if r not in ("--follow", "--tail")]
        cmd_logs(rest[0], last, show, follow)
    elif cmd == "marketplace":
        if rest and rest[0] == "updates":
            cmd_marketplace_updates()
        elif rest and rest[0] == "info" and len(rest) >= 2:
            cmd_marketplace_info(rest[1])
        elif rest and rest[0] == "search":
            cmd_marketplace_search(" ".join(rest[1:]))
        else:
            cmd_marketplace(filter_tag=rest[0] if rest else "")
    elif cmd == "install" and rest:
        job_arg = rest[0] if not rest[0].startswith("-") else (rest[1] if len(rest) > 1 else "")
        if not job_arg:
            die("usage: clauck install <marketplace-job> [--update]")
        cmd_install_marketplace(job_arg, update="--update" in rest)
    elif cmd == "update":
        cmd_update(apply="--apply" in rest)
    elif cmd == "uninstall":
        cmd_uninstall(wipe="--wipe" in rest)
    elif cmd == "config":
        cmd_config(rest)
    elif cmd == "version":
        cmd_version()
    elif cmd == "peek":
        cmd_peek()
    elif cmd == "size":
        if not rest:
            die("usage: clauck size <scale> [--ctx N] [--model auto|haiku|sonnet|opus] [--strict-mcp]")
        # Parse flags first (accepting them anywhere in the arglist), then
        # take the first non-flag token as the positional scale. This
        # allows `clauck size --strict-mcp 0.5` and `clauck size 0.5 --strict-mcp`
        # to behave identically; the prior code took rest[0] verbatim and
        # died with a spurious "expected float" when the flag was first.
        size_strict_mcp = "--strict-mcp" in rest
        size_ctx = 0
        size_model = "auto"
        positionals: list[str] = []
        i = 0
        while i < len(rest):
            tok = rest[i]
            if tok == "--strict-mcp":
                i += 1
            elif tok == "--ctx" and i + 1 < len(rest):
                try:
                    size_ctx = int(rest[i + 1])
                except ValueError:
                    die(f"--ctx expects an integer, got {rest[i + 1]!r}")
                i += 2
            elif tok == "--model" and i + 1 < len(rest):
                size_model = rest[i + 1]
                i += 2
            elif not tok.startswith("--"):
                positionals.append(tok)
                i += 1
            else:
                i += 1
        if not positionals:
            die("usage: clauck size <scale> [--ctx N] [--model auto|haiku|sonnet|opus] [--strict-mcp]")
        cmd_size(
            positionals[0],
            ctx_tokens=size_ctx,
            model_override=size_model,
            strict_mcp=size_strict_mcp,
        )
    elif cmd == "broken":
        cmd_broken()
    elif cmd == "revive" and rest:
        rev_name = rest[0]
        rev_budget = None
        rev_turns = None
        i = 1
        while i < len(rest):
            if rest[i] == "--budget" and i + 1 < len(rest):
                try:
                    rev_budget = float(rest[i + 1])
                except ValueError:
                    die(f"invalid --budget value: {rest[i + 1]}")
                i += 2
            elif rest[i] == "--turns" and i + 1 < len(rest):
                try:
                    rev_turns = int(rest[i + 1])
                except ValueError:
                    die(f"invalid --turns value: {rest[i + 1]}")
                i += 2
            else:
                i += 1
        cmd_revive(rev_name, budget=rev_budget, turns=rev_turns)
    elif cmd == "discard" and rest:
        cmd_discard(rest[0])
    elif cmd == "add" and rest:
        add_path = ""
        add_name = ""
        add_when = ""
        i = 0
        while i < len(rest):
            if rest[i] == "--name" and i + 1 < len(rest):
                add_name = rest[i + 1]
                i += 2
            elif rest[i] == "--when" and i + 1 < len(rest):
                add_when = rest[i + 1]
                i += 2
            elif not add_path:
                add_path = rest[i]
                i += 1
            else:
                i += 1
        if not add_path:
            die("usage: clauck add <path> [--name NAME] [--when \"schedule\"]")
        cmd_add(add_path, name=add_name, when=add_when)
    elif cmd == "validate":
        if "--all" in rest:
            cmd_validate([], all_jobs=True)
        elif rest:
            cmd_validate([r for r in rest if not r.startswith("-")])
        else:
            die("usage: clauck validate <name> [<name2> ...] | --all")
    elif cmd == "inspect" and rest:
        cmd_inspect(rest[0])
    elif cmd == "doctor":
        # Flag parsing: modes are two pairs with defaults biased toward safety.
        #   --dry (default) / --fix   — analysis-only vs apply fixes
        #   --safe (default) / --unsafe — restrict vs allow system-file mutation
        interactive = "-i" in rest or "--interactive" in rest
        fix_flag = "--fix" in rest
        unsafe_flag = "--unsafe" in rest
        # Explicit --dry and --safe are accepted but are already defaults.
        dry_flag = "--dry" in rest or not fix_flag
        safe_flag = "--safe" in rest or not unsafe_flag
        flag_names = {
            "-i", "--interactive", "--dry", "--fix", "--safe", "--unsafe",
        }
        context_parts = [r for r in rest if not r.startswith("-") and r not in flag_names]
        cmd_doctor(
            dry=dry_flag,
            fix=fix_flag,
            safe=safe_flag,
            unsafe=unsafe_flag,
            interactive=interactive,
            context=" ".join(context_parts),
        )
    elif cmd == "mcp":
        if "--install" in rest:
            cmd_mcp_install()
        else:
            cmd_mcp()
    elif cmd == "report":
        inbox_flag = "--inbox" in rest
        tail = " ".join(r for r in rest if not r.startswith("-"))
        cmd_report(tail, inbox=inbox_flag)
    elif cmd == "cost":
        all_time = "--all" in rest
        days = 30
        cost_rest = list(rest)
        if "--days" in cost_rest:
            idx = cost_rest.index("--days")
            if idx + 1 < len(cost_rest):
                try:
                    days = int(cost_rest[idx + 1])
                except ValueError:
                    die("--days requires an integer")
                cost_rest = [r for i, r in enumerate(cost_rest) if i != idx and i != idx + 1]
            else:
                cost_rest = [r for i, r in enumerate(cost_rest) if i != idx]
        job_filter = next((r for r in cost_rest if not r.startswith("-")), "")
        cmd_cost(name=job_filter, days=days, all_time=all_time)
    elif cmd == "work":
        # `clauck work <text>` is an explicit alias for semantic fallthrough,
        # avoiding conflicts if semantic text starts with a subcommand name.
        cmd_semantic(" ".join(rest) if rest else "show system status")
    elif cmd not in KNOWN_COMMANDS:
        # Semantic fallthrough: anything that isn't a known command is treated
        # as natural-language input for Claude to interpret as a clauck operation.
        cmd_semantic(" ".join(args))
    else:
        print(f"missing argument for: {cmd}", file=sys.stderr)
        print("run `clauck --help` for usage", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
