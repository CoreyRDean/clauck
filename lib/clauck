#!/usr/bin/env python3
"""clauck — your agent, on the clock.

Usage:
    clauck list                          Show all jobs with status
    clauck status                        System overview
    clauck fire <name>                   Ad-hoc trigger a job
    clauck pause <name>                  Disable a job
    clauck resume <name>                 Re-enable a paused job
    clauck edit <name>                   Open job prompt in your editor
    clauck remove <name>                 Delete a job + its state (also: delete, rm)
    clauck logs <name> [--last N]        Show recent logs
    clauck marketplace                    Browse pre-made jobs
    clauck install <marketplace-job>     Install from marketplace
    clauck update [--apply]              Check for / apply updates
    clauck config [set <key> <value>]    Show or edit config
    clauck add <path> [--name N] [--when "schedule"]  Import a file as a job
    clauck inspect <name>                 Inspect a job's config and DAG
    clauck doctor [-i|--interactive]     Diagnose system health
    clauck peek                          Live-tail all job logs (Ctrl+C to stop)
    clauck version                       Show version
    clauck work <text>                   Explicit semantic command (alias)
    clauck <anything else>               Natural-language command (uses Claude)

Examples:
    clauck every morning check my PRs and post to slack
    clauck pause everything for the weekend
    clauck what ran today
    clauck change heartbeat to every 2 hours
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ.get("HOME", str(Path.home())))
JOBS_DIR = HOME / ".claude" / "scheduled-jobs"
STATE_DIR = JOBS_DIR / ".state"
MANIFEST = JOBS_DIR / ".manifest.json"
VERSION_FILE = JOBS_DIR / ".version"
CONFIG_FILE = JOBS_DIR / ".clauck.config.json"
TRIGGER_SCRIPT = JOBS_DIR / "trigger-job.sh"
UPDATE_SCRIPT = JOBS_DIR / "update-check.sh"
MARKETPLACE_DIR = HOME / ".claude" / "skills" / "clauck" / "marketplace"


KNOWN_COMMANDS = {
    "list", "status", "fire", "pause", "resume", "edit", "logs",
    "marketplace", "install", "update", "config", "version", "doctor", "peek", "work",
    "add", "inspect", "remove", "delete", "rm",
    "-h", "--help", "help",
}


# ── helpers ──────────────────────────────────────────────────────────────

def jit_update_check() -> None:
    """Print a one-line update notice if a new version is available.
    Reads the state file left by the background update-check; no network.

    Self-healing: if the installed version (.version file) has caught up to
    the 'latest' recorded in the state file, the state is stale — delete it
    silently. This handles cases where an update applied successfully but
    the state file wasn't cleared (e.g., verification step failed due to
    unrelated issues after files were already copied).
    """
    available = STATE_DIR / ".update-available"
    if not available.exists():
        return
    try:
        upd = json.loads(available.read_text())
        latest = upd.get("latest", "?")
        # Read LIVE installed version, not the stale one from the state file
        installed = "?"
        if VERSION_FILE.exists():
            installed = VERSION_FILE.read_text().strip() or "?"
        if installed == latest and installed != "?":
            # Update already applied — clean up stale marker
            available.unlink()
            return
        if installed != latest:
            print(f"\033[33m  update available: {installed} → {latest}"
                  f" (run: clauck update --apply)\033[0m")
    except (OSError, ValueError, KeyError):
        pass


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def load_manifest() -> dict:
    if not MANIFEST.exists():
        die("manifest not found — is clauck installed?")
    return json.loads(MANIFEST.read_text())


def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except (OSError, ValueError):
            return {}
    return {}


def job_state(name: str) -> dict:
    """Collect state info for a single job."""
    info: dict = {}
    lr = STATE_DIR / f"{name}.last-run"
    if lr.exists():
        try:
            ts = int(lr.read_text().strip())
            info["last_run"] = datetime.fromtimestamp(ts).isoformat()
        except (OSError, ValueError):
            pass
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        try:
            info["auto_disabled"] = json.loads(ad.read_text())
        except (OSError, ValueError):
            info["auto_disabled"] = True
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        try:
            info["runs_remaining"] = int(rr.read_text().strip())
        except (OSError, ValueError):
            pass
    sid = STATE_DIR / f"{name}.session-id"
    if sid.exists():
        info["session_id"] = sid.read_text().strip()
    return info


# ── commands ─────────────────────────────────────────────────────────────

def cmd_list() -> None:
    m = load_manifest()
    jobs = m.get("jobs", [])
    if not jobs:
        print("No jobs registered.")
        return
    for j in jobs:
        name = j["name"]
        cron = j.get("cron") or "(no cron)"
        desc = j.get("description", "")[:60]
        disabled = j.get("disabled", False)
        state = job_state(name)

        status = "active"
        if disabled:
            status = "paused"
        elif state.get("auto_disabled"):
            reason = ""
            if isinstance(state["auto_disabled"], dict):
                reason = f" ({state['auto_disabled'].get('reason', '')})"
            status = f"auto-disabled{reason}"

        extra = ""
        if "runs_remaining" in state:
            extra += f"  runs left: {state['runs_remaining']}"
        if "last_run" in state:
            extra += f"  last: {state['last_run']}"

        print(f"  {name:<25} {cron:<20} [{status}]")
        if desc:
            print(f"    {desc}")
        if extra:
            print(f"   {extra}")


def cmd_status() -> None:
    version = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"
    config = load_config()

    # Check if scheduler is loaded
    result = subprocess.run(
        ["launchctl", "list"],
        capture_output=True, text=True,
    )
    scheduler_running = "claude-scheduler" in result.stdout

    m = load_manifest() if MANIFEST.exists() else {"jobs": []}
    job_count = len(m.get("jobs", []))

    # Count logs
    log_count = len(list(JOBS_DIR.glob("*-[0-9]*.log")))

    auto_update = config.get("auto_update", {})
    repo = config.get("repo", "CoreyRDean/clauck")

    print(f"  clauck {version}")
    print(f"  scheduler: {'running' if scheduler_running else 'NOT RUNNING'}")
    print(f"  jobs: {job_count}")
    print(f"  logs: {log_count}")
    print(f"  repo: {repo}")
    print(f"  auto-update: {'enabled' if auto_update.get('enabled', True) else 'disabled'}"
          f" (auto-apply: {'on' if auto_update.get('auto_apply', False) else 'off'})")

    # Check for pending update
    available = STATE_DIR / ".update-available"
    if available.exists():
        try:
            upd = json.loads(available.read_text())
            print(f"  UPDATE AVAILABLE: {upd.get('installed')} → {upd.get('latest')}")
        except (OSError, ValueError):
            pass


def cmd_fire(name: str, extra_args: list[str] | None = None) -> None:
    if not TRIGGER_SCRIPT.exists():
        die("trigger-job.sh not found")

    args = list(extra_args or [])

    # If any arg is missing '=', treat the tail as semantic context and use the
    # interpreter to convert it to proper KEY=VALUE args.
    if args and any("=" not in a for a in args):
        claude_bin = _find_claude()
        if claude_bin:
            m = load_manifest()
            job_entry = next((j for j in m.get("jobs", []) if j["name"] == name), None)
            declared_inputs = ""
            if job_entry:
                for inp in job_entry.get("inputs", []):
                    if isinstance(inp, dict):
                        iname = inp.get("name", "?")
                        idesc = inp.get("description", "")
                        idefault = inp.get("default", "")
                        declared_inputs += f"  - {iname}: {idesc}"
                        if idefault:
                            declared_inputs += f" (default: {idefault})"
                        declared_inputs += "\n"
                    else:
                        declared_inputs += f"  - {inp}\n"

            semantic_tail = " ".join(args)
            interpret_prompt = (
                f"The user ran: `clauck fire {name} {semantic_tail}`\n"
                f"Job `{name}` declares these inputs:\n{declared_inputs}\n"
                f"Convert the semantic tail into KEY=VALUE args matching the declared inputs.\n"
                f'Return JSON only: {{"args": ["KEY1=VAL1", "KEY2=VAL2"]}}'
            )
            result = subprocess.run(
                [claude_bin, "-p", interpret_prompt,
                 "--max-turns", "3", "--max-budget-usd", "0.05",
                 "--model", "haiku", "--output-format", "text",
                 "--setting-sources", ""],
                capture_output=True, text=True,
            )
            if result.returncode == 0 and result.stdout.strip():
                import re as _re
                raw = result.stdout.strip()
                # Extract JSON from response (may be wrapped in markdown)
                json_match = _re.search(r'\{[^}]+\}', raw)
                if json_match:
                    try:
                        parsed = json.loads(json_match.group(0))
                        resolved = parsed.get("args", [])
                        if resolved and all("=" in a for a in resolved):
                            print(f"  resolved args: {' '.join(resolved)}")
                            args = resolved
                    except (json.JSONDecodeError, KeyError):
                        pass

    cmd = [str(TRIGGER_SCRIPT), name] + args
    result = subprocess.run(cmd, capture_output=True, text=True)
    print(result.stdout.strip())
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)


def cmd_pause(name: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    (STATE_DIR / f"{name}.auto-disabled").write_text(
        json.dumps({"reason": "paused via clauck CLI", "at": datetime.now(timezone.utc).isoformat()})
    )
    print(f"  paused: {name}")


def cmd_resume(name: str) -> None:
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        ad.unlink()
        print(f"  resumed: {name}")
    else:
        print(f"  {name} is not paused/auto-disabled")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_remove(name: str) -> None:
    """Delete a job (standard or module format) + clean up its state.

    Direct filesystem operation — no LLM, no permission prompts.
    """
    import shutil as _shutil
    removed = []

    # Standard format: <name>.md
    flat = JOBS_DIR / f"{name}.md"
    if flat.exists():
        flat.unlink()
        removed.append(str(flat))

    # Module format: <name>/ directory with JOB.md
    module = JOBS_DIR / name
    if module.is_dir() and (module / "JOB.md").exists():
        _shutil.rmtree(module)
        removed.append(f"{module}/ (module)")

    # Clean up state: last-run, session-id, runs-remaining, auto-disabled,
    # producer-outputs, lock.d, trigger state files
    state_patterns = [
        f"{name}.last-run",
        f"{name}.last-start",
        f"{name}.session-id",
        f"{name}.runs-remaining",
        f"{name}.auto-disabled",
    ]
    for pattern in state_patterns:
        f = STATE_DIR / pattern
        if f.exists():
            f.unlink()
    # Glob patterns: lock dirs, producer-outputs, trigger state
    import glob as _glob
    for pat in [
        f"{STATE_DIR}/{name}.lock.d",
        f"{STATE_DIR}/{name}.lock.d/*",
        f"{STATE_DIR}/{name}.producer-outputs-*.json",
        f"{STATE_DIR}/{name}.trigger-*.json",
        f"{STATE_DIR}/{name}.runs-remaining",
    ]:
        for match in _glob.glob(pat):
            p = Path(match)
            if p.is_dir():
                _shutil.rmtree(p)
            elif p.exists():
                p.unlink()

    # Remove logs? User might want them for audit. Leave them — they rotate naturally.

    if not removed:
        die(f"no job found: {name} (checked {flat} and {module}/JOB.md)")

    for r in removed:
        print(f"  removed: {r}")
    print(f"  (logs preserved at {JOBS_DIR}/{name}-*.log)")


def cmd_edit(name: str) -> None:
    """Open job prompt in user's editor, validate on close."""
    job_file = JOBS_DIR / f"{name}.md"
    if not job_file.exists():
        die(f"no job file: {job_file}")

    # Determine editor: VISUAL > EDITOR > fallback
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "nano"

    import shlex
    editor_parts = shlex.split(editor)

    # Record mtime before editing
    mtime_before = job_file.stat().st_mtime

    result = subprocess.run(editor_parts + [str(job_file)])
    if result.returncode != 0:
        print(f"  editor exited with code {result.returncode}", file=sys.stderr)
        return

    # Check if file was modified
    mtime_after = job_file.stat().st_mtime
    if mtime_after == mtime_before:
        print("  no changes detected")
        return

    # Static analysis: check frontmatter parses
    text = job_file.read_text()
    import re
    fm_match = re.match(r"\A---\s*\n(.*?)\n---\s*\n", text, re.DOTALL)
    if not fm_match:
        print("\033[33m  warning: no YAML frontmatter detected (missing --- delimiters)\033[0m")
        return

    # Validate required-ish fields
    fm_text = fm_match.group(1)
    issues = []
    if "cron:" not in fm_text and "external_triggers:" not in fm_text:
        issues.append("no cron or external_triggers — job will only fire via ad-hoc trigger")
    if "max_budget_usd:" not in fm_text:
        issues.append("no max_budget_usd — will use default ($2.00)")
    if "model:" not in fm_text:
        issues.append("no model specified — will use claude default (Opus)")

    if issues:
        print("\033[33m  notes:\033[0m")
        for issue in issues:
            print(f"    - {issue}")
    else:
        print("  \033[32m✓\033[0m saved, looks good. Changes take effect within 60s.")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_logs(name: str, last: int = 5) -> None:
    pattern = f"{name}-[0-9]*.log"
    logs = sorted(JOBS_DIR.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    if not logs:
        print(f"  no logs found for: {name}")
        return
    for log in logs[:last]:
        # Extract key info from log
        text = log.read_text()
        exit_line = ""
        cost = ""
        for line in text.splitlines():
            if "exit_code=" in line:
                exit_line = line.strip()
            if '"total_cost_usd"' in line:
                import re
                m = re.search(r'"total_cost_usd":([\d.]+)', line)
                if m:
                    cost = f"${float(m.group(1)):.4f}"
        ts = log.stem.split("-", 1)[1] if "-" in log.stem else "?"
        print(f"  {ts:<30} {exit_line:<25} {cost}")


def cmd_marketplace(filter_tag: str = "") -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found — run the installer to populate it")
    index = json.loads(index_file.read_text())
    jobs = index.get("jobs", [])

    if filter_tag:
        ft = filter_tag.lower()
        jobs = [j for j in jobs if ft in [t.lower() for t in j.get("tags", [])]]
        if not jobs:
            print(f"  no jobs matching tag: {filter_tag}")
            # Show available tags
            all_tags = set()
            for j in index.get("jobs", []):
                all_tags.update(j.get("tags", []))
            print(f"  available tags: {', '.join(sorted(all_tags))}")
            return

    # Group by first tag (category) for display
    seen_categories: set = set()
    for j in jobs:
        tags = j.get("tags", [])
        category = tags[0] if tags else "uncategorized"
        if category not in seen_categories:
            seen_categories.add(category)
            print(f"\n  [{category}]")
        installed = (JOBS_DIR / f"{j['name']}.md").exists()
        marker = " [installed]" if installed else ""
        cost = j.get("cost_per_run_usd_approx", "?")
        print(f"    {j['name']:<23} ~${cost}/run  {j.get('schedule', '')}{marker}")
        print(f"      {j.get('one_line', '')}")

    # Show all tags
    all_tags = set()
    for j in index.get("jobs", []):
        all_tags.update(j.get("tags", []))
    print(f"\n  filter by tag: clauck marketplace <tag>")
    print(f"  tags: {', '.join(sorted(all_tags))}")


def cmd_install_marketplace(name: str) -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found")
    index = json.loads(index_file.read_text())
    match = [j for j in index.get("jobs", []) if j["name"] == name]
    if not match:
        die(f"no marketplace job named '{name}'. Run `clauck marketplace` to see available jobs.")
    job = match[0]
    src = MARKETPLACE_DIR / job["path"]
    if not src.exists():
        die(f"marketplace file missing: {src}")
    dst = JOBS_DIR / f"{name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or edit directly.")
    import shutil
    shutil.copy2(str(src), str(dst))
    print(f"  installed: {dst}")
    setup = job.get("requires", {}).get("setup", [])
    if setup:
        print(f"  CUSTOMIZE BEFORE FIRST RUN:")
        for step in setup:
            print(f"    - {step}")
    print(f"  test: clauck fire {name}")


def cmd_update(apply: bool = False) -> None:
    if not UPDATE_SCRIPT.exists():
        die("update-check.sh not found")
    args = [str(UPDATE_SCRIPT)]
    if apply:
        args.append("--apply")
    os.execvp(args[0], args)


def cmd_config(args: list[str]) -> None:
    if not args or args[0] != "set":
        config = load_config()
        print(json.dumps(config, indent=2))
        return
    # clauck config set <dotted.key> <value>
    if len(args) < 3:
        die("usage: clauck config set <key> <value>")
    key_path = args[1].split(".")
    value = args[2]
    # Coerce value
    if value.lower() == "true":
        value = True
    elif value.lower() == "false":
        value = False
    else:
        try:
            value = int(value)
        except ValueError:
            try:
                value = float(value)
            except ValueError:
                pass
    config = load_config()
    # Navigate to the nested key
    d = config
    for k in key_path[:-1]:
        d = d.setdefault(k, {})
    d[key_path[-1]] = value
    CONFIG_FILE.write_text(json.dumps(config, indent=2) + "\n")
    print(f"  set {args[1]} = {value}")


def cmd_peek() -> None:
    """Live-tail all job + scheduler + DAG logs in a unified stream."""
    import signal

    print("  clauck peek — live log stream (Ctrl+C to stop)\n")

    # Build the tail command: scheduler stdout/stderr + all job logs
    targets = [
        str(JOBS_DIR / ".scheduler-stdout.log"),
        str(JOBS_DIR / ".scheduler-stderr.log"),
    ]
    # tail -f on existing + future log files via a glob trick:
    # we tail the scheduler logs and use a polling loop to pick up new job logs
    try:
        proc = subprocess.Popen(
            ["tail", "-f"] + targets + ["-n", "0"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        # Also start a background tail on the most recent job logs
        import threading
        import glob
        import time

        seen_files: set = set()

        def watch_new_logs():
            while True:
                current = set(glob.glob(str(JOBS_DIR / "*-[0-9]*.log")))
                new = current - seen_files
                for f in sorted(new):
                    seen_files.add(f)
                    # Start a tail on the new file
                    subprocess.Popen(
                        ["tail", "-f", "-n", "5", f],
                        stderr=subprocess.DEVNULL,
                    )
                time.sleep(2)

        watcher = threading.Thread(target=watch_new_logs, daemon=True)
        watcher.start()

        # Stream scheduler output to terminal
        for line in proc.stdout:
            print(line, end="", flush=True)
    except KeyboardInterrupt:
        proc.terminate()
        print("\n  peek stopped.")


def cmd_version() -> None:
    v = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"
    print(f"clauck {v}")


def cmd_add(path: str, name: str = "", when: str = "") -> None:
    """Import a file as a scheduled job."""
    import shutil
    src = Path(path).expanduser().resolve()
    if not src.exists():
        die(f"file not found: {src}")
    job_name = name or src.stem
    dst = JOBS_DIR / f"{job_name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or use `clauck edit {job_name}`.")
    JOBS_DIR.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(src), str(dst))

    # If the file has no YAML frontmatter, prepend minimal defaults
    text = dst.read_text(encoding="utf-8")
    if not text.startswith("---"):
        header = (
            "---\n"
            f"name: {job_name}\n"
            "max_budget_usd: 2.00\n"
            "effort: high\n"
            "---\n"
        )
        dst.write_text(header + text)

    # If --when provided, use claude to interpret the schedule
    if when:
        claude_bin = _find_claude()
        if claude_bin:
            interpret_prompt = (
                f'The user wants to schedule a job with this timing: "{when}"\n'
                f"Convert this to a 5-field cron expression (minute hour day-of-month month day-of-week).\n"
                f"Reply with ONLY the cron expression, nothing else. Example: 0 9 * * 1-5"
            )
            result = subprocess.run(
                [claude_bin, "-p", interpret_prompt,
                 "--max-turns", "1", "--max-budget-usd", "0.05",
                 "--model", "haiku", "--output-format", "text",
                 "--setting-sources", ""],
                capture_output=True, text=True,
            )
            cron_expr = result.stdout.strip()
            if cron_expr and result.returncode == 0:
                # Insert cron into frontmatter
                text = dst.read_text(encoding="utf-8")
                if "cron:" not in text:
                    # Insert after the opening ---
                    text = text.replace("---\n", f"---\ncron: \"{cron_expr}\"\n", 1)
                    dst.write_text(text)
                print(f"  added: {job_name} (schedule: {cron_expr})")
            else:
                print(f"  added: {job_name} (could not interpret schedule — edit manually)")
        else:
            print(f"  added: {job_name} (claude not found — set cron manually)")
    else:
        print(f"  added: {job_name}")
    print(f"  path: {dst}")
    print(f"  test: clauck fire {job_name}")


def cmd_inspect(name: str) -> None:
    """Inspect a job's full configuration and producer DAG."""
    m = load_manifest()
    jobs = m.get("jobs", [])
    job = None
    for j in jobs:
        if j["name"] == name:
            job = j
            break
    if not job:
        die(f"job not found in manifest: {name}")

    # --- Print full config ---
    print(f"\n  Job: {job['name']}")
    if job.get("description"):
        print(f"  Description: {job['description']}")
    print(f"  Cron: {job.get('cron') or '(none)'}")
    if job.get("module_root"):
        print(f"  Module root: {job['module_root']}")
    print(f"  Prompt: {job.get('prompt_path', '')}")
    print(f"  Disabled: {job.get('disabled', False)}")

    # Show tags
    tags = job.get("tags", [])
    if tags:
        print(f"  Tags: {', '.join(str(t) for t in tags)}")

    # Show triggers
    triggers = job.get("external_triggers", [])
    if triggers:
        print(f"  External triggers:")
        for t in triggers:
            if isinstance(t, dict):
                parts = [f"{k}={v}" for k, v in t.items()]
                print(f"    - {', '.join(parts)}")
            else:
                print(f"    - {t}")

    hooks = job.get("semantic_hooks", [])
    if hooks:
        print(f"  Semantic hooks:")
        for h in hooks:
            print(f"    - {h}")

    # Show inputs
    inputs = job.get("inputs", [])
    if inputs:
        print(f"  Inputs:")
        for inp in inputs:
            if isinstance(inp, dict):
                iname = inp.get("name", "?")
                idefault = inp.get("default", "")
                idesc = inp.get("description", "")
                line = f"    - {iname}"
                if idefault:
                    line += f"  (default: {idefault})"
                if idesc:
                    line += f"  — {idesc}"
                print(line)
            else:
                print(f"    - {inp}")

    # Show producers/consumers
    producers = job.get("producers", [])
    consumers = job.get("consumers", [])
    if producers:
        print(f"  Producers: {', '.join(p['name'] if isinstance(p, dict) else str(p) for p in producers)}")
    if consumers:
        print(f"  Consumers: {', '.join(str(c) for c in consumers)}")

    # --- DAG tree visualization ---
    if producers:
        # Build a lookup from name -> job dict
        job_by_name = {j["name"]: j for j in jobs}

        def build_tree(jname: str, depth: int, visited: set) -> list[tuple[str, int, bool]]:
            """Returns list of (display_name, depth, is_module) tuples."""
            nodes: list[tuple[str, int, bool]] = []
            jobj = job_by_name.get(jname)
            if not jobj:
                return nodes
            prods = jobj.get("producers", [])
            for p in prods:
                pname = p["name"] if isinstance(p, dict) else str(p)
                pobj = job_by_name.get(pname)
                is_mod = bool(pobj.get("module_root", "")) if pobj else False
                nodes.append((pname, depth, is_mod))
                if pname not in visited and depth < 10:
                    visited.add(pname)
                    nodes.extend(build_tree(pname, depth + 1, visited))
            return nodes

        tree = build_tree(name, 0, {name})

        if tree:
            print(f"\n  Producer DAG:")
            print(f"  {name}")

            # Group by parent for proper tree drawing
            # We need to know which items are last at each depth
            # Simpler approach: walk linearly, tracking depth transitions
            for i, (node_name, depth, is_mod) in enumerate(tree):
                # Determine if this is the last sibling at this depth
                is_last = True
                for future_name, future_depth, _ in tree[i + 1:]:
                    if future_depth == depth:
                        is_last = False
                        break
                    if future_depth < depth:
                        break

                # Build prefix
                prefix = ""
                for d in range(depth):
                    # Check if there's still a continuing branch at this depth
                    has_continuation = False
                    for fn, fd, _ in tree[i + 1:]:
                        if fd == d:
                            has_continuation = True
                            break
                        if fd < d:
                            break
                    prefix += "│  " if has_continuation else "   "

                connector = "└─ " if is_last else "├─ "
                suffix = " (module)" if is_mod else ""
                print(f"  {prefix}{connector}{node_name}{suffix}")

            # Show internal files for modules in the tree
            all_tree_names = {node_name for node_name, _, _ in tree}
            all_tree_names.add(name)
            # Show internals only for modules OTHER than the inspected job itself
            # (the inspected job's own internals are shown separately below).
            inspected_root = job.get("module_root", "")
            for tname in sorted(all_tree_names):
                tobj = job_by_name.get(tname)
                if not tobj or not tobj.get("module_root"):
                    continue
                if tobj["module_root"] == inspected_root:
                    continue  # skip — this is the inspected job itself
                mod_root = Path(tobj["module_root"])
                if mod_root.is_dir():
                    internal_mds = sorted(
                        p for p in mod_root.glob("*.md")
                        if p.name != "JOB.md" and not p.name.startswith(".")
                    )
                    if internal_mds:
                        print(f"\n  Module internals: {tname}")
                        for md in internal_mds:
                            print(f"    [internal] {md.stem}")

    # --- Module internals for the inspected job itself (shown once) ---
    if job.get("module_root"):
        mod_root = Path(job["module_root"])
        if mod_root.is_dir():
            internal_mds = sorted(
                p for p in mod_root.glob("*.md")
                if p.name != "JOB.md" and not p.name.startswith(".")
            )
            if internal_mds:
                print(f"\n  Module internals:")
                for md in internal_mds:
                    print(f"    [internal] {md.stem}")

    print()


def cmd_doctor(interactive: bool = False, context: str = "") -> None:
    """Spawn a clauck-work diagnostic session."""
    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found")

    prompt = """Diagnose the clauck scheduled-jobs system on this machine.

Check in order:
1. Is the LaunchAgent loaded? (`launchctl list | grep claude-scheduler`)
2. Is scheduler.py producing output? (`tail ~/.claude/scheduled-jobs/.scheduler-stderr.log`)
3. Is the manifest fresh? (check .manifest.json mtime vs now)
4. Are any jobs auto-disabled unexpectedly? (check .state/*.auto-disabled)
5. Are any jobs failing? (scan recent logs for non-zero exit codes)
6. Is the update check working? (check .state/.update-last-check)
7. Any frontmatter parse errors in job files?

For each issue found: explain the root cause, attempt a fix if safe, report what you did.
For issues needing user input: explain what's needed and how to fix it.
If everything is healthy, say so concisely."""

    if context:
        prompt += f"\n\n## User-provided context\n\n{context}"

    if interactive:
        # Run diagnostic, then open interactive session for follow-up
        result = subprocess.run(
            [claude_bin, "-p", prompt,
             "--append-system-prompt", f"You are clauck doctor. Jobs dir: {JOBS_DIR}. State: {STATE_DIR}. Manifest: {MANIFEST}.",
