#!/usr/bin/env python3
"""clauck — your agent, on the clock.

Usage:
    clauck list                          Show all jobs with status
    clauck status                        System overview
    clauck fire <name>                   Ad-hoc trigger a job
    clauck pause <name>                  Disable a job
    clauck resume <name>                 Re-enable a paused job
    clauck edit <name>                   Open job prompt in your editor
    clauck logs <name> [--last N]        Show recent logs
    clauck marketplace                    Browse pre-made jobs
    clauck install <marketplace-job>     Install from marketplace
    clauck update [--apply]              Check for / apply updates
    clauck config [set <key> <value>]    Show or edit config
    clauck doctor [-i|--interactive]     Diagnose system health
    clauck peek                          Live-tail all job logs (Ctrl+C to stop)
    clauck version                       Show version
    clauck work <text>                   Explicit semantic command (alias)
    clauck <anything else>               Natural-language command (uses Claude)

Examples:
    clauck every morning check my PRs and post to slack
    clauck pause everything for the weekend
    clauck what ran today
    clauck change heartbeat to every 2 hours
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

HOME = Path(os.environ.get("HOME", str(Path.home())))
JOBS_DIR = HOME / ".claude" / "scheduled-jobs"
STATE_DIR = JOBS_DIR / ".state"
MANIFEST = JOBS_DIR / ".manifest.json"
VERSION_FILE = JOBS_DIR / ".version"
CONFIG_FILE = JOBS_DIR / ".clauck.config.json"
TRIGGER_SCRIPT = JOBS_DIR / "trigger-job.sh"
UPDATE_SCRIPT = JOBS_DIR / "update-check.sh"
MARKETPLACE_DIR = HOME / ".claude" / "skills" / "scheduled-jobs" / "marketplace"


KNOWN_COMMANDS = {
    "list", "status", "fire", "pause", "resume", "edit", "logs",
    "marketplace", "install", "update", "config", "version", "doctor", "peek", "work",
    "-h", "--help", "help",
}


# ── helpers ──────────────────────────────────────────────────────────────

def jit_update_check() -> None:
    """Print a one-line update notice if a new version is available.
    Reads the state file left by the background update-check; no network."""
    available = STATE_DIR / ".update-available"
    if not available.exists():
        return
    try:
        upd = json.loads(available.read_text())
        installed = upd.get("installed", "?")
        latest = upd.get("latest", "?")
        if installed != latest:
            print(f"\033[33m  update available: {installed} → {latest}"
                  f" (run: clauck update --apply)\033[0m")
    except (OSError, ValueError, KeyError):
        pass


def die(msg: str) -> None:
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(1)


def load_manifest() -> dict:
    if not MANIFEST.exists():
        die("manifest not found — is clauck installed?")
    return json.loads(MANIFEST.read_text())


def load_config() -> dict:
    if CONFIG_FILE.exists():
        try:
            return json.loads(CONFIG_FILE.read_text())
        except (OSError, ValueError):
            return {}
    return {}


def job_state(name: str) -> dict:
    """Collect state info for a single job."""
    info: dict = {}
    lr = STATE_DIR / f"{name}.last-run"
    if lr.exists():
        try:
            ts = int(lr.read_text().strip())
            info["last_run"] = datetime.fromtimestamp(ts).isoformat()
        except (OSError, ValueError):
            pass
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        try:
            info["auto_disabled"] = json.loads(ad.read_text())
        except (OSError, ValueError):
            info["auto_disabled"] = True
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        try:
            info["runs_remaining"] = int(rr.read_text().strip())
        except (OSError, ValueError):
            pass
    sid = STATE_DIR / f"{name}.session-id"
    if sid.exists():
        info["session_id"] = sid.read_text().strip()
    return info


# ── commands ─────────────────────────────────────────────────────────────

def cmd_list() -> None:
    m = load_manifest()
    jobs = m.get("jobs", [])
    if not jobs:
        print("No jobs registered.")
        return
    for j in jobs:
        name = j["name"]
        cron = j.get("cron") or "(no cron)"
        desc = j.get("description", "")[:60]
        disabled = j.get("disabled", False)
        state = job_state(name)

        status = "active"
        if disabled:
            status = "paused"
        elif state.get("auto_disabled"):
            reason = ""
            if isinstance(state["auto_disabled"], dict):
                reason = f" ({state['auto_disabled'].get('reason', '')})"
            status = f"auto-disabled{reason}"

        extra = ""
        if "runs_remaining" in state:
            extra += f"  runs left: {state['runs_remaining']}"
        if "last_run" in state:
            extra += f"  last: {state['last_run']}"

        print(f"  {name:<25} {cron:<20} [{status}]")
        if desc:
            print(f"    {desc}")
        if extra:
            print(f"   {extra}")


def cmd_status() -> None:
    version = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"
    config = load_config()

    # Check if scheduler is loaded
    result = subprocess.run(
        ["launchctl", "list"],
        capture_output=True, text=True,
    )
    scheduler_running = "claude-scheduler" in result.stdout

    m = load_manifest() if MANIFEST.exists() else {"jobs": []}
    job_count = len(m.get("jobs", []))

    # Count logs
    log_count = len(list(JOBS_DIR.glob("*-[0-9]*.log")))

    auto_update = config.get("auto_update", {})
    repo = config.get("repo", "CoreyRDean/clauck")

    print(f"  clauck {version}")
    print(f"  scheduler: {'running' if scheduler_running else 'NOT RUNNING'}")
    print(f"  jobs: {job_count}")
    print(f"  logs: {log_count}")
    print(f"  repo: {repo}")
    print(f"  auto-update: {'enabled' if auto_update.get('enabled', True) else 'disabled'}"
          f" (auto-apply: {'on' if auto_update.get('auto_apply', False) else 'off'})")

    # Check for pending update
    available = STATE_DIR / ".update-available"
    if available.exists():
        try:
            upd = json.loads(available.read_text())
            print(f"  UPDATE AVAILABLE: {upd.get('installed')} → {upd.get('latest')}")
        except (OSError, ValueError):
            pass


def cmd_fire(name: str) -> None:
    if not TRIGGER_SCRIPT.exists():
        die("trigger-job.sh not found")
    result = subprocess.run([str(TRIGGER_SCRIPT), name], capture_output=True, text=True)
    print(result.stdout.strip())
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)


def cmd_pause(name: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    (STATE_DIR / f"{name}.auto-disabled").write_text(
        json.dumps({"reason": "paused via clauck CLI", "at": datetime.now(timezone.utc).isoformat()})
    )
    print(f"  paused: {name}")


def cmd_resume(name: str) -> None:
    ad = STATE_DIR / f"{name}.auto-disabled"
    if ad.exists():
        ad.unlink()
        print(f"  resumed: {name}")
    else:
        print(f"  {name} is not paused/auto-disabled")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_edit(name: str) -> None:
    """Open job prompt in user's editor, validate on close."""
    job_file = JOBS_DIR / f"{name}.md"
    if not job_file.exists():
        die(f"no job file: {job_file}")

    # Determine editor: VISUAL > EDITOR > fallback
    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR") or "nano"

    import shlex
    editor_parts = shlex.split(editor)

    # Record mtime before editing
    mtime_before = job_file.stat().st_mtime

    result = subprocess.run(editor_parts + [str(job_file)])
    if result.returncode != 0:
        print(f"  editor exited with code {result.returncode}", file=sys.stderr)
        return

    # Check if file was modified
    mtime_after = job_file.stat().st_mtime
    if mtime_after == mtime_before:
        print("  no changes detected")
        return

    # Static analysis: check frontmatter parses
    text = job_file.read_text()
    import re
    fm_match = re.match(r"\A---\s*\n(.*?)\n---\s*\n", text, re.DOTALL)
    if not fm_match:
        print("\033[33m  warning: no YAML frontmatter detected (missing --- delimiters)\033[0m")
        return

    # Validate required-ish fields
    fm_text = fm_match.group(1)
    issues = []
    if "cron:" not in fm_text and "external_triggers:" not in fm_text:
        issues.append("no cron or external_triggers — job will only fire via ad-hoc trigger")
    if "max_budget_usd:" not in fm_text:
        issues.append("no max_budget_usd — will use default ($2.00)")
    if "model:" not in fm_text:
        issues.append("no model specified — will use claude default (Opus)")

    if issues:
        print("\033[33m  notes:\033[0m")
        for issue in issues:
            print(f"    - {issue}")
    else:
        print("  \033[32m✓\033[0m saved, looks good. Changes take effect within 60s.")
    # Also reset runs-remaining if max_runs was exhausted
    rr = STATE_DIR / f"{name}.runs-remaining"
    if rr.exists():
        rr.unlink()
        print(f"  reset runs counter for: {name}")


def cmd_logs(name: str, last: int = 5) -> None:
    pattern = f"{name}-[0-9]*.log"
    logs = sorted(JOBS_DIR.glob(pattern), key=lambda p: p.stat().st_mtime, reverse=True)
    if not logs:
        print(f"  no logs found for: {name}")
        return
    for log in logs[:last]:
        # Extract key info from log
        text = log.read_text()
        exit_line = ""
        cost = ""
        for line in text.splitlines():
            if "exit_code=" in line:
                exit_line = line.strip()
            if '"total_cost_usd"' in line:
                import re
                m = re.search(r'"total_cost_usd":([\d.]+)', line)
                if m:
                    cost = f"${float(m.group(1)):.4f}"
        ts = log.stem.split("-", 1)[1] if "-" in log.stem else "?"
        print(f"  {ts:<30} {exit_line:<25} {cost}")


def cmd_marketplace(filter_tag: str = "") -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found — run the installer to populate it")
    index = json.loads(index_file.read_text())
    jobs = index.get("jobs", [])

    if filter_tag:
        ft = filter_tag.lower()
        jobs = [j for j in jobs if ft in [t.lower() for t in j.get("tags", [])]]
        if not jobs:
            print(f"  no jobs matching tag: {filter_tag}")
            # Show available tags
            all_tags = set()
            for j in index.get("jobs", []):
                all_tags.update(j.get("tags", []))
            print(f"  available tags: {', '.join(sorted(all_tags))}")
            return

    # Group by first tag (category) for display
    seen_categories: set = set()
    for j in jobs:
        tags = j.get("tags", [])
        category = tags[0] if tags else "uncategorized"
        if category not in seen_categories:
            seen_categories.add(category)
            print(f"\n  [{category}]")
        installed = (JOBS_DIR / f"{j['name']}.md").exists()
        marker = " [installed]" if installed else ""
        cost = j.get("cost_per_run_usd_approx", "?")
        print(f"    {j['name']:<23} ~${cost}/run  {j.get('schedule', '')}{marker}")
        print(f"      {j.get('one_line', '')}")

    # Show all tags
    all_tags = set()
    for j in index.get("jobs", []):
        all_tags.update(j.get("tags", []))
    print(f"\n  filter by tag: clauck marketplace <tag>")
    print(f"  tags: {', '.join(sorted(all_tags))}")


def cmd_install_marketplace(name: str) -> None:
    index_file = MARKETPLACE_DIR / "index.json"
    if not index_file.exists():
        die("marketplace not found")
    index = json.loads(index_file.read_text())
    match = [j for j in index.get("jobs", []) if j["name"] == name]
    if not match:
        die(f"no marketplace job named '{name}'. Run `clauck marketplace` to see available jobs.")
    job = match[0]
    src = MARKETPLACE_DIR / job["path"]
    if not src.exists():
        die(f"marketplace file missing: {src}")
    dst = JOBS_DIR / f"{name}.md"
    if dst.exists():
        die(f"job already exists: {dst}. Remove it first or edit directly.")
    import shutil
    shutil.copy2(str(src), str(dst))
    print(f"  installed: {dst}")
    setup = job.get("requires", {}).get("setup", [])
    if setup:
        print(f"  CUSTOMIZE BEFORE FIRST RUN:")
        for step in setup:
            print(f"    - {step}")
    print(f"  test: clauck fire {name}")


def cmd_update(apply: bool = False) -> None:
    if not UPDATE_SCRIPT.exists():
        die("update-check.sh not found")
    args = [str(UPDATE_SCRIPT)]
    if apply:
        args.append("--apply")
    os.execvp(args[0], args)


def cmd_config(args: list[str]) -> None:
    if not args or args[0] != "set":
        config = load_config()
        print(json.dumps(config, indent=2))
        return
    # clauck config set <dotted.key> <value>
    if len(args) < 3:
        die("usage: clauck config set <key> <value>")
    key_path = args[1].split(".")
    value = args[2]
    # Coerce value
    if value.lower() == "true":
        value = True
    elif value.lower() == "false":
        value = False
    else:
        try:
            value = int(value)
        except ValueError:
            try:
                value = float(value)
            except ValueError:
                pass
    config = load_config()
    # Navigate to the nested key
    d = config
    for k in key_path[:-1]:
        d = d.setdefault(k, {})
    d[key_path[-1]] = value
    CONFIG_FILE.write_text(json.dumps(config, indent=2) + "\n")
    print(f"  set {args[1]} = {value}")


def cmd_peek() -> None:
    """Live-tail all job + scheduler + DAG logs in a unified stream."""
    import signal

    print("  clauck peek — live log stream (Ctrl+C to stop)\n")

    # Build the tail command: scheduler stdout/stderr + all job logs
    targets = [
        str(JOBS_DIR / ".scheduler-stdout.log"),
        str(JOBS_DIR / ".scheduler-stderr.log"),
    ]
    # tail -f on existing + future log files via a glob trick:
    # we tail the scheduler logs and use a polling loop to pick up new job logs
    try:
        proc = subprocess.Popen(
            ["tail", "-f"] + targets + ["-n", "0"],
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
        )
        # Also start a background tail on the most recent job logs
        import threading
        import glob
        import time

        seen_files: set = set()

        def watch_new_logs():
            while True:
                current = set(glob.glob(str(JOBS_DIR / "*-[0-9]*.log")))
                new = current - seen_files
                for f in sorted(new):
                    seen_files.add(f)
                    # Start a tail on the new file
                    subprocess.Popen(
                        ["tail", "-f", "-n", "5", f],
                        stderr=subprocess.DEVNULL,
                    )
                time.sleep(2)

        watcher = threading.Thread(target=watch_new_logs, daemon=True)
        watcher.start()

        # Stream scheduler output to terminal
        for line in proc.stdout:
            print(line, end="", flush=True)
    except KeyboardInterrupt:
        proc.terminate()
        print("\n  peek stopped.")


def cmd_version() -> None:
    v = VERSION_FILE.read_text().strip() if VERSION_FILE.exists() else "unknown"
    print(f"clauck {v}")


def cmd_doctor(interactive: bool = False) -> None:
    """Spawn a clauck-work diagnostic session."""
    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found")

    prompt = """Diagnose the clauck scheduled-jobs system on this machine.

Check in order:
1. Is the LaunchAgent loaded? (`launchctl list | grep claude-scheduler`)
2. Is scheduler.py producing output? (`tail ~/.claude/scheduled-jobs/.scheduler-stderr.log`)
3. Is the manifest fresh? (check .manifest.json mtime vs now)
4. Are any jobs auto-disabled unexpectedly? (check .state/*.auto-disabled)
5. Are any jobs failing? (scan recent logs for non-zero exit codes)
6. Is the update check working? (check .state/.update-last-check)
7. Any frontmatter parse errors in job files?

For each issue found: explain the root cause, attempt a fix if safe, report what you did.
For issues needing user input: explain what's needed and how to fix it.
If everything is healthy, say so concisely."""

    if interactive:
        # Run diagnostic, then open interactive session for follow-up
        result = subprocess.run(
            [claude_bin, "-p", prompt,
             "--append-system-prompt", f"You are clauck doctor. Jobs dir: {JOBS_DIR}. State: {STATE_DIR}. Manifest: {MANIFEST}.",
             "--dangerously-skip-permissions",
             "--max-turns", "15", "--max-budget-usd", "0.50",
             "--model", "sonnet", "--output-format", "text",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
        print(result.stdout.strip())
        # Get session ID for interactive follow-up
        # Re-run with json to capture session_id
        result_json = subprocess.run(
            [claude_bin, "-p", "Summarize what you found in one line.",
             "--append-system-prompt", f"You are clauck doctor. Jobs dir: {JOBS_DIR}.",
             "--dangerously-skip-permissions",
             "--max-turns", "1", "--max-budget-usd", "0.05",
             "--model", "haiku", "--output-format", "json",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
        try:
            sid = json.loads(result_json.stdout).get("session_id", "")
            if sid:
                print(f"\n  Opening interactive session for follow-up...")
                os.execvp(claude_bin, [claude_bin, "--resume", sid])
        except (json.JSONDecodeError, KeyError):
            pass
    else:
        result = subprocess.run(
            [claude_bin, "-p", prompt,
             "--append-system-prompt", f"You are clauck doctor. Jobs dir: {JOBS_DIR}. State: {STATE_DIR}. Manifest: {MANIFEST}.",
             "--dangerously-skip-permissions",
             "--max-turns", "15", "--max-budget-usd", "0.50",
             "--model", "sonnet", "--output-format", "text",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
        if result.stdout.strip():
            print(result.stdout.strip())
        if result.returncode != 0 and result.stderr.strip():
            print(result.stderr.strip(), file=sys.stderr)


def _find_claude() -> str | None:
    """Locate the claude binary."""
    for p in [HOME / ".local" / "bin" / "claude", Path("/usr/local/bin/claude")]:
        if p.exists():
            return str(p)
    import shutil
    return shutil.which("claude")


def cmd_semantic(text: str) -> None:
    """Pass natural-language text to Claude for execution against clauck.

    Spawns `claude -p` with a system prompt scoping it to clauck operations.
    The user sees only the result — no indication that an LLM is involved.
    """
    claude_bin = _find_claude()
    if not claude_bin:
        die("claude CLI not found — semantic commands require claude on PATH")

    system_prompt = f"""You are the clauck CLI executing a user's natural-language command.
The user typed: `clauck {text}`

You are scoped EXCLUSIVELY to clauck (scheduled-jobs) operations. Do not do anything
outside this domain. Available operations:
- Create, edit, pause, resume, remove scheduled jobs at {JOBS_DIR}/
- Read the manifest at {MANIFEST}
- Read/write state at {STATE_DIR}/
- Read the marketplace at {MARKETPLACE_DIR}/
- Read/write config at {CONFIG_FILE}
- Fire jobs via {TRIGGER_SCRIPT}
- Read logs at {JOBS_DIR}/<name>-*.log

Respond with ONLY the actionable output. No preamble, no explanation of what you're
doing, no sign-off. Behave like a CLI command: input → output. If the request is
ambiguous, make the best interpretation and execute it. If you cannot satisfy the
request within clauck's domain, say so in one sentence.
Do NOT add any footer, signature, branding, or sign-off to your response."""

    result = subprocess.run(
        [claude_bin, "-p", text,
         "--append-system-prompt", system_prompt,
         "--dangerously-skip-permissions",
         "--max-turns", "10",
         "--max-budget-usd", "0.30",
         "--model", "sonnet",
         "--output-format", "text",
         "--setting-sources", ""],
        capture_output=True, text=True,
    )
    if result.stdout.strip():
        print(result.stdout.strip())
    if result.returncode != 0 and result.stderr.strip():
        print(result.stderr.strip(), file=sys.stderr)
        sys.exit(result.returncode)


# ── main ─────────────────────────────────────────────────────────────────

def main() -> None:
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    # JIT update notice (reads local state file, no network)
    jit_update_check()

    cmd = args[0]
    rest = args[1:]

    if cmd == "list":
        cmd_list()
    elif cmd == "status":
        cmd_status()
    elif cmd == "fire" and rest:
        cmd_fire(rest[0])
    elif cmd == "pause" and rest:
        cmd_pause(rest[0])
    elif cmd == "resume" and rest:
        cmd_resume(rest[0])
    elif cmd == "edit" and rest:
        cmd_edit(rest[0])
    elif cmd == "logs" and rest:
        last = 5
        if "--last" in rest:
            idx = rest.index("--last")
            if idx + 1 < len(rest):
                last = int(rest[idx + 1])
            rest = [r for i, r in enumerate(rest) if i != idx and i != idx + 1]
        cmd_logs(rest[0], last)
    elif cmd == "marketplace":
        cmd_marketplace(filter_tag=rest[0] if rest else "")
    elif cmd == "install" and rest:
        cmd_install_marketplace(rest[0])
    elif cmd == "update":
        cmd_update(apply="--apply" in rest)
    elif cmd == "config":
        cmd_config(rest)
    elif cmd == "version":
        cmd_version()
    elif cmd == "peek":
        cmd_peek()
    elif cmd == "doctor":
        cmd_doctor(interactive=("-i" in rest or "--interactive" in rest))
    elif cmd == "work":
        # `clauck work <text>` is an explicit alias for semantic fallthrough,
        # avoiding conflicts if semantic text starts with a subcommand name.
        cmd_semantic(" ".join(rest) if rest else "show system status")
    elif cmd not in KNOWN_COMMANDS:
        # Semantic fallthrough: anything that isn't a known command is treated
        # as natural-language input for Claude to interpret as a clauck operation.
        cmd_semantic(" ".join(args))
    else:
        print(f"missing argument for: {cmd}", file=sys.stderr)
        print("run `clauck --help` for usage", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
