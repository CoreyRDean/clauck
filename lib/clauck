             "--setting-sources", ""],
            capture_output=True, text=True,
        )
        try:
            sid = json.loads(result_json.stdout).get("session_id", "")
            if sid:
                print(f"\n  Opening interactive session for follow-up...")
                os.execvp(claude_bin, [claude_bin, "--resume", sid])
        except (json.JSONDecodeError, KeyError):
            pass
    else:
        result = subprocess.run(
            [claude_bin, "-p", prompt,
             "--append-system-prompt", f"You are clauck doctor. Jobs dir: {JOBS_DIR}. State: {STATE_DIR}. Manifest: {MANIFEST}.",
             "--dangerously-skip-permissions",
             "--permission-mode", "bypassPermissions",
             "--max-turns", "15", "--max-budget-usd", "0.50",
             "--model", "sonnet", "--output-format", "text",
             "--setting-sources", ""],
            capture_output=True, text=True,
        )
        if result.stdout.strip():
            print(result.stdout.strip())
        if result.returncode != 0 and result.stderr.strip():
            print(result.stderr.strip(), file=sys.stderr)


def _find_claude() -> str | None:
    """Locate the claude binary."""
    for p in [HOME / ".local" / "bin" / "claude", Path("/usr/local/bin/claude")]:
        if p.exists():
            return str(p)
    import shutil
    return shutil.which("claude")


def _build_interpreter_prompt() -> str:
    """Build the stage-1 interpreter system prompt with live manifest data."""
    subcommands = (
        "list, status, fire, pause, resume, edit, logs, marketplace, install, "
        "update, config, doctor, peek, version, add, inspect, work, "
        "remove (aliases: delete, rm)"
    )

    # Read manifest for job descriptions + inputs
    job_descriptions = ""
    if MANIFEST.exists():
        try:
            m = json.loads(MANIFEST.read_text())
            for j in m.get("jobs", []):
                name = j["name"]
                desc = (j.get("description") or "")[:120]
                inputs_list = j.get("inputs", [])
                input_names = []
                for inp in inputs_list:
                    if isinstance(inp, dict):
                        input_names.append(inp.get("name", "?"))
                    else:
                        input_names.append(str(inp))
                inputs_str = ", ".join(input_names) if input_names else "(none)"
                job_descriptions += f"  - {name}: {desc}  [inputs: {inputs_str}]\n"
        except (OSError, ValueError):
            job_descriptions = "  (manifest unreadable)\n"
    else:
        job_descriptions = "  (no manifest found)\n"

    return f"""You are the clauck CLI interpreter (stage 1). Your ONLY job is to classify a user's natural-language input and return a JSON routing decision.

# Known clauck subcommands
{subcommands}

# Registered jobs (from manifest)
{job_descriptions}
# Routing rules

**Pick "deterministic" when the user's intent maps directly to an existing clauck subcommand or job trigger:**
- "Run jobA" / "fire jobA" / "trigger jobA" -> deterministic (clauck fire jobA)
- "show me jobA's last run" / "logs for jobA" -> deterministic (clauck logs jobA)
- "Pause jobA" / "disable jobA" -> deterministic (clauck pause jobA)
- "Resume jobA" / "enable jobA" -> deterministic (clauck resume jobA)
- "Delete jobA" / "remove jobA" / "rm jobA" -> deterministic (clauck remove jobA). Direct filesystem op — always prefer this over Write/Delete via the execution agent.
- "What jobs are running" / "list jobs" -> deterministic (clauck list)
- "System status" / "how is clauck doing" -> deterministic (clauck status)
- "Fire jobA with the source at ~/file.md" -> deterministic; convert to KEY=VALUE args using the job's declared inputs

**Pick "semantic" when the user's intent requires Claude to create, modify, or reason about jobs:**
- "Do X every morning" / "Build a pipeline that..." -> semantic
- "Change heartbeat to every 2 hours" -> semantic
- "Create a job that watches for new PDFs" -> semantic
- "What ran today and were there any failures?" -> semantic (needs log analysis)

# Complexity hints for semantic commands
- Trivial (simple query, single status check): haiku, low effort, 3 turns, $0.05 budget
- Standard (create/modify a single job): sonnet, medium effort, 15 turns, $0.50 budget
- Complex (multi-stage pipeline, module creation, DAG wiring): sonnet or opus, high effort, 40 turns, $2.00 budget

# CRITICAL: Quality of `interpretation` field

The `interpretation` field is the value you add. It is shown to the user as feedback proving you understood their intent. It MUST:

1. **Be a distillation, not a copy.** Never echo the user's words verbatim. Rewrite in your own words capturing the intent.
2. **Read like a CLI directive.** Imperative mood, 6–14 words, no filler, no pronouns ("Create hourly job...", not "I will create...").
3. **Name the concrete artifact.** When creating a job, include the inferred job name. When firing, include the resolved args.
4. **Expose inferred details.** Name the schedule in human terms ("every hour on the hour"), the model tier, and the job type (standard vs module) when relevant.
5. **Never be generic.** "Execute semantic command" or "Run user request" are failures. Be specific about the what and where.

Bad interpretation: "execute: every hour invoke a claude code session to mine..."
Good interpretation: "Create hourly module 'intent-miner' (sonnet, medium budget) that opens a draft PR"

Bad interpretation: "I want to see my jobs"
Good interpretation: "List all registered jobs with schedules and status"

# CRITICAL: Quality of `enhanced_prompt` field (semantic only)

The `enhanced_prompt` is what the execution agent receives. It must:
1. **Preserve all intent** the user expressed.
2. **Add prescriptive structure** the user didn't say but that the execution agent needs (file path, frontmatter fields, module vs standard choice, cron expression).
3. **Remove conversational filler** and reformulate as a task brief.
4. **Scale detail with complexity.** A trivial request stays terse. A complex pipeline gets a structured breakdown.

# Output format

Return ONLY valid JSON, no markdown fencing, no explanation:

For deterministic:
{{"command_type": "deterministic", "interpretation": "<distilled CLI directive>", "deterministic_cmd": "clauck fire jobA SOURCE_PATH=/x"}}

For semantic:
{{"command_type": "semantic", "interpretation": "<distilled CLI directive>", "enhanced_prompt": "<prescriptive task brief>", "exec_model": "haiku"|"sonnet"|"opus", "exec_effort": "low"|"medium"|"high", "exec_max_turns": <int>, "exec_max_budget_usd": <float>}}"""


